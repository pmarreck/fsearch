#!/usr/bin/env bash

set -u

source_root=$(realpath "${1:-.}")
mode=${2:-integrity}
if [ "$mode" != integrity ] && [ "$mode" != --complete ]; then
	printf 'Usage: test_catalogs [SOURCE_ROOT] [--complete]\n' >&2
	exit 2
fi
require_complete=false
if [ "$mode" = --complete ]; then
	require_complete=true
fi
po_dir="$source_root/po"
pot_file="$po_dir/fsearch.pot"
potfiles_file="$po_dir/POTFILES.in"
failures=0

fail() {
	printf 'i18n: %s\n' "$*" >&2
	failures=$((failures + 1))
}

contains_line() {
	awk -v expected="$1" '$0 == expected { found = 1 } END { exit !found }' "$2"
}

count_entries() {
	msgattrib "$1" --no-obsolete "$2" | awk '/^msgid / { count += 1 } END { print count + 0 }'
}

has_concrete_plural_forms() {
	awk '
		/^msgid ""$/ { in_header = 1 }
		in_header && /^"/ {
			line = $0
			sub(/^"/, "", line)
			sub(/"$/, "", line)
			header = header line
		}
		in_header && /^$/ { exit }
		END {
			valid = header ~ /Plural-Forms: nplurals=[1-9][0-9]*; plural=/ \
				&& header !~ /nplurals=INTEGER; plural=EXPRESSION/
			exit !valid
		}
	' "$1"
}

has_expected_plural_forms() {
	case "${1#"$source_root/"}" in
		po/frc.po|po/prs.po)
			expected='"Plural-Forms: nplurals=2; plural=n > 1;\n"'
			;;
		po/ie.po|po/ka.po|po/ur.po)
			expected='"Plural-Forms: nplurals=2; plural=n != 1;\n"'
			;;
		*)
			return 0
			;;
	esac

	sed -n '1,/^$/p' "$1" | grep -Fqx "$expected"
}

has_portable_root_output_format() {
	awk '
		function quoted_value(line,    value) {
			value = line
			sub(/^[^"]*"/, "", value)
			sub(/"$/, "", value)
			return value
		}

		function check_entry() {
			if (msgid == "%s\\tactive=%s monitor=%s one-file-system=%s scan-after-launch=%s rescan-after=%s\\n")
				found = 1
		}

		/^msgid / {
			check_entry()
			msgid = quoted_value($0)
			field = "msgid"
			next
		}

		field == "msgid" && /^"/ {
			msgid = msgid quoted_value($0)
			next
		}

		/^msgstr/ { field = "" }

		END {
			check_entry()
			exit !found
		}
	' "$1"
}

assert_ai_owned_header_provenance() {
	local locale catalog header
	for locale in ar ca et frc ga gl hu ie ka mr prs sk sv te tzm ur zgh; do
		catalog="$po_dir/$locale.po"
		header=$(sed -n '1,/^$/p' "$catalog")
		if [[ "$header" == *'hosted.weblate.org'* ]]; then
			fail "AI-majority catalog retains hosted Weblate provenance: po/$locale.po"
		fi
		if [[ "$header" != *'"X-Generator: tools/translate-po\n"'* ]]; then
			fail "AI-majority catalog lacks tools/translate-po provenance: po/$locale.po"
		fi
	done
}

for source in src/fsearch_cli.c src/fsearch_cli_config.c; do
	if ! contains_line "$source" "$potfiles_file"; then
		fail "missing CLI source from POTFILES.in: $source"
	fi
done

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
cli_pot="$tmp_dir/cli.pot"
template_cli_pot="$tmp_dir/template-cli.pot"
template_config_pot="$tmp_dir/template-config.pot"
template_all_pot="$tmp_dir/template-all.pot"
if ! xgettext \
	--language=C \
	--from-code=UTF-8 \
	--keyword=_ \
	--keyword=N_ \
	--keyword=fsearch_cli_printerr:1 \
	--keyword=C_:1c,2 \
	--keyword=ngettext:1,2 \
	--output="$cli_pot" \
	"$source_root/src/fsearch_cli.c" \
	"$source_root/src/fsearch_cli_config.c" >/dev/null 2>&1; then
	fail 'could not extract CLI gettext messages'
elif [ ! -s "$cli_pot" ]; then
	fail 'CLI/config user-facing strings are not marked for gettext extraction'
elif ! msggrep --location=src/fsearch_cli.c --output-file="$template_cli_pot" "$pot_file" \
	|| ! msggrep --location=src/fsearch_cli_config.c --output-file="$template_config_pot" "$pot_file" \
	|| ! msgcat --use-first --output-file="$template_all_pot" "$template_cli_pot" "$template_config_pot" \
	|| ! msgcmp --use-fuzzy --use-untranslated "$template_all_pot" "$cli_pot" >/dev/null 2>&1; then
	fail 'committed template omits one or more CLI/config gettext messages'
fi
if ! has_portable_root_output_format "$cli_pot"; then
	fail 'CLI root output format is not portable gettext text with six string placeholders'
fi

assert_ai_owned_header_provenance

while IFS= read -r catalog; do
	case "$catalog" in
		"$pot_file") continue ;;
	esac

	if ! msgfmt --check --output-file=/dev/null "$catalog" >/dev/null 2>&1; then
		fail "invalid gettext catalog: ${catalog#"$source_root/"}"
		continue
	fi
	if ! msgcmp --use-fuzzy --use-untranslated "$catalog" "$pot_file" >/dev/null 2>&1; then
		fail "stale catalog template: ${catalog#"$source_root/"}"
	fi

	# Data-quality regression: MT catalogs must not carry cross-language contamination
	# that gettext validation cannot see. (1) The Gaelic CLI-help example comments
	# "# eolaire reatha"/"# cás-íogair" once fell back from ga's phrase table into other
	# languages; they are legitimate ONLY in po/ga.po. (2) The product name must stay the
	# literal "FSearch" (an MT run introduced "FSSearch"/"FSarch").
	if [ "$(basename "$catalog")" != ga.po ]; then
		for irish_fragment in 'eolaire reatha' 'cás-íogair'; do
			if grep -qF "$irish_fragment" "$catalog"; then
				fail "Irish string \"$irish_fragment\" leaked into ${catalog#"$source_root/"} (use the target language or the English source comment, never Gaelic)"
			fi
		done
	fi
	if [ "$(basename "$catalog")" != th.po ] && rg -q -P '[\x{0E00}-\x{0E7F}]' "$catalog"; then
		fail "Thai-script text leaked into ${catalog#"$source_root/"}: only po/th.po may contain Thai"
	fi
	if grep -qE 'FSSearch|FSarch' "$catalog"; then
		fail "misspelled product name in ${catalog#"$source_root/"}: must be the literal \"FSearch\""
	fi
	if ! grep -qF 'FSearch' "$catalog"; then
		fail "product name \"FSearch\" missing from ${catalog#"$source_root/"}"
	fi

	if awk '/^msgid_plural / { found = 1 } END { exit !found }' "$catalog" \
		&& ! has_concrete_plural_forms "$catalog"; then
		fail "catalog with plural entries lacks concrete Plural-Forms: ${catalog#"$source_root/"}"
	fi
	if ! has_expected_plural_forms "$catalog"; then
		fail "catalog has an unexpected Plural-Forms rule: ${catalog#"$source_root/"}"
	fi

	if [ "$require_complete" = true ]; then
		fuzzy=$(count_entries --only-fuzzy "$catalog")
		if [ "$fuzzy" -ne 0 ]; then
			fail "fuzzy entries in ${catalog#"$source_root/"}: $fuzzy"
		fi

		untranslated=$(count_entries --untranslated "$catalog")
		if [ "$untranslated" -ne 0 ]; then
			fail "untranslated entries in ${catalog#"$source_root/"}: $untranslated"
		fi
	fi
done < <(find "$po_dir" -maxdepth 1 -type f -name '*.po' -print | sort)

exit "$failures"
