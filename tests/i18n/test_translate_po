cp "$ollama_env_catalog" "$ollama_slots_invalid_catalog"
printf '%s\n' '{"translations":["ONE"]}' >"$ollama_slots_invalid_response"
before=$(sha256sum "$ollama_slots_invalid_catalog" | awk '{ print $1 }')
ollama_slots_invalid_count_file="$tmp_dir/ollama-slots-invalid-count"
output=$(env -u OPENAI_API_KEY FAKE_OLLAMA_URL=http://127.0.0.1:11434 \
