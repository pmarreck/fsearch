#!/usr/bin/env bash

set -u

translator=${1:?usage: test_translate_po /path/to/translate-po}
failures=0
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
catalog="$tmp_dir/catalog.po"
ollama_catalog="$tmp_dir/ollama-catalog.po"
ollama_env_catalog="$tmp_dir/ollama-env-catalog.po"
ollama_error_catalog="$tmp_dir/ollama-error-catalog.po"
ollama_retry_catalog="$tmp_dir/ollama-retry-catalog.po"
ollama_retry_exhausted_catalog="$tmp_dir/ollama-retry-exhausted-catalog.po"
ollama_header_catalog="$tmp_dir/ollama-header-catalog.po"
ollama_broken_header_catalog="$tmp_dir/ollama-broken-header-catalog.po"
ollama_headerless_catalog="$tmp_dir/ollama-headerless-catalog.po"
ollama_slots_catalog="$tmp_dir/ollama-slots-catalog.po"
ollama_slots_response="$tmp_dir/ollama-slots-response.json"
ollama_slots_invalid_catalog="$tmp_dir/ollama-slots-invalid-catalog.po"
ollama_slots_invalid_response="$tmp_dir/ollama-slots-invalid-response.json"
ollama_slots_plural_catalog="$tmp_dir/ollama-slots-plural-catalog.po"
ollama_slots_plural_response="$tmp_dir/ollama-slots-plural-response.json"
ollama_slots_grouped_catalog="$tmp_dir/ollama-slots-grouped-catalog.po"
ollama_slots_grouped_response="$tmp_dir/ollama-slots-grouped-response.json"
ollama_slots_newline_catalog="$tmp_dir/ollama-slots-newline-catalog.po"
ollama_slots_newline_response="$tmp_dir/ollama-slots-newline-response.json"
ollama_batch_catalog="$tmp_dir/ollama-batch-catalog.po"
ollama_batch_one="$tmp_dir/ollama-batch-one.po"
ollama_batch_two="$tmp_dir/ollama-batch-two.po"
ollama_batch_three="$tmp_dir/ollama-batch-three.po"
partial="$tmp_dir/partial.po"
complete="$tmp_dir/complete.po"
header_changed="$tmp_dir/header-changed.po"
broken_header_keyword="$tmp_dir/broken-header-keyword.po"
headerless_body="$tmp_dir/headerless-body.po"
quote_catalog="$tmp_dir/quote-catalog.po"
quote_unescaped="$tmp_dir/quote-unescaped.po"
multiline_catalog="$tmp_dir/multiline.po"
multiline_partial="$tmp_dir/multiline-partial.po"
format_catalog="$tmp_dir/format.po"
format_bad="$tmp_dir/format-bad.po"
format_good="$tmp_dir/format-good.po"
syntax_bad="$tmp_dir/syntax-bad.po"
unflagged_catalog="$tmp_dir/unflagged-format.po"
unflagged_bad="$tmp_dir/unflagged-format-bad.po"
keyword_catalog="$tmp_dir/keyword-catalog.po"
keyword_unchanged="$tmp_dir/keyword-unchanged.po"
keyword_translated="$tmp_dir/keyword-translated.po"
large_catalog="$tmp_dir/large.po"
large_batch_one="$tmp_dir/large-batch-one.po"
large_batch_two="$tmp_dir/large-batch-two.po"
override_catalog="$tmp_dir/override.po"
override_batch_one="$tmp_dir/override-batch-one.po"
override_batch_two="$tmp_dir/override-batch-two.po"
override_batch_three="$tmp_dir/override-batch-three.po"
fake_bin="$tmp_dir/bin"
locale_names="$tmp_dir/LOCALE_NAMES"
mkdir -p "$fake_bin"

printf 'xx\tTest language\n' >"$locale_names"

fail() {
	printf 'i18n translate-po: %s\n' "$*" >&2
	failures=$((failures + 1))
}

run_translator() {
	bash "$translator" "$@"
}

for invalid_batch_size in abc 0 -5 3.5; do
	output=$(FSEARCH_TRANSLATE_BATCH_SIZE="$invalid_batch_size" run_translator --dry-run "$catalog" 2>&1)
	rc=$?
	if [ "$rc" -ne 2 ]; then
		fail "accepted invalid batch size $invalid_batch_size: $output"
	elif [[ "$output" != *'must be a positive integer'* ]]; then
		fail "rejected invalid batch size $invalid_batch_size without an actionable error: $output"
	fi
done

header() {
	awk '
		/^msgid ""$/ { in_header = 1 }
		in_header { print }
		in_header && /^$/ { exit }
	' "$1"
}

printf '%s\n' \
	'msgid ""' \
	'msgstr ""' \
	'"Language: xx\n"' \
	'"Content-Type: text/plain; charset=UTF-8\n"' \
	'"Content-Transfer-Encoding: 8bit\n"' \
	'' \
	'#: source-one' \
	'msgid "one"' \
	'msgstr ""' \
	'' \
	'#: source-two' \
	'msgid "two"' \
	'msgstr ""' >"$catalog"

cp "$catalog" "$ollama_catalog"
cp "$catalog" "$ollama_env_catalog"
cp "$catalog" "$ollama_error_catalog"
cp "$catalog" "$ollama_retry_catalog"
cp "$catalog" "$ollama_retry_exhausted_catalog"
cp "$catalog" "$ollama_header_catalog"
cp "$catalog" "$ollama_broken_header_catalog"
cp "$catalog" "$ollama_headerless_catalog"
cp "$catalog" "$ollama_slots_catalog"
printf '%s\n' '{"translations":["ONE","TWO"]}' >"$ollama_slots_response"

header "$catalog" >"$partial"
printf '%s\n' \
	'msgid "one"' \
	'msgstr "ONE"' >>"$partial"

header "$catalog" >"$complete"
printf '%s\n' \
	'msgid "one"' \
	'msgstr "ONE"' \
	'' \
	'msgid "two"' \
	'msgstr "TWO"' >>"$complete"

sed 's/Content-Transfer-Encoding: 8bit/Content-Transfer-Encoding: changed/' "$complete" >"$header_changed"
sed '0,/^msgid ""$/s//msg_id ""/' "$complete" >"$broken_header_keyword"
awk 'saw_body { print } /^$/ { saw_body = 1 }' "$complete" >"$headerless_body"

printf '%s\n' \
	'msgid ""' \
	'msgstr ""' \
	'"Language: xx\n"' \
	'"Content-Type: text/plain; charset=UTF-8\n"' \
	'"Content-Transfer-Encoding: 8bit\n"' \
	'' \
	'msgid "quoted \"fsearch\" example"' \
	'msgstr ""' >"$quote_catalog"
header "$quote_catalog" >"$quote_unescaped"
printf '%s\n' \
	'msgid "quoted "fsearch" example"' \
	'msgstr "citation "fsearch" traduite"' >>"$quote_unescaped"

printf '%s\n' \
	'msgid ""' \
	'msgstr ""' \
	'"Language: xx\n"' \
	'"Content-Type: text/plain; charset=UTF-8\n"' \
	'"Content-Transfer-Encoding: 8bit\n"' \
	'' \
	'msgid ""' \
	'"A message that begins on a continuation line\n"' \
	'"must still be counted."' \
	'msgstr ""' >"$multiline_catalog"

header "$multiline_catalog" >"$multiline_partial"

printf '%s\n' \
	'msgid ""' \
	'msgstr ""' \
	'"Language: xx\n"' \
	'"Content-Type: text/plain; charset=UTF-8\n"' \
	'"Content-Transfer-Encoding: 8bit\n"' \
	'"Plural-Forms: nplurals=2; plural=n != 1;\n"' \
	'' \
	'#, c-format' \
	'msgid "Do you really want to open %'"'"'d file?"' \
	'msgid_plural "Do you really want to open %'"'"'d files?"' \
	'msgstr[0] ""' \
	'msgstr[1] ""' >"$format_catalog"

header "$format_catalog" >"$format_bad"
printf '%s\n' \
	'#, c-format' \
	'msgid "Do you really want to open %'"'"'d file?"' \
	'msgid_plural "Do you really want to open %'"'"'d files?"' \
	'msgstr[0] "Benetan %d fitxategi ireki nahi dituzu?"' \
	'msgstr[1] "Benetan %d fitxategi ireki nahi dituzu?"' >>"$format_bad"

header "$format_catalog" >"$format_good"
printf '%s\n' \
	'#, c-format' \
	'msgid "Do you really want to open %'"'"'d file?"' \
	'msgid_plural "Do you really want to open %'"'"'d files?"' \
	'msgstr[0] "Benetan %'"'"'d fitxategi ireki nahi dituzu?"' \
	'msgstr[1] "Benetan %'"'"'d fitxategi ireki nahi dituzu?"' >>"$format_good"

cp "$format_catalog" "$ollama_slots_plural_catalog"
printf '%s\n' '{"translations":["Open %'"'"'d file?","Open %'"'"'d files?"]}' >"$ollama_slots_plural_response"
cp "$format_catalog" "$ollama_slots_grouped_catalog"
printf '%s\n' '{"translations":["Open %d file?","Open %d files?"]}' >"$ollama_slots_grouped_response"

printf '%s\n' \
	'msgid ""' \
	'msgstr ""' \
	'"Language: xx\n"' \
	'"Content-Type: text/plain; charset=UTF-8\n"' \
	'"Content-Transfer-Encoding: 8bit\n"' \
	'"Plural-Forms: nplurals=2; plural=n != 1;\n"' \
	'' \
	'msgid "Singular source line\n"' \
	'msgstr ""' \
	'' \
	'msgid "One plural source line\n"' \
	'msgid_plural "Many plural source lines\n"' \
	'msgstr[0] ""' \
	'msgstr[1] ""' \
	'' \
	'msgid "Literal source \\n"' \
	'msgstr ""' >"$ollama_slots_newline_catalog"
printf '%s\n' '{"translations":["Ligne source unique","Une ligne source","Plusieurs lignes source","Source litterale"]}' >"$ollama_slots_newline_response"

header "$format_catalog" >"$syntax_bad"
printf '%s\n' \
	'#, c-format' \
	'msgid "Do you really want to open %'"'"'d file?"' \
	'msgid_plural "Do you really want to open %'"'"'d files?"' \
	'msgstr[0] "Benetan %'"'"'d fitxategi ireki nahi dituzu?"' \
	'msgstr[1] "unterminated' >>"$syntax_bad"

printf '%s\n' \
	'msgid ""' \
	'msgstr ""' \
	'"Language: xx\n"' \
	'"Content-Type: text/plain; charset=UTF-8\n"' \
	'"Content-Transfer-Encoding: 8bit\n"' \
	'' \
	'msgid "%s\tactive=%s"' \
	'msgstr ""' >"$unflagged_catalog"

header "$unflagged_catalog" >"$unflagged_bad"
printf '%s\n' \
	'msgid "%s\tactive=%s"' \
	'msgstr "active=%s"' >>"$unflagged_bad"

header "$catalog" >"$keyword_catalog"
printf '%s\n' \
	'#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:10' \
	'msgid "search;fsearch;files;folders;music;video;documents;find;tool;everything;"' \
	'msgstr ""' >>"$keyword_catalog"

header "$keyword_catalog" >"$keyword_unchanged"
printf '%s\n' \
	'#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:10' \
	'msgid "search;fsearch;files;folders;music;video;documents;find;tool;everything;"' \
	'msgstr "search;fsearch;files;folders;music;video;documents;find;tool;everything;"' >>"$keyword_unchanged"

header "$keyword_catalog" >"$keyword_translated"
printf '%s\n' \
	'#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:10' \
	'msgid "search;fsearch;files;folders;music;video;documents;find;tool;everything;"' \
	'msgstr "recherche;fsearch;fichiers;dossiers;musique;video;documents;trouver;outil;tout;"' >>"$keyword_translated"

printf '%s\n' \
	"#!$BASH" \
	'data_file=""' \
	'expect_data_file=false' \
	'expect_value=""' \
	'no_buffer=false' \
	'max_time=""' \
	'speed_limit=""' \
	'speed_time=""' \
	'for argument in "$@"; do' \
	'  if [ "$expect_data_file" = true ]; then' \
	'    data_file="$argument"' \
	'    expect_data_file=false' \
	'    continue' \
	'  fi' \
	'  if [ -n "$expect_value" ]; then' \
	'    case "$expect_value" in' \
	'      max_time) max_time="$argument" ;;' \
	'      speed_limit) speed_limit="$argument" ;;' \
	'      speed_time) speed_time="$argument" ;;' \
	'    esac' \
	'    expect_value=""' \
	'    continue' \
	'  fi' \
	'  case "$argument" in' \
	'    --data-binary) expect_data_file=true ;;' \
	'    --no-buffer) no_buffer=true ;;' \
	'    --max-time) expect_value=max_time ;;' \
	'    --speed-limit) expect_value=speed_limit ;;' \
	'    --speed-time) expect_value=speed_time ;;' \
	'    *test-key*) printf "credential leaked through curl argv\n" >&2; exit 99 ;;' \
	'  esac' \
	'done' \
	'request_path=$(printf "%s" "$data_file" | cut -c 2-)' \
	'if [[ "$data_file" != @* ]] || [ ! -s "$request_path" ]; then' \
	'  printf "request body was not passed through a readable file\n" >&2' \
	'  exit 98' \
	'fi' \
	'if [ "$no_buffer" != true ] || [ "$max_time" != 900 ] || [ "$speed_limit" != 1 ] || [ "$speed_time" != 60 ]; then' \
	'  printf "translation request did not use the streaming timeout policy\n" >&2' \
	'  exit 97' \
	'fi' \
	'if ! jq -e '\''.stream == true and .reasoning.effort == "none" and .max_output_tokens == 10000'\'' "$request_path" >/dev/null; then' \
	'  printf "translation request did not request streamed batches\n" >&2' \
	'  exit 96' \
	'fi' \
	'call=1' \
	'if [ -n "${FAKE_CURL_COUNT_FILE-}" ]; then' \
	'  if [ -s "$FAKE_CURL_COUNT_FILE" ]; then call=$(($(cat "$FAKE_CURL_COUNT_FILE") + 1)); fi' \
	'  printf "%s\n" "$call" >"$FAKE_CURL_COUNT_FILE"' \
	'fi' \
	'if [ -n "${FAKE_EXPECT_BATCH_SIZES-}" ]; then' \
	'  expected=$(printf "%s" "$FAKE_EXPECT_BATCH_SIZES" | cut -d, -f "$call")' \
	'  actual=$(jq -r '\''.input'\'' "$request_path" | awk '\''/^msgid / && $0 != "msgid \"\"" { count += 1 } END { print count + 0 }'\'')' \
	'  if [ "$actual" != "$expected" ]; then' \
	'    printf "expected batch %s to contain %s entries, got %s\n" "$call" "$expected" "$actual" >&2' \
	'    exit 95' \
	'  fi' \
	'fi' \
	'if [ "${FAKE_STREAM_ERROR-false}" = true ]; then' \
	'  printf '\''event: error\ndata: {"type":"error","message":"model rejected request"}\n\n'\''' \
	'  exit 0' \
	'fi' \
	'translation_path=$(printenv "FAKE_TRANSLATION_$call" 2>/dev/null || true)' \
	'if [ -z "$translation_path" ]; then translation_path=${FAKE_TRANSLATION-}; fi' \
	'translation=$(jq -n --rawfile po "$translation_path" '\''{po:$po}'\'')' \
	'first=${translation:0:7}' \
	'rest=${translation:7}' \
	'for delta in "$first" "$rest"; do' \
	'  event=$(jq -nc --arg delta "$delta" '\''{type:"response.output_text.delta", delta:$delta}'\'')' \
	'  printf "event: response.output_text.delta\n"' \
	'  printf "data: %s\n\n" "$event"' \
	'done' \
	'printf '\''event: response.completed\ndata: {"type":"response.completed","response":{"status":"completed"}}\n\n'\''' >"$fake_bin/curl"
chmod +x "$fake_bin/curl"

fake_ollama_bin="$tmp_dir/ollama-bin"
mkdir -p "$fake_ollama_bin"
printf '%s\n' \
	"#!$BASH" \
	'data_file=""' \
	'endpoint=""' \
	'no_buffer=false' \
	'max_time=""' \
	'speed_limit=""' \
	'speed_time=""' \
	'expect_value=""' \
	'for argument in "$@"; do' \
	'  if [ "$expect_value" = data_file ]; then data_file="$argument"; expect_value=""; continue; fi' \
	'  if [ -n "$expect_value" ]; then' \
	'    case "$expect_value" in max_time) max_time="$argument" ;; speed_limit) speed_limit="$argument" ;; speed_time) speed_time="$argument" ;; esac' \
	'    expect_value=""; continue' \
	'  fi' \
	'  case "$argument" in' \
	'    --data-binary) expect_value=data_file ;;' \
	'    --no-buffer) no_buffer=true ;;' \
	'    --max-time) expect_value=max_time ;;' \
	'    --speed-limit) expect_value=speed_limit ;;' \
	'    --speed-time) expect_value=speed_time ;;' \
	'    --config|Authorization:*) printf "Ollama request used OpenAI credential transport\\n" >&2; exit 94 ;;' \
	'    http://*|https://*) endpoint="$argument" ;;' \
	'  esac' \
	'done' \
	'request_path=$(printf "%s" "$data_file" | cut -c 2-)' \
	'if [[ "$data_file" != @* ]] || [ ! -s "$request_path" ]; then printf "Ollama request body was not passed through a readable file\\n" >&2; exit 93; fi' \
	'if [ "$endpoint" != "${FAKE_OLLAMA_URL}/api/chat" ]; then printf "unexpected Ollama endpoint: %s\\n" "$endpoint" >&2; exit 92; fi' \
	'if [ "$no_buffer" != true ] || [ "$max_time" != 900 ] || [ "$speed_limit" != 1 ] || [ "$speed_time" != 60 ]; then printf "Ollama request did not use the streaming timeout policy\\n" >&2; exit 91; fi' \
	'if ! jq -e '\'' .model == "gemma4:12b" and .stream == true and .think == false and .options.temperature == 0 and .options.num_predict == 10000 and .format.required == ["translations"] and .format.properties.translations.type == "array" and .format.properties.translations.items.type == "string" and ([.messages[].role] == ["system", "user"]) and ([.messages[].content] | join("\n") | contains("Do not generate GNU PO syntax")) and ([.messages[].content] | join("\n") | contains("semicolon-separated desktop keyword list")) and ([.messages[].content] | join("\n") | contains("human-readable prose in CLI usage and diagnostic messages")) and ([.messages[].content] | join("\n") | contains("Usage: fsearch config get KEY [--json]")) and ([.messages[].content] | join("\n") | contains("Cou_per")) and ([.messages[].content] | join("\n") | contains("Target language: Test language (xx)")) '\'' "$request_path" >/dev/null; then printf "Ollama request did not include a human-readable target language\\n" >&2; exit 90; fi' \
	'call=1' \
	'if [ -n "${FAKE_OLLAMA_COUNT_FILE-}" ]; then if [ -s "$FAKE_OLLAMA_COUNT_FILE" ]; then call=$(($(cat "$FAKE_OLLAMA_COUNT_FILE") + 1)); fi; printf "%s\\n" "$call" >"$FAKE_OLLAMA_COUNT_FILE"; fi' \
	'if [ -n "${FAKE_OLLAMA_EXPECT_BATCH_SIZES-}" ]; then expected=$(printf "%s" "$FAKE_OLLAMA_EXPECT_BATCH_SIZES" | cut -d, -f "$call"); actual=$(jq -r '\''.messages[1].content'\'' "$request_path" | awk '\''/^msgid / && $0 != "msgid \"\"" { count += 1 } END { print count + 0 }'\''); if [ "$actual" != "$expected" ]; then printf "expected Ollama batch %s to contain %s entries, got %s\\n" "$call" "$expected" "$actual" >&2; exit 89; fi; fi' \
	'if [ "${FAKE_OLLAMA_ERROR-false}" = true ]; then jq -nc '\''{error:"model rejected request"}'\''; exit 0; fi' \
	'response_path=$(printenv FAKE_OLLAMA_RESPONSE_PATH 2>/dev/null || true)' \
	'translation_path=$(printenv "FAKE_OLLAMA_TRANSLATION_$call" 2>/dev/null || true)' \
	'if [ -z "$translation_path" ]; then translation_path=${FAKE_TRANSLATION-}; fi' \
	'if [ -n "$response_path" ]; then translation=$(cat "$response_path"); else translation=$(jq -n --rawfile po "$translation_path" '\''{po:$po}'\''); fi' \
	'first=${translation:0:7}' \
	'rest=${translation:7}' \
	'for content in "$first" "$rest"; do jq -nc --arg content "$content" '\''{model:"gemma4:12b", message:{role:"assistant", content:$content}, done:false}'\''; done' \
	'if [ "${FAKE_OLLAMA_DONE-true}" = true ]; then jq -nc '\''{model:"gemma4:12b", message:{role:"assistant", content:""}, done:true, done_reason:"stop"}'\''; fi' >"$fake_ollama_bin/curl"
chmod +x "$fake_ollama_bin/curl"

before=$(sha256sum "$catalog" | awk '{ print $1 }')
output=$(OPENAI_API_KEY=test-key FAKE_TRANSLATION="$partial" PATH="$fake_bin:$PATH" \
	run_translator --apply "$catalog" 2>&1)
rc=$?
after=$(sha256sum "$catalog" | awk '{ print $1 }')

if [ "$rc" -eq 0 ]; then
	fail "accepted a response that omitted a requested entry: $output"
elif [[ "$output" != *'translation response omitted or left empty'* ]]; then
	fail "rejected the response for an unexpected reason: $output"
fi
if [ "$before" != "$after" ]; then
	fail 'modified the catalog after rejecting an incomplete response'
fi

before=$(sha256sum "$multiline_catalog" | awk '{ print $1 }')
output=$(OPENAI_API_KEY=test-key FAKE_TRANSLATION="$multiline_partial" PATH="$fake_bin:$PATH" \
	run_translator --apply "$multiline_catalog" 2>&1)
rc=$?
after=$(sha256sum "$multiline_catalog" | awk '{ print $1 }')
if [ "$rc" -eq 0 ]; then
	fail "accepted a response that omitted a multiline requested entry: $output"
elif [[ "$output" != *'translation response omitted or left empty'* ]]; then
	fail "rejected the multiline response for an unexpected reason: $output"
fi
if [ "$before" != "$after" ]; then
	fail 'modified the catalog after rejecting an incomplete multiline response'
fi

output=$(OPENAI_API_KEY=test-key FAKE_STREAM_ERROR=true PATH="$fake_bin:$PATH" \
	run_translator --apply "$catalog" 2>&1)
rc=$?
if [ "$rc" -eq 0 ]; then
	fail "accepted a streamed API error: $output"
elif [[ "$output" != *'model rejected request'* ]]; then
	fail "discarded the streamed API error detail: $output"
fi

output=$(OPENAI_API_KEY=test-key FAKE_TRANSLATION="$complete" PATH="$fake_bin:$PATH" \
	run_translator --apply "$catalog" 2>&1)
rc=$?
if [ "$rc" -ne 0 ]; then
	fail "rejected a complete streamed response: $output"
fi
output=$(OPENAI_API_KEY=test-key FAKE_TRANSLATION="$quote_unescaped" PATH="$fake_bin:$PATH" \
	run_translator --apply "$quote_catalog" 2>&1)
rc=$?
if [ "$rc" -ne 0 ]; then
	fail "did not canonicalize unescaped quote characters in a completed PO response: $output"
elif ! awk '$0 == "msgstr \"citation \\\"fsearch\\\" traduite\"" { found = 1 } END { exit !found }' "$quote_catalog"; then
	fail 'did not retain escaped literal quotes in the normalized translation'
fi
if msgattrib --untranslated --no-obsolete "$catalog" | awk '/^msgid / { found = 1 } END { exit found ? 0 : 1 }'; then
	fail 'left an untranslated entry after accepting a complete response'
fi
for reference in source-one source-two; do
	if ! awk -v expected="#: $reference" '$0 == expected { found = 1 } END { exit !found }' "$catalog"; then
		fail "discarded source reference: $reference"
	fi
done

before=$(sha256sum "$keyword_catalog" | awk '{ print $1 }')
output=$(OPENAI_API_KEY=test-key FAKE_TRANSLATION="$keyword_unchanged" PATH="$fake_bin:$PATH" \
	run_translator --apply "$keyword_catalog" 2>&1)
rc=$?
after=$(sha256sum "$keyword_catalog" | awk '{ print $1 }')
if [ "$rc" -eq 0 ]; then
	fail "accepted an unchanged desktop discovery keyword list: $output"
elif [[ "$output" != *'left a desktop keyword list unchanged'* ]]; then
	fail "rejected an unchanged desktop discovery keyword list unclearly: $output"
fi
if [ "$before" != "$after" ]; then
	fail 'modified the catalog after rejecting an unchanged desktop discovery keyword list'
fi

output=$(OPENAI_API_KEY=test-key FAKE_TRANSLATION="$keyword_translated" PATH="$fake_bin:$PATH" \
	run_translator --apply "$keyword_catalog" 2>&1)
rc=$?
if [ "$rc" -ne 0 ]; then
	fail "rejected a localized desktop discovery keyword list: $output"
fi

before=$(sha256sum "$ollama_error_catalog" | awk '{ print $1 }')
output=$(env -u OPENAI_API_KEY FAKE_OLLAMA_URL=http://127.0.0.1:11434 FAKE_OLLAMA_ERROR=true \
	PATH="$fake_ollama_bin:$PATH" bash "$translator" --apply --backend ollama "$ollama_error_catalog" 2>&1)
rc=$?
after=$(sha256sum "$ollama_error_catalog" | awk '{ print $1 }')
if [ "$rc" -eq 0 ]; then
	fail "accepted a structured Ollama stream error: $output"
elif [[ "$output" != *'Ollama stream failed: model rejected request'* ]]; then
	fail "discarded a structured Ollama stream error detail: $output"
fi
if [ "$before" != "$after" ]; then
	fail 'modified the catalog after rejecting a structured Ollama stream error'
