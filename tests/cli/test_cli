#!/usr/bin/env bash

set -u

binary=${1:?usage: test_cli /path/to/fsearch}
failures=0

fail() {
	printf 'FAIL: %s\n' "$1" >&2
	failures=$((failures + 1))
}

assert_success_contains() {
	local description=$1
	local expected=$2
	shift 2
	local output rc
	output=$("$@" 2>&1)
	rc=$?
	if [ "$rc" -ne 0 ]; then
		fail "$description returned $rc: $output"
	elif [[ "$output" != *"$expected"* ]]; then
		fail "$description did not contain $expected: $output"
	fi
}

assert_success_contains 'CLI help' 'Usage: fsearch --cli' "$binary" --cli --help
assert_success_contains 'CLI help examples' 'Examples:' "$binary" --cli --help
assert_success_contains 'CLI help regex example' 'file:regex:".+\.pdf$"' "$binary" --cli --help
assert_success_contains 'CLI help case-sensitive example' "case:AGENTS" "$binary" --cli --help
assert_success_contains 'CLI help case-sensitive regex example' 'case:regex:"^AGENTS\.md$"' "$binary" --cli --help
assert_success_contains 'CLI help glob example' 'glob:*.png' "$binary" --cli --help
assert_success_contains 'CLI help case-sensitive glob example' 'case:glob:AGENTS.md' "$binary" --cli --help
assert_success_contains 'CLI help glob syntax' 'Glob syntax:' "$binary" --cli --help
assert_success_contains 'CLI help glob escaping' '\* matches a literal *' "$binary" --cli --help
assert_success_contains 'CLI help explicit boolean syntax' 'Boolean syntax: AND or &&; OR or ||; NOT or !.' "$binary" --cli --help
assert_success_contains 'CLI help unlimited alias' '--unlimit, --unlimited' "$binary" --cli --help
assert_success_contains 'CLI unlimited alias parses' '--unlimit, --unlimited' "$binary" --cli --unlimited --help
assert_success_contains 'CLI about' 'indexed file search for' "$binary" --cli --about
assert_success_contains 'CLI version compatibility' 'FSearch 0.3-beta2' "$binary" --cli --version
assert_success_contains 'environment-selected CLI help' '--unlimit' env FSEARCH_UI=CLI "$binary" --help
assert_success_contains 'explicit GUI overrides CLI environment' 'FSearch 0.3-beta2' env FSEARCH_UI=CLI "$binary" --gui --version

exit "$failures"
