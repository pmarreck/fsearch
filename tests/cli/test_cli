assert_success_contains 'config root mutation warns about stale index' 'next CLI search will rebuild it' "${config_env[@]}" "$binary" config roots set "$root_with_spaces" --inactive
assert_success_contains 'config excludes add' '*.tmp' "${config_env[@]}" "$binary" config excludes add --type wildcard --scope basename --target files '*.tmp'
assert_success_contains 'config excludes persist' '*.tmp' "${config_env[@]}" "$binary" config excludes list
assert_success_contains 'config excludes hidden set' 'exclude-hidden = true' "${config_env[@]}" "$binary" config excludes hidden true
assert_success_contains 'config excludes hidden persist' 'true' "${config_env[@]}" "$binary" config excludes hidden
assert_success_contains 'config filters add' 'My PDFs' "${config_env[@]}" "$binary" config filters add --query 'ext:pdf' --macro docs --case --no-case 'My PDFs'
