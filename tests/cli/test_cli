assert_success_contains 'config set shared refresh interval' 'database.refresh-interval = 3600' "${config_env[@]}" "$binary" config set database.refresh-interval 3600
assert_success_contains 'config get shared refresh interval' '3600' "${config_env[@]}" "$binary" config get database.refresh-interval
assert_failure_contains 'config rejects invalid refresh mode' 'invalid value' "${config_env[@]}" "$binary" config set database.refresh-mode sometimes
folder_command='open "quoted"\folder'
assert_success_contains 'config set string with escapes' "$folder_command" "${config_env[@]}" "$binary" config set application.folder-open-command "$folder_command"
assert_success_contains 'config roots add path with spaces' "$root_with_spaces" "${config_env[@]}" "$binary" config roots add --monitor --rescan-every 4294967296 "$root_with_spaces"
