assert_success_contains 'CLI help refresh interval override' '--reindex-interval SECONDS' "$binary" --cli --help
assert_success_contains 'CLI help config command' 'fsearch config --help' "$binary" --cli --help
assert_success_contains 'CLI unlimited alias parses' '--unlimit, --unlimited' "$binary" --cli --unlimited --help
assert_failure_contains 'CLI rejects invalid refresh interval' 'requires a non-negative number of seconds' "$binary" --cli --reindex-interval -1
assert_failure_contains 'later no-reindex overrides refresh' 'index is unavailable and automatic reindexing is disabled' "$binary" --cli --global --refresh --no-reindex --search needle
assert_success_contains 'config help' 'Configuration commands:' "$binary" config --help
assert_success_contains 'config help roots' 'roots list|add|set|remove' "$binary" config --help
assert_success_contains 'config help exclusions' 'excludes list|add|remove|hidden' "$binary" config --help
assert_success_contains 'config help filters' 'filters list|add|set|remove|reset' "$binary" config --help
