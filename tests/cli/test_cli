#!/usr/bin/env bash

set -u

binary=${1:?usage: test_cli /path/to/fsearch}
failures=0
test_root=$(mktemp -d "${TMPDIR:-/tmp}/fsearch-cli-test-state.XXXXXX")
mkdir -p "$test_root/home" "$test_root/config" "$test_root/data" "$test_root/cache" "$test_root/state" "$test_root/runtime"
chmod 700 "$test_root/runtime"
export FSEARCH_TEST_ROOT="$test_root"
export HOME="$test_root/home"
export XDG_CONFIG_HOME="$test_root/config"
export XDG_DATA_HOME="$test_root/data"
export XDG_CACHE_HOME="$test_root/cache"
export XDG_STATE_HOME="$test_root/state"
export XDG_RUNTIME_DIR="$test_root/runtime"

fail() {
	printf 'FAIL: %s\n' "$1" >&2
	failures=$((failures + 1))
}

assert_success_contains() {
	local description=$1
	local expected=$2
	shift 2
	local output rc
	output=$("$@" 2>&1)
	rc=$?
	if [ "$rc" -ne 0 ]; then
		fail "$description returned $rc: $output"
	elif [[ "$output" != *"$expected"* ]]; then
		fail "$description did not contain $expected: $output"
	fi
}

assert_failure_contains() {
	local description=$1
	local expected=$2
	shift 2
	local output rc
	output=$("$@" 2>&1)
	rc=$?
	if [ "$rc" -eq 0 ]; then
		fail "$description unexpectedly succeeded: $output"
	elif [[ "$output" != *"$expected"* ]]; then
		fail "$description did not contain $expected: $output"
	fi
}

assert_success_not_contains() {
	local description=$1
	local rejected=$2
	shift 2
	local output rc
	output=$("$@" 2>&1)
	rc=$?
	if [ "$rc" -ne 0 ]; then
		fail "$description returned $rc: $output"
	elif [[ "$output" == *"$rejected"* ]]; then
		fail "$description unexpectedly contained $rejected: $output"
	fi
}

assert_valid_json() {
	local description=$1
	shift
	local output rc
	output=$("$@" 2>/dev/null)
	rc=$?
	if [ "$rc" -ne 0 ]; then
		fail "$description returned $rc"
	elif ! printf '%s\n' "$output" | jq -e . >/dev/null 2>&1; then
		fail "$description returned invalid JSON: $output"
	fi
}

assert_success_contains 'CLI help' 'Usage: fsearch --cli' "$binary" --cli --help
assert_success_contains 'default help points to CLI help' 'fsearch --cli --help' "$binary" --help
assert_success_contains 'default help points to config help' 'fsearch config --help' "$binary" --help
