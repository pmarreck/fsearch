#!/usr/bin/env bash

set -u

batch_size=${FSEARCH_TRANSLATE_BATCH_SIZE-}
max_output_tokens=10000
stream_max_time=900
stream_idle_seconds=60
stream_idle_bytes=1

if [ -n "$batch_size" ]; then
	case "$batch_size" in
		*[!0-9]*)
			printf 'translate-po: FSEARCH_TRANSLATE_BATCH_SIZE must be a positive integer\n' >&2
			exit 2
			;;
	esac
	if [ "$batch_size" -lt 1 ]; then
		printf 'translate-po: FSEARCH_TRANSLATE_BATCH_SIZE must be a positive integer\n' >&2
		exit 2
	fi
fi

usage() {
	printf '%s\n' 'Usage: tools/translate-po [--dry-run|--apply] [--backend openai|ollama] [--model MODEL] CATALOG.po' >&2
}

header() {
	awk '
		/^msgid ""$/ { in_header = 1 }
		in_header { print }
		in_header && /^$/ { exit }
	' "$1"
}

restore_source_header() {
	local source=$1
	local translated=$2
	local restored=$3
	local first_entry

	first_entry=$(awk '/^(msgid|msg_id) / { print; exit }' "$translated")

	{
		header "$source"
		case "$first_entry" in
			'msgid ""'|'msg_id ""')
				awk '
					!saw_body {
						if (/^$/)
							saw_body = 1
						next
					}
					saw_body { print }
				' "$translated"
				;;
			*)
				cat "$translated"
				;;
		esac
	} >"$restored"
}

normalize_unescaped_po_quotes() {
	local input=$1
	local output=$2

	awk '
		function last_quote(line,    position_index, position) {
			position = 0
			for (position_index = 1; position_index <= length(line); position_index += 1) {
				if (substr(line, position_index, 1) == "\"")
					position = position_index
			}
			return position
		}

		function escape_unescaped_quotes(text,    character_index, character, previous, backslashes, escaped) {
			for (character_index = 1; character_index <= length(text); character_index += 1) {
				character = substr(text, character_index, 1)
				if (character != "\"") {
					escaped = escaped character
					continue
				}
				backslashes = 0
				for (previous = character_index - 1; previous >= 1 && substr(text, previous, 1) == "\\"; previous -= 1)
					backslashes += 1
				if (backslashes % 2 == 0)
					escaped = escaped "\\"
				escaped = escaped character
			}
			return escaped
		}

		/^(msgctxt|msgid|msgid_plural|msgstr(\[[0-9]+\])?) "/ || /^"/ {
			first = index($0, "\"")
			last = last_quote($0)
			if (last <= first || substr($0, last + 1) !~ /^[[:space:]]*$/) {
				print
				next
			}
			prefix = substr($0, 1, first)
			body = substr($0, first + 1, last - first - 1)
			suffix = substr($0, last)
			print prefix escape_unescaped_quotes(body) suffix
			next
		}

		{ print }
	' "$input" >"$output"
}

render_translation_slots() {
	local source=$1
	local slots=$2
	local output=$3

	# GNU gettext requires terminal newlines to agree with the source strings.
	awk -v slots="$slots" '
		function take_slot(    encoded) {
			if ((getline encoded < slots) <= 0) {
				printf "translate-po: translation response omitted a required slot\n" > "/dev/stderr"
				failed = 1
				return ""
			}
			slots_used += 1
			return encoded
		}

		function quoted_value(line,    value) {
			value = line
			sub(/^[^"]*"/, "", value)
			sub(/"$/, "", value)
			return value
		}

		function ends_with_escaped_newline(value,    character_index, backslashes) {
			if (substr(value, length(value), 1) != "n")
				return 0
			backslashes = 0
			for (character_index = length(value) - 1; character_index >= 1 && substr(value, character_index, 1) == "\\"; character_index -= 1)
				backslashes += 1
			return backslashes % 2 == 1
		}

		function trailing_escaped_newlines(value,    suffix) {
			suffix = ""
			while (ends_with_escaped_newline(value)) {
				suffix = "\\n" suffix
				value = substr(value, 1, length(value) - 2)
			}
			return suffix
		}

		function leading_escaped_newlines(value,    prefix) {
			if (substr(value, 1, 1) == "\"")
				value = substr(value, 2)
			prefix = ""
			while (substr(value, 1, 2) == "\\n") {
				prefix = prefix "\\n"
				value = substr(value, 3)
			}
			return prefix
		}

		function preserve_boundary_newlines(encoded, source_value,    encoded_value, source_prefix, encoded_prefix, source_suffix, encoded_suffix) {
			encoded_value = encoded
			sub(/"$/, "", encoded_value)
			source_prefix = leading_escaped_newlines(source_value)
			encoded_prefix = leading_escaped_newlines(encoded_value)
			encoded_value = "\"" substr(encoded_value, 2 + length(encoded_prefix))
			encoded_value = "\"" source_prefix substr(encoded_value, 2)
			source_suffix = trailing_escaped_newlines(source_value)
			encoded_suffix = trailing_escaped_newlines(encoded_value)
			if (encoded_suffix != "")
				encoded_value = substr(encoded_value, 1, length(encoded_value) - length(encoded_suffix))
			return encoded_value source_suffix "\""
		}

		function restore_grouped_decimal_flag(encoded, source_value) {
			if (source_value ~ /%\047d/ && source_value !~ /%d/)
				gsub(/%d/, "%\047d", encoded)
			return encoded
		}

		!header_complete {
			print
			if ($0 == "msgid \"\"")
				in_header = 1
			if (in_header && /^$/)
				header_complete = 1
			next
		}

		skip_translation_continuations {
			if (/^"/)
				next
			skip_translation_continuations = 0
		}

		/^msgid / {
			source_msgid = quoted_value($0)
			source_msgid_plural = ""
			source_field = "msgid"
			print
			next
		}

		/^msgid_plural / {
			source_msgid_plural = quoted_value($0)
			source_field = "msgid_plural"
			print
			next
		}

		/^"/ {
			if (source_field == "msgid")
				source_msgid = source_msgid quoted_value($0)
			else if (source_field == "msgid_plural")
				source_msgid_plural = source_msgid_plural quoted_value($0)
			print
			next
		}

		/^msgstr(\[[0-9]+\])? / {
			quote = index($0, "\"")
			if (quote == 0) {
				printf "translate-po: source PO has an invalid translation slot\n" > "/dev/stderr"
				failed = 1
				exit
			}
			encoded = take_slot()
			if (failed)
				exit
			source_field = ""
			if (source_msgid_plural != "")
				source_value = source_msgid_plural
			else
				source_value = source_msgid
			encoded = restore_grouped_decimal_flag(encoded, source_value)
			encoded = preserve_boundary_newlines(encoded, source_value)
			print substr($0, 1, quote - 1) encoded
			skip_translation_continuations = 1
			next
		}

		{ print }

		END {
			if (!failed && (getline extra < slots) > 0) {
				printf "translate-po: translation response supplied an extra slot\n" > "/dev/stderr"
				failed = 1
			}
			close(slots)
			exit failed
		}
	' "$source" >"$output"
}

count_messages() {
	awk '
		/^msgid / {
			# The first PO entry is the required header, even though multiline messages also start with msgid "".
			message_index += 1
			if (message_index > 1)
				count += 1
		}
		END { print count + 0 }
	' "$1"
}

locale_display_name() {
	local catalog=$1
	local locale=$2
	local names_file
	local display_name
	local catalog_locale
	local resolved_locale=$locale

	names_file="$(dirname "$catalog")/LOCALE_NAMES"
	if [ ! -f "$names_file" ]; then
		printf 'translate-po: missing locale-name mapping: %s\n' "$names_file" >&2
		return 1
	fi

	display_name=$(awk -F '\t' -v locale="$locale" '$1 == locale { print $2; exit }' "$names_file")
	if [ -z "$display_name" ]; then
		catalog_locale=$(basename "$catalog" .po)
		display_name=$(awk -F '\t' -v locale="$catalog_locale" '$1 == locale { print $2; exit }' "$names_file")
		if [ -n "$display_name" ]; then
			resolved_locale=$catalog_locale
		fi
	fi
	if [ -z "$display_name" ]; then
		printf 'translate-po: locale %s has no display name in %s\n' "$locale" "$names_file" >&2
		return 1
	fi

	printf '%s (%s)' "$display_name" "$resolved_locale"
}

count_translation_slots() {
	awk '
		!header_complete {
			if ($0 == "msgid \"\"")
				in_header = 1
			if (in_header && /^$/)
				header_complete = 1
			next
		}
		/^msgstr(\[[0-9]+\])? / { count += 1 }
		END { print count + 0 }
	' "$1"
}

validate_exact_printf_placeholders() {
	# gettext accepts compatible printf directives; translations must retain exact ones.
	awk '
		function quoted_text(line,    value) {
			value = line
			sub(/^[^"]*"/, "", value)
			sub(/"$/, "", value)
			return value
		}

		function is_digit(character) {
			return character ~ /[0-9]/
		}

		function is_conversion(character) {
			return character ~ /[aAcCdDeEfFgGimnOoPsSuUxX%]/
		}

		function printf_token(text, start,    i, text_length, first_digit, character, pair) {
			text_length = length(text)
			i = start + 1
			if (i > text_length)
				return ""
			if (substr(text, i, 1) == "%")
				return "%%"

			first_digit = i
			while (i <= text_length && is_digit(substr(text, i, 1)))
				i += 1
			if (i > first_digit && substr(text, i, 1) == "$")
				i += 1
			else
				i = first_digit

			while (i <= text_length && substr(text, i, 1) ~ /[-+ #0'\'']/)
				i += 1
			if (substr(text, i, 1) == "*") {
				i += 1
				first_digit = i
				while (i <= text_length && is_digit(substr(text, i, 1)))
					i += 1
				if (i > first_digit && substr(text, i, 1) == "$")
					i += 1
			} else {
				while (i <= text_length && is_digit(substr(text, i, 1)))
					i += 1
			}

			if (substr(text, i, 1) == ".") {
				i += 1
				if (substr(text, i, 1) == "*") {
					i += 1
					first_digit = i
					while (i <= text_length && is_digit(substr(text, i, 1)))
						i += 1
					if (i > first_digit && substr(text, i, 1) == "$")
						i += 1
				} else {
					while (i <= text_length && is_digit(substr(text, i, 1)))
						i += 1
				}
			}

			pair = substr(text, i, 2)
			if (pair == "hh" || pair == "ll")
				i += 2
			else if (substr(text, i, 1) ~ /[hljztLq]/)
				i += 1
			if (is_conversion(substr(text, i, 1)))
				return substr(text, start, i - start + 1)
			return ""
		}

		function placeholders(text,    i, text_length, token, tokens) {
			text_length = length(text)
			for (i = 1; i <= text_length; i += 1) {
				if (substr(text, i, 1) != "%")
					continue
				token = printf_token(text, i)
				if (token == "")
					continue
				tokens = tokens "\034" token
				i += length(token) - 1
			}
			return tokens
		}

		function placeholder_list(tokens) {
			sub(/^\034/, "", tokens)
			gsub(/\034/, ", ", tokens)
			return tokens == "" ? "(none)" : tokens
		}

		function clear_entry(    item_index) {
			entry_is_c_format = 0
			msgid = ""
			msgid_plural = ""
			translation_count = 0
			current_field = ""
			for (item_index in translations)
				delete translations[item_index]
		}

		function check_entry(    expected, actual, item_index) {
			expected = placeholders(msgid)
			if (!entry_is_c_format && expected == "")
				return
			for (item_index = 1; item_index <= translation_count; item_index += 1) {
				actual = placeholders(translations[item_index])
				if (actual != expected) {
					printf "translate-po: translation changed a printf placeholder\n" > "/dev/stderr"
					printf "translate-po: source tokens: %s; translation tokens: %s\n", placeholder_list(expected), placeholder_list(actual) > "/dev/stderr"
					printf "translate-po: source msgid: %s\n", msgid > "/dev/stderr"
					validation_failed = 1
					exit 1
				}
			}
		}

		BEGIN {
			clear_entry()
		}

		/^#,/ {
			if ($0 ~ /(^|,)[[:space:]]*c-format([[:space:]]*,|$)/)
				entry_is_c_format = 1
			next
		}

		/^msgid / {
			msgid = quoted_text($0)
			current_field = "msgid"
			next
		}

		/^msgid_plural / {
			msgid_plural = quoted_text($0)
			current_field = "msgid_plural"
			next
		}

		/^msgstr(\[[0-9]+\])? / {
			translation_count += 1
			translations[translation_count] = quoted_text($0)
			current_field = "translation"
			next
		}

		/^"/ {
			if (current_field == "msgid")
				msgid = msgid quoted_text($0)
			else if (current_field == "msgid_plural")
				msgid_plural = msgid_plural quoted_text($0)
			else if (current_field == "translation")
				translations[translation_count] = translations[translation_count] quoted_text($0)
			next
		}

		/^$/ {
			check_entry()
			clear_entry()
		}

		END {
			if (!validation_failed)
				check_entry()
		}
	' "$1"
}

validate_desktop_keyword_translation() {
	local catalog=$1
	local locale=$2

	case "$locale" in
		en|en_*) return 0 ;;
	esac

	awk '
		function quoted_text(line,    value) {
			value = line
			sub(/^[^"]*"/, "", value)
			sub(/"$/, "", value)
			return value
		}

		function clear_entry() {
			entry_is_desktop = 0
			msgid = ""
			msgstr = ""
			current_field = ""
		}

		function check_entry() {
			if (entry_is_desktop && msgid ~ /^[^;]+;[^;]+;/ && msgstr == msgid) {
				printf "translate-po: non-English desktop keyword list remained unchanged: %s\n", msgid > "/dev/stderr"
				validation_failed = 1
				exit 1
			}
		}

		BEGIN {
			clear_entry()
		}

		/^#:/ {
			if ($0 ~ /data\/[^[:space:]]+\.desktop[^[:space:]]*:[0-9]+/)
				entry_is_desktop = 1
			next
		}

		/^msgid / {
			msgid = quoted_text($0)
			current_field = "msgid"
			next
		}

		/^msgstr / {
			msgstr = quoted_text($0)
			current_field = "msgstr"
			next
		}

		/^"/ {
			if (current_field == "msgid")
				msgid = msgid quoted_text($0)
			else if (current_field == "msgstr")
				msgstr = msgstr quoted_text($0)
			next
		}

		/^$/ {
			check_entry()
			clear_entry()
		}

		END {
			if (!validation_failed)
				check_entry()
		}
	' "$catalog"
}

split_batches() {
	local source=$1
	local output_dir=$2

	# Preserve the header in every batch while grouping complete PO entries.
	awk -v output_dir="$output_dir" -v batch_size="$batch_size" '
		BEGIN {
			in_header = 1
		}

		function flush_batch(    file, item_index) {
			if (batch_entries == 0)
				return
			batch_index += 1
			file = sprintf("%s/batch-%03d.po", output_dir, batch_index)
			printf "%s", catalog_header > file
			for (item_index = 1; item_index <= batch_entries; item_index += 1)
				printf "%s\n", entries[item_index] > file
			close(file)
			for (item_index in entries)
				delete entries[item_index]
			batch_entries = 0
		}

		function flush_entry() {
			if (entry == "")
				return
			batch_entries += 1
			entries[batch_entries] = entry
			entry = ""
			if (batch_entries == batch_size)
				flush_batch()
		}

		{
			line = $0 "\n"
			if (in_header) {
				catalog_header = catalog_header line
				if ($0 == "")
					in_header = 0
				next
			}
			if ($0 == "") {
				flush_entry()
				next
			}
			entry = entry line
		}

		END {
			flush_entry()
			flush_batch()
		}
	' "$source"
}

extract_stream_events() {
	local stream_file=$1
	local event_file=$2

	# Reassemble one JSON payload per Server-Sent Event for jq validation.
	awk '
		function flush_event() {
			if (data != "" && data != "[DONE]")
				print data
			data = ""
		}

		/^data: / {
			chunk = substr($0, 7)
			data = data == "" ? chunk : data "\n" chunk
			next
		}

		/^$/ {
			flush_event()
			next
		}

		END {
			flush_event()
		}
	' "$stream_file" >"$event_file"
}

mode=''
backend=${FSEARCH_TRANSLATE_BACKEND:-openai}
model=''
catalog=''

while [ "$#" -gt 0 ]; do
	case "$1" in
		--dry-run|--apply)
			if [ -n "$mode" ]; then
				usage
				exit 2
			fi
			mode=${1#--}
			;;
		--model)
			shift
			if [ "$#" -eq 0 ]; then
				usage
				exit 2
			fi
			model=$1
			;;
		--backend)
			shift
			if [ "$#" -eq 0 ]; then
				usage
				exit 2
			fi
			backend=$1
			;;
		--help|-h)
			usage
			exit 0
		;;
		-*)
			usage
			exit 2
		;;
		*)
			if [ -n "$catalog" ]; then
				usage
				exit 2
			fi
			catalog=$1
			;;
	esac
	shift
done

if [ -z "$mode" ] || [ -z "$catalog" ] || [ ! -f "$catalog" ]; then
	usage
	exit 2
fi

case "$backend" in
	openai|ollama) ;;
	*)
		printf 'translate-po: backend must be openai or ollama\n' >&2
		exit 2
		;;
esac

if [ -z "$model" ]; then
	case "$backend" in
		openai) model='gpt-5.6' ;;
		ollama) model='gemma4:12b' ;;
	esac
fi

if [ -z "$batch_size" ]; then
	case "$backend" in
		openai) batch_size=20 ;;
		ollama) batch_size=5 ;;
	esac
fi

catalog=$(realpath "$catalog")
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
untranslated="$tmp_dir/untranslated.po"
fuzzy="$tmp_dir/fuzzy.po"
todo="$tmp_dir/todo.po"
batch_dir="$tmp_dir/batches"
translated_dir="$tmp_dir/translated"
translated_all="$tmp_dir/translated-all.po"
reconciled="$tmp_dir/reconciled.po"
cleaned="$tmp_dir/cleaned.po"
remaining="$tmp_dir/remaining.po"
merged="$tmp_dir/merged.po"
mkdir -p "$batch_dir" "$translated_dir"

if ! msgattrib --untranslated --no-obsolete --force-po --output-file="$untranslated" "$catalog" \
	|| ! msgattrib --only-fuzzy --no-obsolete --force-po --output-file="$fuzzy" "$catalog"; then
	printf 'translate-po: could not prepare incomplete entries from %s\n' "$catalog" >&2
	exit 1
fi

untranslated_entries=$(count_messages "$untranslated")
fuzzy_entries=$(count_messages "$fuzzy")
if [ "$untranslated_entries" -eq 0 ] && [ "$fuzzy_entries" -eq 0 ]; then
	printf 'translate-po: %s is already complete\n' "$catalog"
	exit 0
fi

if ! msgcat --use-first --output-file="$todo" "$untranslated" "$fuzzy"; then
	printf 'translate-po: could not combine incomplete entries from %s\n' "$catalog" >&2
	exit 1
fi

if ! split_batches "$todo" "$batch_dir"; then
	printf 'translate-po: could not batch incomplete entries from %s\n' "$catalog" >&2
	exit 1
fi

batch_count=$(find "$batch_dir" -maxdepth 1 -type f -name '*.po' -print | awk 'END { print NR + 0 }')
if [ "$batch_count" -eq 0 ]; then
	printf 'translate-po: could not create translation batches for %s\n' "$catalog" >&2
	exit 1
fi

entries=$(count_messages "$todo")
locale=$(awk -F': ' '/^"Language: / { sub(/\\n"$/, "", $2); print $2; exit }' "$catalog")
if [ -z "$locale" ]; then
	printf 'translate-po: catalog has no Language header: %s\n' "$catalog" >&2
	exit 1
fi
if ! target_language=$(locale_display_name "$catalog" "$locale"); then
	exit 1
fi

printf 'translate-po: %s has %s incomplete message%s for locale %s in %s batch%s\n' \
	"$catalog" "$entries" "$([ "$entries" -eq 1 ] || printf 's')" "$locale" "$batch_count" \
	"$([ "$batch_count" -eq 1 ] || printf 'es')"
if [ "$mode" = 'dry-run' ]; then
	exit 0
fi

if [ "$backend" = openai ] && [ -z "${OPENAI_API_KEY-}" ]; then
	printf 'translate-po: OPENAI_API_KEY is required for --apply\n' >&2
	exit 2
fi

po_instructions='Translate GNU gettext PO entries. Preserve every msgid, msgid_plural, msgctxt, source reference, comment, HTML/XML markup, and printf-style placeholder exactly. Use valid GNU PO escaping for control characters. Use typographic Unicode quotation marks in translated prose instead of ASCII double quotes, so no literal ASCII quote appears inside a PO string. Translate every msgstr or msgstr[n] into the requested locale. Remove fuzzy flags. Do not translate CLI options, environment-variable names, JSON keys, setting keys, query syntax, paths, URLs, file extensions, or printf placeholders. Any msgid that is a semicolon-separated desktop keyword list must become an equally semicolon-separated list in the requested locale; translate every human-language token, retain only the literal fsearch brand token, and never return a non-English list unchanged. For example, French search;fsearch;files; becomes recherche;fsearch;fichiers;. The GNU gettext directive is literally msgid, with no underscore: Never write msg_id or change any PO keyword. Return no commentary: the JSON schema requires the complete translated PO file in its po property.'
ollama_instructions='Translate the user-facing text in the supplied GNU gettext PO batch. Do not generate GNU PO syntax, comments, msgid values, msgstr values, headers, source references, or markup. Return only translation data in the JSON schema. The translations array must contain exactly one non-empty string for every non-header msgstr or msgstr[n] slot in the supplied batch, in source order. Preserve HTML/XML markup and printf-style placeholders exactly within each translation. Do not translate CLI options, environment-variable names, JSON keys, setting keys, query syntax, paths, URLs, file extensions, or printf placeholders. Translate human-readable prose in CLI usage and diagnostic messages even when they contain CLI syntax; preserve only literal command names, flags, uppercase metavariables such as KEY, PATH, and SECONDS, and printf placeholders. For example, French Usage: fsearch config get KEY [--json] becomes Utilisation : fsearch config get KEY [--json]. Translate accelerator labels containing an underscore while preserving exactly one underscore before an appropriate localized letter; for example, French Cu_t becomes Cou_per. Any source that is a semicolon-separated desktop keyword list must become an equally semicolon-separated localized list; retain only the literal fsearch brand token, and never return a non-English list unchanged. For example, French search;fsearch;files; becomes recherche;fsearch;fichiers;. Return no commentary.'
ollama_output_schema='{"type":"object","properties":{"translations":{"type":"array","items":{"type":"string"}}},"required":["translations"],"additionalProperties":false}'
ollama_url=${FSEARCH_OLLAMA_URL:-http://127.0.0.1:11434}
batch_number=0
translated_files=()

while IFS= read -r batch; do
	batch_number=$((batch_number + 1))
	batch_entries=$(count_messages "$batch")
	batch_slots=$(count_translation_slots "$batch")
	request_file="$tmp_dir/request-$batch_number.json"
	stream_file="$tmp_dir/stream-$batch_number.sse"
	event_file="$tmp_dir/events-$batch_number.ndjson"
	response_text="$tmp_dir/response-$batch_number.json"
	raw_batch_translation="$tmp_dir/raw-translation-$batch_number.po"
	batch_translation="$tmp_dir/translation-$batch_number.po"
	normalized_batch_translation="$tmp_dir/normalized-translation-$batch_number.po"
	translation_slots="$tmp_dir/translation-slots-$batch_number.jsonl"
	batch_reconciled="$tmp_dir/reconciled-$batch_number.po"
	batch_cleaned="$translated_dir/batch-$batch_number.po"
	batch_remaining="$tmp_dir/remaining-$batch_number.po"
	msgfmt_error="$tmp_dir/msgfmt-$batch_number.log"
	curl_config="$tmp_dir/curl-$batch_number.conf"

	printf 'translate-po: translating batch %s/%s (%s message%s)\n' \
		"$batch_number" "$batch_count" "$batch_entries" "$([ "$batch_entries" -eq 1 ] || printf 's')"
	validation_attempt=0
	while :; do
		validation_attempt=$((validation_attempt + 1))
		rendered_from_slots=false
		slot_render_failed=false
	case "$backend" in
		openai)
			if ! jq -n \
				--arg model "$model" \
				--arg target_language "$target_language" \
				--arg instructions "$po_instructions" \
				--rawfile po "$batch" \
				--argjson max_output_tokens "$max_output_tokens" \
				'{
					model: $model,
					store: false,
					stream: true,
					max_output_tokens: $max_output_tokens,
					reasoning: { effort: "none" },
					instructions: $instructions,
					input: ("Target language: " + $target_language + "\n\nTranslate this partial PO catalog:\n" + $po),
					text: {
						format: {
							type: "json_schema",
							name: "po_translation",
							strict: true,
							schema: {
								type: "object",
								properties: { po: { type: "string" } },
								required: ["po"],
								additionalProperties: false
							}
						}
					}
				}' >"$request_file"; then
				printf 'translate-po: could not prepare translation request for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			;;
		ollama)
			if ! jq -n \
				--arg model "$model" \
				--arg target_language "$target_language" \
				--arg instructions "$ollama_instructions" \
				--rawfile po "$batch" \
				--argjson max_output_tokens "$max_output_tokens" \
				--argjson translation_slot_count "$batch_slots" \
				--argjson output_schema "$ollama_output_schema" \
				'{
					model: $model,
					stream: true,
					think: false,
					format: $output_schema,
					options: { temperature: 0, num_predict: $max_output_tokens },
					messages: [
						{ role: "system", content: $instructions },
						{
							role: "user",
							content: (
								"Target language: " + $target_language +
								"\n\nThis batch has exactly " + ($translation_slot_count | tostring) + " translation slots. Translate this partial PO catalog as data only:\n" + $po +
								"\n\nReturn JSON matching this schema:\n" + ($output_schema | tojson)
							)
						}
					]
				}' >"$request_file"; then
				printf 'translate-po: could not prepare translation request for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			;;
	esac

	umask 077
	case "$backend" in
		openai)
			if ! printf '%s\n' \
				'header = "Content-Type: application/json"' \
				"header = \"Authorization: Bearer $OPENAI_API_KEY\"" >"$curl_config"; then
				printf 'translate-po: could not prepare private API credentials for batch %s\n' "$batch_number" >&2
				exit 1
			fi

			if ! curl --config "$curl_config" \
				--connect-timeout 10 \
				--max-time "$stream_max_time" \
				--speed-limit "$stream_idle_bytes" \
				--speed-time "$stream_idle_seconds" \
				--no-buffer \
				--fail-with-body \
				--silent \
				--show-error \
				--data-binary "@$request_file" \
				https://api.openai.com/v1/responses >"$stream_file"; then
				api_error=$(jq -r '.error.message? // empty' "$stream_file" 2>/dev/null || true)
				if [ -n "$api_error" ]; then
					printf 'translate-po: API request rejected: %s\n' "$api_error" >&2
				fi
				printf 'translate-po: translation request failed for batch %s\n' "$batch_number" >&2
				exit 1
			fi

			if ! extract_stream_events "$stream_file" "$event_file" || [ ! -s "$event_file" ]; then
				printf 'translate-po: API stream produced no events for batch %s\n' "$batch_number" >&2
				exit 1
			fi

			stream_error=$(jq -r 'select(.type == "error") | .message // .error.message // empty' "$event_file" 2>/dev/null | head -n 1)
			if [ -n "$stream_error" ]; then
				printf 'translate-po: API stream failed: %s\n' "$stream_error" >&2
				exit 1
			fi
			if ! jq -e 'select(.type == "response.completed" and .response.status == "completed")' "$event_file" >/dev/null 2>&1; then
				printf 'translate-po: API stream ended before completion for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			if ! jq -rj 'select(.type == "response.output_text.delta") | .delta' "$event_file" >"$response_text" \
				|| [ ! -s "$response_text" ] \
				|| ! jq -er '.po' "$response_text" >"$raw_batch_translation"; then
				printf 'translate-po: API stream did not contain a structured PO translation for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			;;
		ollama)
			if ! curl \
				--connect-timeout 10 \
				--max-time "$stream_max_time" \
				--speed-limit "$stream_idle_bytes" \
				--speed-time "$stream_idle_seconds" \
				--no-buffer \
				--fail-with-body \
				--silent \
				--show-error \
				--data-binary "@$request_file" \
				"${ollama_url%/}/api/chat" >"$stream_file"; then
				api_error=$(jq -r '.error? // empty' "$stream_file" 2>/dev/null || true)
				if [ -n "$api_error" ]; then
					printf 'translate-po: Ollama request rejected: %s\n' "$api_error" >&2
				fi
				printf 'translate-po: Ollama translation request failed for batch %s\n' "$batch_number" >&2
				exit 1
			fi

			if ! jq -c . "$stream_file" >"$event_file" 2>/dev/null || [ ! -s "$event_file" ]; then
				printf 'translate-po: Ollama stream produced no JSON events for batch %s\n' "$batch_number" >&2
				exit 1
			fi

			stream_error=$(jq -r 'select(.error != null) | .error' "$event_file" 2>/dev/null | head -n 1)
			if [ -n "$stream_error" ]; then
				printf 'translate-po: Ollama stream failed: %s\n' "$stream_error" >&2
				exit 1
			fi
			if ! jq -e 'select(.done == true)' "$event_file" >/dev/null 2>&1; then
				printf 'translate-po: Ollama stream ended before completion for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			if ! jq -rj 'select(.message.content? != null) | .message.content' "$event_file" >"$response_text" \
				|| [ ! -s "$response_text" ]; then
				printf 'translate-po: Ollama stream did not contain structured translation data for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			if jq -e 'has("translations")' "$response_text" >/dev/null 2>&1; then
				rendered_from_slots=true
				if ! jq -e '.translations | type == "array" and all(.[]; type == "string" and length > 0)' "$response_text" >/dev/null \
					|| ! jq -c '.translations[]' "$response_text" >"$translation_slots" \
					|| ! render_translation_slots "$batch" "$translation_slots" "$batch_translation"; then
					slot_render_failed=true
				fi
			elif ! jq -er '.po' "$response_text" >"$raw_batch_translation"; then
				printf 'translate-po: Ollama stream did not contain structured translation data for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			;;
		esac

		if [ "$rendered_from_slots" = false ]; then
			if ! restore_source_header "$catalog" "$raw_batch_translation" "$batch_translation"; then
				printf 'translate-po: could not restore the immutable source header for batch %s\n' "$batch_number" >&2
				exit 1
			fi
			if ! normalize_unescaped_po_quotes "$batch_translation" "$normalized_batch_translation" \
				|| ! mv "$normalized_batch_translation" "$batch_translation"; then
				printf 'translate-po: could not normalize PO string quoting for batch %s\n' "$batch_number" >&2
				exit 1
			fi
		fi

		validation_failed=false
		if [ "$slot_render_failed" = true ]; then
			printf 'translate-po: Ollama response did not provide exactly one non-empty translation per source slot for batch %s\n' "$batch_number" >&2
			validation_failed=true
		elif ! diff -u <(header "$catalog") <(header "$batch_translation") >/dev/null; then
			printf 'translate-po: translated batch %s changed its required header\n' "$batch_number" >&2
			validation_failed=true
		elif ! msgfmt --check --check-format --output-file=/dev/null "$batch_translation" 2>"$msgfmt_error"; then
			printf 'translate-po: translated batch %s failed msgfmt validation:\n' "$batch_number" >&2
			sed -n '1,20p' "$msgfmt_error" >&2
			validation_failed=true
		elif ! validate_exact_printf_placeholders "$batch_translation"; then
			printf 'translate-po: translated batch %s is invalid or changed a format placeholder\n' "$batch_number" >&2
			validation_failed=true
		elif ! validate_desktop_keyword_translation "$batch_translation" "$locale"; then
			printf 'translate-po: translated batch %s left a desktop keyword list unchanged\n' "$batch_number" >&2
			validation_failed=true
		elif ! msgmerge --no-fuzzy-matching --output-file="$batch_reconciled" "$batch_translation" "$batch" \
			|| ! msgattrib --clear-fuzzy --output-file="$batch_cleaned" "$batch_reconciled" \
			|| ! msgattrib --untranslated --no-obsolete --force-po --output-file="$batch_remaining" "$batch_cleaned"; then
			printf 'translate-po: could not reconcile translated batch %s\n' "$batch_number" >&2
			validation_failed=true
		elif [ "$(count_messages "$batch_remaining")" -ne 0 ]; then
			printf 'translate-po: translation response omitted or left empty one or more requested entries for batch %s\n' "$batch_number" >&2
			validation_failed=true
		fi

		if [ "$validation_failed" = false ]; then
			translated_files+=("$batch_cleaned")
			break
		fi
		if [ "$backend" != ollama ] || [ "$validation_attempt" -ge 3 ]; then
			exit 1
		fi
		printf 'translate-po: retrying after validation failure: batch %s/%s (attempt %s/3)\n' \
			"$batch_number" "$batch_count" "$validation_attempt" >&2
	done
done < <(find "$batch_dir" -maxdepth 1 -type f -name '*.po' -print | sort)

if ! msgcat --use-first --output-file="$translated_all" "${translated_files[@]}" \
	|| ! msgmerge --no-fuzzy-matching --output-file="$reconciled" "$translated_all" "$todo" \
	|| ! msgattrib --clear-fuzzy --output-file="$cleaned" "$reconciled" \
	|| ! msgattrib --untranslated --no-obsolete --force-po --output-file="$remaining" "$cleaned"; then
	printf 'translate-po: could not reconcile translated batches for %s\n' "$catalog" >&2
	exit 1
fi
if [ "$(count_messages "$remaining")" -ne 0 ]; then
	printf 'translate-po: translated batches omitted or left empty one or more requested entries for %s\n' "$catalog" >&2
	exit 1
fi
if ! msgcat --use-first --output-file="$merged" "$cleaned" "$catalog" \
	|| ! msgfmt --check --check-format --output-file=/dev/null "$merged" >/dev/null 2>&1; then
	printf 'translate-po: could not merge validated translations into %s\n' "$catalog" >&2
	exit 1
fi
if ! diff -u <(header "$catalog") <(header "$merged") >/dev/null; then
	printf 'translate-po: merge changed the catalog header\n' >&2
	exit 1
fi

if ! mv "$merged" "$catalog"; then
	printf 'translate-po: could not atomically update %s\n' "$catalog" >&2
	exit 1
fi

printf 'translate-po: applied %s translations across %s batch%s to %s\n' \
	"$entries" "$batch_count" "$([ "$batch_count" -eq 1 ] || printf 'es')" "$catalog"
