#!/usr/bin/env bash

set -u

usage() {
	printf '%s\n' 'Usage: tools/translate-po [--dry-run|--apply] [--model MODEL] CATALOG.po' >&2
}

header() {
	awk '
		/^msgid ""$/ { in_header = 1 }
		in_header { print }
		in_header && /^$/ { exit }
	' "$1"
}

count_messages() {
	awk '$0 ~ /^msgid / && $0 != "msgid \"\"" { count += 1 } END { print count + 0 }' "$1"
}

mode=''
model='gpt-5.6'
catalog=''

while [ "$#" -gt 0 ]; do
	case "$1" in
		--dry-run|--apply)
			if [ -n "$mode" ]; then
				usage
				exit 2
			fi
			mode=${1#--}
			;;
		--model)
			shift
			if [ "$#" -eq 0 ]; then
				usage
				exit 2
			fi
			model=$1
			;;
		--help|-h)
			usage
			exit 0
		;;
		-*)
			usage
			exit 2
		;;
		*)
			if [ -n "$catalog" ]; then
				usage
				exit 2
			fi
			catalog=$1
			;;
	esac
	shift
done

if [ -z "$mode" ] || [ -z "$catalog" ] || [ ! -f "$catalog" ]; then
	usage
	exit 2
fi

catalog=$(realpath "$catalog")
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
untranslated="$tmp_dir/untranslated.po"
fuzzy="$tmp_dir/fuzzy.po"
todo="$tmp_dir/todo.po"
translated="$tmp_dir/translated.po"
reconciled="$tmp_dir/reconciled.po"
cleaned="$tmp_dir/cleaned.po"
remaining="$tmp_dir/remaining.po"
merged="$tmp_dir/merged.po"
response="$tmp_dir/response.json"
response_text="$tmp_dir/response-text.json"
curl_config="$tmp_dir/curl.conf"
request_file="$tmp_dir/request.json"

if ! msgattrib --untranslated --no-obsolete --force-po --output-file="$untranslated" "$catalog" \
	|| ! msgattrib --only-fuzzy --no-obsolete --force-po --output-file="$fuzzy" "$catalog"; then
	printf 'translate-po: could not prepare incomplete entries from %s\n' "$catalog" >&2
	exit 1
fi

untranslated_entries=$(count_messages "$untranslated")
fuzzy_entries=$(count_messages "$fuzzy")
if [ "$untranslated_entries" -eq 0 ] && [ "$fuzzy_entries" -eq 0 ]; then
	printf 'translate-po: %s is already complete\n' "$catalog"
	exit 0
fi

if ! msgcat --use-first --output-file="$todo" "$untranslated" "$fuzzy"; then
	printf 'translate-po: could not combine incomplete entries from %s\n' "$catalog" >&2
	exit 1
fi

entries=$(count_messages "$todo")
locale=$(awk -F': ' '/^"Language: / { sub(/\\n"$/, "", $2); print $2; exit }' "$catalog")
if [ -z "$locale" ]; then
	printf 'translate-po: catalog has no Language header: %s\n' "$catalog" >&2
	exit 1
fi

printf 'translate-po: %s has %s incomplete message%s for locale %s\n' \
	"$catalog" "$entries" "$([ "$entries" -eq 1 ] || printf 's')" "$locale"
if [ "$mode" = 'dry-run' ]; then
	exit 0
fi

if [ -z "${OPENAI_API_KEY-}" ]; then
	printf 'translate-po: OPENAI_API_KEY is required for --apply\n' >&2
	exit 2
fi

instructions='Translate GNU gettext PO entries. Preserve the PO header byte-for-byte. Preserve every msgid, msgid_plural, msgctxt, source reference, comment, and printf-style placeholder exactly. Translate every msgstr or msgstr[n] into the requested locale. Remove fuzzy flags. Do not translate CLI options, environment-variable names, JSON keys, setting keys, query syntax, paths, URLs, file extensions, or printf placeholders. Return no commentary: the JSON schema requires the complete translated PO file in its po property.'
if ! jq -n \
	--arg model "$model" \
	--arg locale "$locale" \
	--arg instructions "$instructions" \
	--rawfile po "$todo" \
	'{
		model: $model,
		store: false,
		max_output_tokens: 20000,
		reasoning: { effort: "none" },
		instructions: $instructions,
		input: ("Target locale: " + $locale + "\n\nTranslate this partial PO catalog:\n" + $po),
		text: {
			format: {
				type: "json_schema",
				name: "po_translation",
				strict: true,
				schema: {
					type: "object",
					properties: { po: { type: "string" } },
					required: ["po"],
					additionalProperties: false
				}
			}
		}
	}' >"$request_file"; then
	printf 'translate-po: could not prepare translation request for %s\n' "$catalog" >&2
	exit 1
fi

umask 077
if ! printf '%s\n' \
	'header = "Content-Type: application/json"' \
	"header = \"Authorization: Bearer $OPENAI_API_KEY\"" >"$curl_config"; then
	printf 'translate-po: could not prepare private API credentials for %s\n' "$catalog" >&2
	exit 1
fi

if ! curl --config "$curl_config" \
	--connect-timeout 10 \
	--max-time 180 \
	--fail-with-body \
	--silent \
	--show-error \
	--data-binary "@$request_file" \
	https://api.openai.com/v1/responses >"$response"; then
	api_error=$(jq -r '.error.message? // empty' "$response" 2>/dev/null || true)
	if [ -n "$api_error" ]; then
		printf 'translate-po: API request rejected: %s\n' "$api_error" >&2
	fi
	printf 'translate-po: translation request failed for %s\n' "$catalog" >&2
	exit 1
fi

if ! jq -er '[.output[]? | select(.type == "message") | .content[]? | select(.type == "output_text") | .text][0]' \
	"$response" >"$response_text" \
	|| ! jq -er '.po' "$response_text" >"$translated"; then
	printf 'translate-po: API response did not contain a structured PO translation\n' >&2
	exit 1
fi

if ! diff -u <(header "$catalog") <(header "$translated") >/dev/null; then
	printf 'translate-po: translated catalog changed its required header\n' >&2
	exit 1
fi
if ! msgfmt --check --check-format --output-file=/dev/null "$translated" >/dev/null 2>&1; then
	printf 'translate-po: translated PO is invalid or changed a format placeholder\n' >&2
	exit 1
fi
if ! msgmerge --no-fuzzy-matching --output-file="$reconciled" "$translated" "$todo" \
	|| ! msgattrib --clear-fuzzy --output-file="$cleaned" "$reconciled" \
	|| ! msgattrib --untranslated --no-obsolete --force-po --output-file="$remaining" "$cleaned"; then
	printf 'translate-po: could not reconcile translated entries for %s\n' "$catalog" >&2
	exit 1
fi
if [ "$(count_messages "$remaining")" -ne 0 ]; then
	printf 'translate-po: translation response omitted or left empty one or more requested entries for %s\n' "$catalog" >&2
	exit 1
fi
if ! msgcat --use-first --output-file="$merged" "$cleaned" "$catalog" \
	|| ! msgfmt --check --check-format --output-file=/dev/null "$merged" >/dev/null 2>&1; then
	printf 'translate-po: could not merge validated translations into %s\n' "$catalog" >&2
	exit 1
fi
if ! diff -u <(header "$catalog") <(header "$merged") >/dev/null; then
	printf 'translate-po: merge changed the catalog header\n' >&2
	exit 1
fi

if ! mv "$merged" "$catalog"; then
	printf 'translate-po: could not atomically update %s\n' "$catalog" >&2
	exit 1
fi

printf 'translate-po: applied %s translations to %s\n' "$entries" "$catalog"
