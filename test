#!/usr/bin/env bash

set -u

source "$HOME/dotfiles/bin/src/capture.bash"

failures=0

run_suite() {
	local name=$1
	shift
	local show_success_output=false
	local out='' err='' rc=0 reported_failures=1

	if [ "${1-}" = --show-success-output ]; then
		show_success_output=true
		shift
	fi

	capture "$@"
	if [ "$rc" -eq 0 ]; then
		if [ "$show_success_output" = true ]; then
			[ -n "$out" ] && printf '%s\n' "$out"
			[ -n "$err" ] && printf '%s\n' "$err" >&2
		fi
		printf 'PASS: %s\n' "$name"
		return 0
	fi

	if [ "$name" = 'Meson tests' ]; then
		reported_failures=$(printf '%s\n%s\n' "$out" "$err" | awk '/^Fail:[[:space:]]+[0-9]+/ { count = $2 } END { print count ? count : 1 }')
	fi
	case "$reported_failures" in
		*[!0-9]*|'') reported_failures=1 ;;
	esac

	failures=$((failures + reported_failures))
	printf 'FAIL: %s (%s failure%s)\n' "$name" "$reported_failures" "$([ "$reported_failures" -eq 1 ] || printf 's')" >&2
	[ -n "$out" ] && printf '%s\n' "$out" >&2
	[ -n "$err" ] && printf '%s\n' "$err" >&2
	return 1
}

if run_suite 'Meson setup' nix develop -c meson setup builddir --reconfigure; then
	run_suite 'Meson tests' nix develop -c meson test -C builddir --print-errorlogs
	run_suite 'Cppcheck static analysis' nix develop -c bash tests/static-analysis . builddir
	run_suite 'gettext translation helper' nix develop -c bash tests/i18n/test_translate_po tools/translate-po
	run_suite 'gettext catalog integrity' nix develop -c bash tests/i18n/test_catalogs .
	run_suite 'required locale gate' nix develop -c bash tests/i18n/test_required_locales tools/check-required-locales
	run_suite 'required locale WARN report' --show-success-output nix develop -c bash tools/check-required-locales . --warn
fi

if run_suite 'release build and Meson checks' nix build .#default; then
	run_suite 'release GTK GSettings runtime wrapper' nix develop -c bash tests/package/test_gsettings_runtime result/bin/fsearch
	run_suite 'release CLI tests' nix develop -c bash tests/cli/test_cli result/bin/fsearch
fi

if [ "$failures" -eq 0 ]; then
	printf 'All tests passed.\n'
else
	printf '%s failure%s.\n' "$failures" "$([ "$failures" -eq 1 ] || printf 's')" >&2
fi

exit "$failures"
