msgstr "бһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһӣбһ·бһ”бһ·бһҖбҹ’бһҡбһҳбҹ– %s"

#: src/fsearch_cli.c:181
msgid ""
"Usage: fsearch --cli [OPTIONS]\n"
"\n"
"Search the existing FSearch index and print matching paths.\n"
"\n"
"  -s, --search PATTERN       Search with FSearch query syntax\n"
"      --path DIRECTORY        Search recursively below DIRECTORY (default: "
"current directory)\n"
"      --global                Search every indexed location\n"
"      --limit COUNT          Print at most COUNT results\n"
"      --unlimit, --unlimited Print every result\n"
"  -u, --update-database      Rescan the configured index and exit\n"
"      --about                Print one-line build information\n"
"  -h, --help                 Show this help\n"
"\n"
"Configuration: fsearch config --help\n"
"\n"
"Examples:\n"
"  fsearch --cli --search invoice              # current directory\n"
"  fsearch --cli --path ~/Documents --search invoice\n"
"  fsearch --cli --global --search invoice\n"
"  fsearch --cli --search 'file:size:>20mb'\n"
"  fsearch --cli --search 'ext:jpg;png'\n"
"  fsearch --cli --search 'path:projects report'\n"
"  fsearch --cli --search 'report AND ext:pdf'\n"
"  fsearch --cli --search '(draft OR final) !archive'\n"
"  fsearch --cli --search 'file:regex:\".+\\.pdf$\"'\n"
"  fsearch --cli --search 'case:AGENTS'        # case-sensitive\n"
"  fsearch --cli --search 'case:regex:\"^AGENTS\\.md$\"'\n"
"  fsearch --cli --search 'glob:**/*.png'\n"
"  fsearch --cli --search 'path:glob:**/AGENTS.md'\n"
"  fsearch --cli --search 'case:glob:AGENTS.md' # case-sensitive glob\n"
"\n"
"Examples use space as AND. Try file:, folder:, path:, ext:, size:, dm:, "
"case:, regex:, and glob:.\n"
"Boolean syntax: AND or &&; OR or ||; NOT or !. Parentheses group terms.\n"
"Glob syntax: * excludes /; ** spans directories; ? matches one character; [a-"
"c] is a range;\n"
"Glob searches paths by default; use **/ for any depth; file:glob: searches "
"file names.\n"
"{png,jpg} selects alternatives; {01..12} is an inclusive numeric range; \\* "
"matches a literal *.\n"
msgstr ""
"бһҖбһ¶бһҡбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбҹ– fsearch --cli [OPTIONS]\n"
"\n"
"бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҹбһ“бҹ’бһ‘бһҹбҹ’бһҹбһ“бҹҚ FSearch бһҠбҹӮбһӣбһҳбһ¶бһ“бһҹбҹ’бһҡбһ¶бһ”бҹӢ бһ“бһ·бһ„бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһ•бҹ’бһӣбһјбһңбһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңбһӮбҹ’бһ“бһ¶бҹ”\n"
"\n"
"  -s, --search PATTERN       бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҠбҹ„бһҷбһ”бҹ’бһҡбһҫбһңбһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҹбҹҶбһҺбһҪбһҡ FSearch\n"
"      --path DIRECTORY        бһҹбҹ’бһңбҹӮбһ„бһҡбһҖвҖӢбһҠбһҠбҹӮбһӣбҹ—вҖӢбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳ DIRECTORY (бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбҹ– бһҗбһҸбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“)\n"
"      --global                бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҡбһ¶бһӣбҹӢбһ‘бһёбһҸбһ¶бҹҶбһ„бһҠбҹӮбһӣбһ”бһ¶бһ“бһ’бҹ’бһңбһҫбһӣбһ·бһ”бһ·бһҖбҹ’бһҡбһҳ\n"
"      --limit COUNT          бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһӣбһ‘бҹ’бһ’бһ•бһӣбһ…бҹ’бһҡбһҫбһ“бһ”бҹҶбһ•бһ»бһҸ COUNT\n"
"      --unlimit, --unlimited бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһӣбһ‘бҹ’бһ’бһ•бһӣбһ“бһёбһҳбһҪбһҷбҹ—\n"
"  -u, --update-database      бһҹбҹ’бһҖбҹҒбһ“бһӣбһ·бһ”бһ·бһҖбҹ’бһҡбһҳбһҠбҹӮбһӣбһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһЎбһҫбһ„бһңбһ·бһү бһ бһҫбһҷбһ…бҹҒбһү\n"
"      --about                бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҹбҹ’бһҗбһ¶бһ”бһ“бһ¶бһҳбһҪбһҷбһҮбһҪбһҡ\n"
"  -h, --help                 бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ“бҹҒбҹҮбҹ”\n"
"\n"
"бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бҹ– fsearch config --help\n"
"\n"
"бһ§бһ‘бһ¶бһ бһҡбһҺбҹҚбҹ–\n"
"  fsearch --cli --search invoice              # current directory\n"
"  fsearch --cli --path ~/Documents --search invoice\n"
"  fsearch --cli --global --search invoice\n"
"  fsearch --cli --search 'file:size:>20mb'\n"
"  fsearch --cli --search 'ext:jpg;png'\n"
"  fsearch --cli --search 'path:projects report'\n"
"  fsearch --cli --search 'report AND ext:pdf'\n"
"  fsearch --cli --search '(draft OR final) !archive'\n"
"  fsearch --cli --search 'file:regex:\".+\\.pdf$\"'\n"
"  fsearch --cli --search 'case:AGENTS'        # case-sensitive\n"
"  fsearch --cli --search 'case:regex:\"^AGENTS\\.md$\"'\n"
"  fsearch --cli --search 'glob:**/*.png'\n"
"  fsearch --cli --search 'path:glob:**/AGENTS.md'\n"
"  fsearch --cli --search 'case:glob:AGENTS.md' # case-sensitive glob\n"
"\n"
"бһ§бһ‘бһ¶бһ бһҡбһҺбҹҚбһ”бҹ’бһҡбһҫбһ…бһ“бҹ’бһӣбҹ„бҹҮбһҮбһ¶ AND бҹ” бһҹбһ¶бһҖбһӣбҹ’бһ”бһ„бһҜбһҖбһҹбһ¶бһҡбҹ–, бһҗбһҸбҹ–, бһ•бҹ’бһӣбһјбһңбҹ–, ext:, бһ‘бҹҶбһ бҹҶбҹ–, dm:, бһҖбһҡбһҺбһёбҹ–, regexбҹ–, бһ“бһ·бһ„ globбҹ–бҹ”\n"
"бһңбһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһ”бҹҠбһјбһӣбһёбһ“бҹ– AND бһ¬ &&; OR бһ¬ ||; бһҳбһ·бһ“бһҳбҹӮбһ“бһ¬!бҹ” бһ–бһ¶бһҖбҹ’бһҷбһҖбҹ’бһҡбһ»бһҳбһңбһ„бҹӢбһҖбҹ’бһҡбһ…бһҖбҹ”\n"
"бһңбһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ Globбҹ– * excludes /; ** бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҗбһҸ; ? бһ•бҹ’бһӮбһјбһ•бҹ’бһӮбһ„бһҸбһҪбһўбһҖбҹ’бһҹбһҡбһҳбһҪбһҷ; [a-c] бһӮбһәбһҮбһ¶бһҮбһҪбһҡбһҳбһҪбһҷ;\n"
"Glob бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһ•бҹ’бһӣбһјбһңбһҸбһ¶бһҳбһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳ; бһ”бҹ’бһҡбһҫ **/ бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҮбһҳбҹ’бһҡбҹ…бһҺбһ¶бһҳбһҪбһҷ; file:glob: бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҲбҹ’бһҳбҹ„бҹҮбһҜбһҖбһҹбһ¶бһҡбҹ”\n"
"{png,jpg} бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҮбһҳбҹ’бһҡбһҫбһҹ; {01..12} бһӮбһәбһҮбһ¶бһҮбһҪбһҡбһӣбҹҒбһҒбһҡбһҪбһҳбһ”бһүбҹ’бһ…бһјбһӣ; \\* бһҸбҹ’бһҡбһјбһңбһӮбҹ’бһ“бһ¶бһ“бһ№бһ„бһ–бҹ’бһҷбһүбҹ’бһҮбһ“бҹҲ * бҹ”\n"

