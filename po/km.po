#: src/fsearch_statusbar.ui:328 src/fsearch_window.ui:103
msgid "Cancel database update"
msgstr "បោះបង់ការធ្វើបច្ចុប្បន្នភាពមូលដ្ឋានទិន្នន័យ"

#: src/fsearch_statusbar.ui:369
