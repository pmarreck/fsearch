#: src/fsearch_cli_config.c:111
msgid ""
"Usage: fsearch config COMMAND [OPTIONS]\n"
"\n"
"View and modify the shared FSearch GUI and CLI configuration.\n"
"\n"
"Configuration commands:\n"
"  path                         Print the configuration file path\n"
"  show [SECTION] [--json]      Show settings\n"
"  get KEY [--json]             Print one scalar setting\n"
"  set KEY VALUE                Set one scalar setting\n"
"  unset KEY                    Restore one scalar setting default\n"
"  reset [KEY|SECTION] --yes [--rescan]\n"
"                               Restore defaults\n"
"  doctor                       Check configuration and index consistency\n"
"  roots list|add|set|remove    Manage indexed roots\n"
"  excludes list|add|remove|hidden\n"
"                               Manage index exclusions\n"
"  filters list|add|set|remove|reset\n"
"                               Manage saved search filters\n"
"\n"
"Scalar values use true/false, decimal integers, or strings.\n"
"Run 'fsearch config show' to list every scalar key and current value.\n"
"Scalar sections: search, application, window, ui, columns, sort, dialogs.\n"
"Use 'fsearch config roots|excludes|filters --help' for family options.\n"
"Close the FSearch GUI before changing shared settings.\n"
"Index changes become searchable on the next CLI search, or immediately with "
"--rescan.\n"
"Use --json with show, get, and collection list commands.\n"
"\n"
"Examples:\n"
"  fsearch config show search --json\n"
"  fsearch config get search.match-case\n"
"  fsearch config set search.match-case true\n"
"  fsearch config roots add ~/Code --monitor --one-file-system --rescan\n"
"  fsearch config excludes add '*.tmp' --type wildcard --scope basename --"
"target files\n"
"  fsearch config filters add Documents --query 'ext:pdf' --macro docs\n"
"  fsearch config reset search --yes\n"
msgstr ""
"Употреба: fsearch config COMMAND [OPTIONS]\n"
"\n"
"Преглед и промяна на споделената конфигурация на графичния интерфейс и CLI "
"на FSearch.\n"
"\n"
"Команди за конфигурация:\n"
"  path                         Извеждане на пътя до конфигурационния файл\n"
"  show [SECTION] [--json]      Показване на настройките\n"
"  get KEY [--json]             Извеждане на една скаларна настройка\n"
"  set KEY VALUE                Задаване на една скаларна настройка\n"
"  unset KEY                    Възстановяване на стандартната стойност на "
"една скаларна настройка\n"
"  reset [KEY|SECTION] --yes [--rescan]\n"
"                               Възстановяване на стандартните стойности\n"
"  doctor                       Проверка на съгласуваността на конфигурацията "
"и индекса\n"
"  roots list|add|set|remove    Управление на индексираните корени\n"
"  excludes list|add|remove|hidden\n"
"                               Управление на изключенията от индекса\n"
"  filters list|add|set|remove|reset\n"
"                               Управление на запазените филтри за търсене\n"
"\n"
"Скаларните стойности използват true/false, десетични цели числа или низове.\n"
"Изпълнете „fsearch config show“, за да изведете всички скаларни ключове и "
"текущите им стойности.\n"
"Скаларни раздели: search, application, window, ui, columns, sort, dialogs.\n"
"Използвайте „fsearch config roots|excludes|filters --help“ за опциите на "
"съответната група.\n"
"Затворете графичния интерфейс на FSearch, преди да променяте споделените "
"настройки.\n"
"Промените в индекса стават достъпни за търсене при следващото търсене от CLI "
"или незабавно с --rescan.\n"
"Използвайте --json с командите show, get и list за колекции.\n"
"\n"
"Примери:\n"
"  fsearch config show search --json\n"
"  fsearch config get search.match-case\n"
"  fsearch config set search.match-case true\n"
"  fsearch config roots add ~/Code --monitor --one-file-system --rescan\n"
"  fsearch config excludes add '*.tmp' --type wildcard --scope basename --"
"target files\n"
"  fsearch config filters add Documents --query 'ext:pdf' --macro docs\n"
"  fsearch config reset search --yes\n"

#: src/fsearch_cli_config.c:152
msgid ""
"Usage: fsearch config show [SECTION] [--json]\n"
"Show all scalar settings or one dotted section.\n"
msgstr ""
"Употреба: fsearch config show [SECTION] [--json]\n"
"Показване на всички скаларни настройки или на един раздел с точково име.\n"

#: src/fsearch_cli_config.c:154
msgid ""
"Usage: fsearch config get KEY [--json]\n"
"Print one typed scalar value. Discover keys with 'fsearch config show'.\n"
msgstr ""
"Употреба: fsearch config get KEY [--json]\n"
"Извеждане на една типизирана скаларна стойност. Открийте ключовете с "
"„fsearch config show“.\n"

#: src/fsearch_cli_config.c:157
msgid ""
"Usage: fsearch config set KEY VALUE\n"
"Set a boolean, integer, string, or enumerated scalar value.\n"
msgstr ""
"Употреба: fsearch config set KEY VALUE\n"
"Задаване на булева, целочислена, низова или изброима скаларна стойност.\n"

#: src/fsearch_cli_config.c:159
msgid ""
"Usage: fsearch config unset KEY\n"
"Restore one scalar setting to its built-in default.\n"
msgstr ""
"Употреба: fsearch config unset KEY\n"
"Възстановяване на вградената стандартна стойност на една скаларна "
"настройка.\n"

#: src/fsearch_cli_config.c:161
msgid ""
"Usage: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Reset is destructive and requires --yes. --rescan applies to roots, "
"database, excludes, or all.\n"
msgstr ""
"Употреба: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Нулирането е разрушително и изисква --yes. --rescan се прилага за roots, "
"database, excludes или all.\n"

#: src/fsearch_cli_config.c:164
msgid ""
"Usage: fsearch config doctor\n"
"Check configuration readability and whether the saved index uses the same "
"roots and exclusions.\n"
msgstr ""
"Употреба: fsearch config doctor\n"
"Проверка дали конфигурацията може да бъде прочетена и дали запазеният индекс "
"използва същите корени и изключения.\n"

#: src/fsearch_cli_config.c:170
msgid ""
"Usage: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                List indexed roots\n"
"  add PATH [OPTIONS]           Add a root directory\n"
"  set PATH [OPTIONS]           Change an existing root\n"
"  remove PATH [--rescan]       Remove an existing root\n"
"\n"
"Options for add and set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Set periodic rescan interval; 0 disables it\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Употреба: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Команди:\n"
"  list [--json]                Извеждане на индексираните корени\n"
"  add PATH [OPTIONS]           Добавяне на коренова директория\n"
"  set PATH [OPTIONS]           Промяна на съществуващ корен\n"
"  remove PATH [--rescan]       Премахване на съществуващ корен\n"
"\n"
"Опции за add и set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Задаване на интервал за периодично повторно "
"сканиране; 0 го изключва\n"
"  --rescan                      Незабавно повторно изграждане на индекса "
"след записване\n"

#: src/fsearch_cli_config.c:187
msgid ""
"Usage: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List exclusions\n"
"  add PATTERN [OPTIONS]         Add an exclusion\n"
"  remove PATTERN [OPTIONS]      Remove a matching exclusion\n"
"  hidden [true|false] [--rescan]\n"
"                                View or change hidden-file exclusion\n"
"\n"
"Options for add and remove:\n"
"  --type fixed|wildcard|regex   Default: fixed\n"
"  --scope full-path|basename    Default: full-path\n"
"  --target both|files|folders   Default: both\n"
"  --active, --inactive          Add state or removal selector\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Употреба: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Команди:\n"
"  list [--json]                 Извеждане на изключенията\n"
"  add PATTERN [OPTIONS]         Добавяне на изключение\n"
"  remove PATTERN [OPTIONS]      Премахване на съвпадащо изключение\n"
"  hidden [true|false] [--rescan]\n"
"                                Преглед или промяна на изключването на "
"скрити файлове\n"
"\n"
"Опции за add и remove:\n"
"  --type fixed|wildcard|regex   По подразбиране: fixed\n"
"  --scope full-path|basename    По подразбиране: full-path\n"
"  --target both|files|folders   По подразбиране: both\n"
"  --active, --inactive          Състояние при добавяне или селектор при "
"премахване\n"
"  --rescan                      Незабавно повторно изграждане на индекса "
"след записване\n"

#: src/fsearch_cli_config.c:204
msgid ""
"Usage: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List saved filters\n"
"  add NAME [OPTIONS]            Add a named filter\n"
"  set NAME [OPTIONS]            Change a named filter\n"
"  remove NAME                   Remove a named filter\n"
"  reset                         Restore built-in filters\n"
"\n"
"Options for add and set:\n"
"  --query QUERY                 Saved FSearch query\n"
"  --macro MACRO                 Query macro name\n"
"  --case, --no-case             Match case\n"
"  --path, --no-path             Search full paths\n"
"  --regex, --no-regex           Treat query as a regular expression\n"
msgstr ""
"Употреба: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Команди:\n"
"  list [--json]                 Извеждане на запазените филтри\n"
"  add NAME [OPTIONS]            Добавяне на именуван филтър\n"
"  set NAME [OPTIONS]            Промяна на именуван филтър\n"
"  remove NAME                   Премахване на именуван филтър\n"
"  reset                         Възстановяване на вградените филтри\n"
"\n"
"Опции за add и set:\n"
"  --query QUERY                 Запазена заявка на FSearch\n"
"  --macro MACRO                 Име на макрос на заявка\n"
"  --case, --no-case             Отчитане на регистъра\n"
"  --path, --no-path             Търсене в пълните пътища\n"
"  --regex, --no-regex           Третиране на заявката като регулярен израз\n"

