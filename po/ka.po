#: src/fsearch_cli_config.c:111
msgid ""
"Usage: fsearch config COMMAND [OPTIONS]\n"
"\n"
"View and modify the shared FSearch GUI and CLI configuration.\n"
"\n"
"Configuration commands:\n"
"  path                         Print the configuration file path\n"
"  show [SECTION] [--json]      Show settings\n"
"  get KEY [--json]             Print one scalar setting\n"
"  set KEY VALUE                Set one scalar setting\n"
"  unset KEY                    Restore one scalar setting default\n"
"  reset [KEY|SECTION] --yes [--rescan]\n"
"                               Restore defaults\n"
"  doctor                       Check configuration and index consistency\n"
"  roots list|add|set|remove    Manage indexed roots\n"
"  excludes list|add|remove|hidden\n"
"                               Manage index exclusions\n"
"  filters list|add|set|remove|reset\n"
"                               Manage saved search filters\n"
"\n"
"Scalar values use true/false, decimal integers, or strings.\n"
"Run 'fsearch config show' to list every scalar key and current value.\n"
"Scalar sections: search, application, window, ui, columns, sort, dialogs.\n"
"Use 'fsearch config roots|excludes|filters --help' for family options.\n"
"Close the FSearch GUI before changing shared settings.\n"
"Index changes become searchable on the next CLI search, or immediately with "
"--rescan.\n"
"Use --json with show, get, and collection list commands.\n"
"\n"
"Examples:\n"
"  fsearch config show search --json\n"
"  fsearch config get search.match-case\n"
"  fsearch config set search.match-case true\n"
"  fsearch config roots add ~/Code --monitor --one-file-system --rescan\n"
"  fsearch config excludes add '*.tmp' --type wildcard --scope basename --"
"target files\n"
"  fsearch config filters add Documents --query 'ext:pdf' --macro docs\n"
"  fsearch config reset search --yes\n"
msgstr ""
"გამოყენება: fsearch config COMMAND [OPTIONS]\n"
"\n"
"ნახეთ და შეცვალეთ გაზიარებული FSearch GUI და CLI კონფიგურაცია.\n"
"\n"
"კონფიგურაციის ბრძანებები:\n"
"  path                         დაბეჭდეთ კონფიგურაციის ფაილის გზა\n"
"  show [SECTION] [--json]      პარამეტრების ჩვენება\n"
"  get KEY [--json]             დაბეჭდეთ ერთი სკალარული პარამეტრი\n"
"  set KEY VALUE                დააყენეთ ერთი სკალარული პარამეტრი\n"
"  unset KEY                    აღადგინეთ ნაგულისხმევი სკალარული პარამეტრი\n"
"  reset [KEY|SECTION] --yes [--rescan]\n"
"                               ნაგულისხმევი პარამეტრების აღდგენა\n"
"  doctor                       შეამოწმეთ კონფიგურაცია და ინდექსის თანმიმდევრულობა\n"
"  roots list|add|set|remove    ინდექსირებული ფესვების მართვა\n"
"  excludes list|add|remove|hidden\n"
"                               ინდექსის გამორიცხვების მართვა\n"
"  filters list|add|set|remove|reset\n"
"                               შენახული საძიებო ფილტრების მართვა\n"
"\n"
"სკალარული მნიშვნელობები იყენებს true/false, ათობითი მთელ რიცხვებს ან სტრიქონებს.\n"
"გაუშვით 'fsearch config show' ყველა სკალარული კლავიშისა და მიმდინარე მნიშვნელობის სიაში.\n"
"სკალარული სექციები: search, application, window, ui, columns, sort, dialogs.\n"
"ოჯახის ვარიანტებისთვის გამოიყენეთ 'fsearch config roots| გამორიცხავს|ფილტრები --help'.\n"
"დახურეთ FSearch GUI გაზიარებული პარამეტრების შეცვლამდე.\n"
"ინდექსის ცვლილებები საძიებო ხდება შემდეგი CLI ძიებისას, ან დაუყოვნებლივ --rescan-ით.\n"
"გამოიყენეთ --json show, get და collect list ბრძანებებით.\n"
"\n"
"მაგალითები:\n"
"  fsearch config show search --json\n"
"  fsearch config get search.match-case\n"
"  fsearch config set search.match-case true\n"
"  fsearch config roots add ~/Code --monitor --one-file-system --rescan\n"
"  fsearch config excludes add '*.tmp' --type wildcard --scope basename --target files\n"
"  fsearch config filters add Documents --query 'ext:pdf' --macro docs\n"
"  fsearch config reset search --yes\n"

#: src/fsearch_cli_config.c:152
msgid ""
"Usage: fsearch config show [SECTION] [--json]\n"
"Show all scalar settings or one dotted section.\n"
msgstr ""
"გამოყენება: fsearch config show [SECTION] [--json]\n"
"აჩვენეთ ყველა სკალარული პარამეტრი ან ერთი წერტილიანი განყოფილება.\n"

#: src/fsearch_cli_config.c:154
msgid ""
"Usage: fsearch config get KEY [--json]\n"
"Print one typed scalar value. Discover keys with 'fsearch config show'.\n"
msgstr ""
"გამოყენება: fsearch config get KEY [--json]\n"
"დაბეჭდეთ ერთი აკრეფილი სკალარული მნიშვნელობა. აღმოაჩინეთ გასაღებები 'fsearch config show'-ით.\n"

#: src/fsearch_cli_config.c:157
msgid ""
"Usage: fsearch config set KEY VALUE\n"
"Set a boolean, integer, string, or enumerated scalar value.\n"
msgstr ""
"გამოყენება: fsearch config set KEY VALUE\n"
"დააყენეთ ლოგიკური, მთელი რიცხვი, სტრიქონი ან ჩამოთვლილი სკალარული მნიშვნელობა.\n"

#: src/fsearch_cli_config.c:159
msgid ""
"Usage: fsearch config unset KEY\n"
"Restore one scalar setting to its built-in default.\n"
msgstr ""
"გამოყენება: fsearch config unset KEY\n"
"აღადგინეთ ერთი სკალარული პარამეტრი ჩაშენებულ ნაგულისხმევად.\n"

#: src/fsearch_cli_config.c:161
msgid ""
"Usage: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Reset is destructive and requires --yes. --rescan applies to roots, "
"database, excludes, or all.\n"
msgstr ""
"გამოყენება: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"გადატვირთვა დამღუპველია და მოითხოვს -- დიახ. -- ხელახლა სკანირება ეხება root-ებს, მონაცემთა ბაზას, გამორიცხავს ან ყველა.\n"

#: src/fsearch_cli_config.c:164
msgid ""
"Usage: fsearch config doctor\n"
"Check configuration readability and whether the saved index uses the same "
"roots and exclusions.\n"
msgstr ""
"გამოყენება: fsearch config doctor\n"
"შეამოწმეთ კონფიგურაციის კითხვადობა და იყენებს თუ არა შენახული ინდექსი იგივე ფესვებს და გამონაკლისებს.\n"

#: src/fsearch_cli_config.c:170
msgid ""
"Usage: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                List indexed roots\n"
"  add PATH [OPTIONS]           Add a root directory\n"
"  set PATH [OPTIONS]           Change an existing root\n"
"  remove PATH [--rescan]       Remove an existing root\n"
"\n"
"Options for add and set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Set periodic rescan interval; 0 disables it\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"გამოყენება: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"ბრძანებები:\n"
"  list [--json]                ჩამოთვალეთ ინდექსირებული ფესვები\n"
"  add PATH [OPTIONS]           დაამატეთ root დირექტორია\n"
"  set PATH [OPTIONS]           შეცვალეთ არსებული ფესვი\n"
"  remove PATH [--rescan]       წაშალეთ არსებული ფესვი\n"
"\n"
"დამატებისა და დაყენების ვარიანტები:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        პერიოდული ხელახალი სკანირების ინტერვალის დაყენება; 0 გამორთავს მას\n"
"  --rescan                      აღადგინეთ ინდექსი შენახვისთანავე\n"

#: src/fsearch_cli_config.c:187
msgid ""
"Usage: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List exclusions\n"
"  add PATTERN [OPTIONS]         Add an exclusion\n"
"  remove PATTERN [OPTIONS]      Remove a matching exclusion\n"
"  hidden [true|false] [--rescan]\n"
"                                View or change hidden-file exclusion\n"
"\n"
"Options for add and remove:\n"
"  --type fixed|wildcard|regex   Default: fixed\n"
"  --scope full-path|basename    Default: full-path\n"
"  --target both|files|folders   Default: both\n"
"  --active, --inactive          Add state or removal selector\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"გამოყენება: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"ბრძანებები:\n"
"  list [--json]                 ჩამოთვალეთ გამონაკლისები\n"
"  add PATTERN [OPTIONS]         დაამატეთ გამონაკლისი\n"
"  remove PATTERN [OPTIONS]      წაშალეთ შესაბამისი გამონაკლისი\n"
"  hidden [true|false] [--rescan]\n"
"                                იხილეთ ან შეცვალეთ დამალული ფაილის გამორიცხვა\n"
"\n"
"დამატებისა და წაშლის ვარიანტები:\n"
"  --type fixed|wildcard|regex   ნაგულისხმევი: დაფიქსირებული\n"
"  --scope full-path|basename    ნაგულისხმევი: სრული გზა\n"
"  --target both|files|folders   ნაგულისხმევი: ორივე\n"
"  --active, --inactive          დაამატეთ მდგომარეობის ან ამოღების ამომრჩეველი\n"
"  --rescan                      აღადგინეთ ინდექსი შენახვისთანავე\n"

#: src/fsearch_cli_config.c:204
msgid ""
"Usage: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List saved filters\n"
"  add NAME [OPTIONS]            Add a named filter\n"
"  set NAME [OPTIONS]            Change a named filter\n"
"  remove NAME                   Remove a named filter\n"
"  reset                         Restore built-in filters\n"
"\n"
"Options for add and set:\n"
"  --query QUERY                 Saved FSearch query\n"
"  --macro MACRO                 Query macro name\n"
"  --case, --no-case             Match case\n"
"  --path, --no-path             Search full paths\n"
"  --regex, --no-regex           Treat query as a regular expression\n"
msgstr ""
"გამოყენება: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"ბრძანებები:\n"
"  list [--json]                 შენახული ფილტრების სია\n"
"  add NAME [OPTIONS]            დაამატეთ დასახელებული ფილტრი\n"
"  set NAME [OPTIONS]            შეცვალეთ დასახელებული ფილტრი\n"
"  remove NAME                   ამოიღეთ დასახელებული ფილტრი\n"
"  reset                         ჩაშენებული ფილტრების აღდგენა\n"
"\n"
"დამატებისა და დაყენების ვარიანტები:\n"
"  --query QUERY                 შენახული FSearch მოთხოვნა\n"
"  --macro MACRO                 მოითხოვეთ მაკრო სახელი\n"
"  --case, --no-case             მატჩის საქმე\n"
"  --path, --no-path             მოძებნეთ სრული ბილიკები\n"
"  --regex, --no-regex           განიხილეთ შეკითხვა, როგორც რეგულარულ გამოხატულებას\n"

#: src/fsearch_cli_config.c:265
msgid ""
"fsearch config: close the running FSearch GUI before changing shared "
"settings\n"
msgstr "fsearch config: დახურეთ გაშვებული FSearch GUI გაზიარებული პარამეტრების შეცვლამდე\n"

