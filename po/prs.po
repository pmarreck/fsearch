#: src/fsearch_window.ui:415 src/menus.ui:150 src/menus.ui:156
msgid "Help"
msgstr "کمک"

#: src/fsearch_preferences.ui:1599
msgid ""
"<b>Exit on Escape:</b>\n"
"\n"
"If enabled, FSearch exits when the Escape key is pressed instead of the "
"window being minimized."
msgstr ""
"<b>خروج با کلید Escape:</b>\n"
"\n"
"اگر فعال باشد، FSearch هنگام فشردن کلید Escape به جای کوچک‌سازی پنجره، بسته "
"می‌شود."

#: src/fsearch_preferences.ui:1580
msgid ""
"<b>Restore default filters:</b>\n"
"\n"
"This button restores the default filter configuration.\n"
"\n"
"⚠ All filters which were created or edited by the user will be lost! ⚠"
msgstr ""
"<b>بازگردانی فیلترهای پیش‌فرض:</b>\n"
"\n"
"این دکمه پیکربندی پیش‌فرض فیلترها را بازمی‌گرداند.\n"
"\n"
"⚠ تمام فیلترهایی که توسط کاربر ایجاد یا ویرایش شده‌اند، از دست خواهند رفت! ⚠"

#: src/fsearch_preferences.ui:1563
msgid ""
"<b>Edit selected filter:</b>\n"
"\n"
"This button opens a dialog where you can edit the selected filter."
msgstr ""
"<b>ویرایش فیلتر انتخاب شده:</b>\n"
"\n"
"این دکمه پنجره‌ای را باز می‌کند که در آن می‌توانید فیلتر انتخاب‌شده را ویرایش "
"کنید."

#: src/fsearch_preferences.ui:1546
msgid ""
"<b>Remove selected filter:</b>\n"
"\n"
"This button removes the currently selected filter."
msgstr ""
"<b>حذف فیلتر انتخاب شده:</b>\n"
"\n"
"این دکمه فیلتر در حال حاضر انتخاب شده را حذف می‌کند."

#: src/fsearch_preferences.ui:1529
msgid ""
"<b>Add a new filter:</b>\n"
"\n"
"This button opens a dialog where you can edit a new filter."
msgstr ""
"<b>افزودن فیلتر جدید:</b>\n"
"\n"
"این دکمه پنجره‌ای را باز می‌کند که در آن می‌توانید یک فیلتر جدید ویرایش کنید."

#: src/fsearch_preferences.ui:1508
msgid ""
"<b>Filters:</b>\n"
"\n"
"This is a list of all available filters. A filter is a predefined search.\n"
"\n"
"\t• <b>Name:</b> A unique and descriptive identifier for the filter\n"
"\t• <b>Macro:</b> By typing the macro text followed by a ':' you can enable "
"the filter on demand\n"
"\t• <b>Query:</b> The search term by which the database should be filtered"
msgstr ""
"<b>فیلترها:</b>\n"
"\n"
"این فهرستی از تمام فیلترهای موجود است. یک فیلتر، جست‌وجویی پیش‌فرض است.\n"
"\n"
"\t• <b>نام:</b> شناسه منحصربه‌فرد و توصیفی برای فیلتر\n"
"\t• <b>ماکرو:</b> با تایپ کردن متن ماکرو و دنبال آن قرار دادن علامت ':'، "
"می‌توانید فیلتر را در صورت نیاز فعال کنید\n"
"\t• <b>پرس‌وجو:</b> عبارت جست‌وجویی که پایگاه داده باید بر اساس آن فیلتر شود"

#: src/fsearch_preferences.ui:1491
msgid ""
"<b>Launch desktop files:</b>\n"
"\n"
"If enabled, activating a <i>.desktop</i> file will launch the application "
"defined within that file. This way FSearch can act like an application "
"launcher. Otherwise the <i>.desktop</i> file will be opened with the default "
"handler for this type of files, which is usually a text editor."
msgstr ""
"<b>اجرای فایل‌های دسک‌تاپ:</b>\n"
"\n"
"اگر فعال باشد، فعال کردن یک فایل <i>.desktop</i> برنامه‌ای را که در آن فایل "
"تعریف شده است اجرا می‌کند. به این ترتیب FSearch می‌تواند مانند یک لانچر برنامه "
"عمل کند. در غیر این صورت، فایل <i>.desktop</i> با هندلر پیش‌فرض برای این نوع "
"فایل‌ها، که معمولاً یک ویرایشگر متن است، باز می‌شود."

#: src/fsearch_preferences.ui:1470
msgid ""
"<b>Periodically update database at a specific time interval:</b>\n"
"\n"
"If enabled and as long as FSearch is running, the database will be updated "
"periodically with the given time interval.\n"
"\n"
"If you want to update the database in the background, even when FSearch is "
"not running, you should use tools like cron or systemd timers to "
"periodically trigger the update with:\n"
"\n"
"<i><tt>fsearch --update-database</tt></i>"
msgstr ""
"<b>پایگاه داده را در یک بازه زمانی مشخص به‌طور دوره‌ای بروزرسانی کنید:</b>\n"
"\n"
"اگر فعال باشد و تا زمانی که FSearch در حال اجرا باشد، پایگاه داده با بازه "
"زمانی تعیین‌شده به‌طور دوره‌ای بروزرسانی خواهد شد.\n"
"\n"
"اگر می‌خواهید پایگاه داده را در پس‌زمینه، حتی زمانی که FSearch در حال اجرا "
"نیست، بروزرسانی کنید، باید از ابزارهایی مانند cron یا تایمرهای systemd "
"استفاده کنید تا به‌طور دوره‌ای با دستور زیر بروزرسانی را فعال کنند:\n"
"\n"
"<i><tt>fsearch --update-database</tt></i>"

#: src/fsearch_preferences.ui:1457
msgid "Focus a setting to get a detailed description of what it does."
msgstr ""
"بر روی یک تنظیمات تمرکز کنید تا توضیحی دقیق درباره عملکرد آن دریافت کنید."

#: src/fsearch_preferences.ui:1440
msgid ""
"<b>Exclude hidden files and folders:</b>\n"
"\n"
"If enabled, hidden files and folders will be excluded from the database "
"<i>(i.e. all files or folders which start with a dot character)</i>."
msgstr ""
"<b>فایل‌ها و پوشه‌های مخفی را حذف کنید:</b>\n"
"\n"
"اگر فعال باشد، فایل‌ها و پوشه‌های مخفی از پایگاه داده حذف می‌شوند <i>(یعنی تمام "
"فایل‌ها یا پوشه‌هایی که با کاراکتر نقطه شروع می‌شوند)</i>."

#: src/fsearch_preferences.ui:1423
msgid ""
"<b>Exclude files and folders from database:</b>\n"
"\n"
"This is a semi-colon separated list of files (or folders) you want to "
"exclude from the database. For example <i>.git;.cache;*.swp</i> will exclude "
"all files or folders which are called either <i>.git</i> or <i>.cache</i> or "
"end with <i>.swp</i>."
msgstr ""
"<b>فایل‌ها و پوشه‌ها را از پایگاه داده حذف کنید:</b>\n"
"\n"
"این لیستی از فایل‌ها (یا پوشه‌ها) است که با سمیکولن از هم جدا شده‌اند و شما "
"می‌خواهید آن‌ها را از پایگاه داده حذف کنید. برای مثال <i>.git;.cache;*.swp</i> "
"تمام فایل‌ها یا پوشه‌هایی را که نام آن‌ها <i>.git</i> یا <i>.cache</i> است، یا "
"با <i>.swp</i> پایان می‌یابند، حذف می‌کند."

#: src/fsearch_preferences.ui:1404
msgid ""
"<b>Restore default exclude rules:</b>\n"
"\n"
"This button restores the default set of exclude rules.\n"
"\n"
"⚠ All rules which were created or edited by the user will be lost! ⚠"
msgstr ""
"<b>بازیابی قوانین استثنای پیش‌فرض:</b>\n"
"\n"
"این دکمه مجموعه پیش‌فرض از قوانین استثنا را بازیابی می‌کند.\n"
"\n"
"⚠ تمام قوانینی که توسط کاربر ایجاد یا ویرایش شده‌اند، از دست خواهند رفت! ⚠"

#: src/fsearch_preferences.ui:1387
msgid ""
"<b>Remove selected row:</b>\n"
"\n"
"This removes the selected rule from the list of exclude rules."
msgstr ""
"<b>حذف سطر انتخاب شده:</b>\n"
"\n"
"این مورد قانون انتخاب شده را از لیست قوانین استثنا حذف می‌کند."

#: src/fsearch_preferences.ui:1370
msgid ""
"<b>Add exclude rule:</b>\n"
"\n"
"This adds a new, empty rule to the list. Edit its Pattern, Type, Match and "
"Applies To columns to control what gets excluded from the database."
msgstr ""
"<b>افزودن قانون استثنا:</b>\n"
"\n"
"این مورد یک قانون جدید و خالی به لیست اضافه می‌کند. ستون‌های Pattern، Type، "
"Match و Applies To را ویرایش کنید تا تعیین کنید چه مواردی از پایگاه داده حذف "
"شوند."

#: src/fsearch_preferences.ui:1347
msgid ""
"<b>Exclude rules:</b>\n"
"\n"
"This list contains rules for the files and folders you want to exclude from "
"the database.\n"
"\n"
"\t• <b>Active:</b> If enabled, the rule is applied and matching items are "
"excluded.\n"
"\t• <b>Pattern:</b> The text matched against each item, interpreted "
"according to the Type.\n"
"\t• <b>Type:</b> How the pattern is interpreted — <i>Literal</i> (exact "
"text), <i>Wildcard</i> (using * and ?) or <i>Regex</i> (a regular "
"expression).\n"
"\t• <b>Match:</b> Whether the pattern is matched against the item's <i>Full "
"Path</i> or only its <i>Basename</i> (the name without the path).\n"
"\t• <b>Applies To:</b> Whether the rule affects <i>Files</i>, <i>Folders</i> "
"or both."
msgstr ""
"<b>قوانین استثنا:**\n"
"\n"
"این لیست شامل قوانینی برای فایل‌ها و پوشه‌هایی است که می‌خواهید از پایگاه داده "
"حذف کنید.\n"
"\n"
"\t• <b>فعال:** اگر فعال باشد، قانون اعمال شده و موارد مطابقت‌یافته حذف "
"می‌شوند.\n"
"\t• <b>الگو:** متنی که با هر مورد مقایسه می‌شود و بر اساس نوع (Type) تفسیر "
"می‌گردد.\n"
"\t• <b>نوع:** نحوه تفسیر الگو — <i>Literal</i> (متن دقیق)، <i>Wildcard</i> "
"(با استفاده از * و ؟) یا <i>Regex</i> (یک عبارت منظم).\n"
"\t• <b>مطابقت:** آیا الگو با <i>مسیر کامل</i> (Full Path) مورد یا فقط <i>نام "
"پایه</i> (Basename) آن (نام بدون مسیر) مطابقت دارد.\n"
"\t• <b>مورد اعمال:** آیا این قانون بر <i>فایل‌ها</i>، <i>پوشه‌ها</i> یا هر دو "
"تأثیر می‌گذارد."

#: src/fsearch_preferences.ui:1328
msgid ""
"<b>Rescan every:</b>\n"
"\n"
"If enabled, this folder is rescanned automatically at the given interval. "
"Use the hours and minutes fields to set how often the rescan happens.\n"
"\n"
"This is useful for folders on file systems that can't be monitored for "
"changes."
msgstr ""
"<b>دوباره اسکن در هر:</b>\n"
"\n"
"اگر فعال باشد، این پوشه به طور خودکار در بازه زمانی تعیین شده دوباره اسکن "
"می‌شود. از فیلدهای ساعت و دقیقه برای تنظیم دفعات انجام اسکن استفاده کنید.\n"
"\n"
"این ویژگی برای پوشه‌هایی در سیستم‌های فایل که نمی‌توان تغییرات آن‌ها را نظارت "
"کرد، مفید است."

#: src/fsearch_preferences.ui:1311
msgid ""
"<b>Stay on one file system:</b>\n"
"\n"
"If enabled, FSearch won't cross file system boundaries while scanning this "
"folder. Mounted file systems below it (e.g. external drives or network "
"shares) are skipped."
msgstr ""
"<b>در یک سیستم فایل بمانید:</b>\n"
"\n"
"اگر فعال باشد، FSearch هنگام اسکن این پوشه از مرزهای سیستم‌های فایل عبور "
"نخواهد کرد. سیستم‌های فایلی که در زیر آن نصب شده‌اند (مثلاً درایوهای خارجی یا "
"اشتراک‌های شبکه) نادیده گرفته می‌شوند."

#: src/fsearch_preferences.ui:1294
msgid ""
"<b>Scan after launch:</b>\n"
"\n"
"If enabled, this folder is rescanned every time FSearch starts, so the "
"database reflects any changes made while FSearch wasn't running."
msgstr ""
"<b>جستجو پس از اجرا:</b>\n"
"\n"
"اگر فعال باشد، این پوشه هر بار که FSearch شروع می‌شود دوباره جستجو می‌شود، "
"بنابراین پایگاه داده تغییراتی را که در زمان عدم اجرای FSearch ایجاد شده‌اند "
"منعکس می‌کند."

#: src/fsearch_preferences.ui:1275
msgid ""
"<b>Attempt to monitor:</b>\n"
"\n"
"If enabled, FSearch watches this folder for changes and keeps the database "
"up to date automatically, so you don't have to rescan manually.\n"
"\n"
"Monitoring isn't supported on every file system and uses a small amount of "
"system resources per watched folder. For large directory trees with many "
"files the system may run out of resources to watch them all."
msgstr ""
"<b>تلاش برای نظارت:</b>\n"
"\n"
"اگر فعال باشد، FSearch این پوشه را برای تغییرات مشاهده می‌کند و پایگاه داده "
"را به‌طور خودکار به‌روز نگه می‌دارد، بنابراین نیازی به اسکن مجدد دستی ندارید.\n"
"\n"
"نظارت در همه سیستم‌های فایل پشتیبانی نمی‌شود و برای هر پوشه تحت نظارت، مقدار "
"کمی از منابع سیستم مصرف می‌شود. برای درخت‌های پوشه‌‌ای بزرگ با تعداد زیادی فایل، "
"ممکن است سیستم منابع کافی برای نظارت بر همه آن‌ها نداشته باشد."

#: src/fsearch_preferences.ui:1258
msgid ""
"<b>Remove selected row:</b>\n"
"\n"
"This removes the selected folder from the list of included folders."
msgstr ""
"<b>حذف سطر انتخاب شده:</b>\n"
"\n"
"این مورد پوشه انتخاب شده را از لیست پوشه‌های شامل شده حذف می‌کند."

#: src/fsearch_preferences.ui:1241
msgid ""
"<b>Add a specific path:</b>\n"
"\n"
"Type the full path of a folder here and click the button next to it to "
"include that folder in the database. This is useful for adding a path "
"directly without browsing for it."
msgstr ""
"<b>افزودن یک مسیر خاص:</b>\n"
"\n"
"\n"
"مسیر کامل یک پوشه را در اینجا تایپ کنید و دکمه کنار آن را فشار دهید تا آن "
"پوشه در پایگاه داده گنجانده شود. این برای افزودن مستقیم یک مسیر بدون جستجو "
"در میان پوشه‌ها مفید است."

#: src/fsearch_preferences.ui:1224
msgid ""
"<b>Add folder to database:</b>\n"
"\n"
"This button opens a dialog where you can select a folder you want to include "
"in the database for searching."
msgstr ""
"<b>افزودن پوشه به پایگاه داده:</b>\n"
"\n"
"این دکمه پنجره‌ای را باز می‌کند که در آن می‌توانید پوشه‌ای را که می‌خواهید در "
"پایگاه داده برای جستجو شامل شود، انتخاب کنید."

#: src/fsearch_preferences.ui:1203
msgid ""
"<b>Included folders:</b>\n"
"\n"
"This list contains all folders you want to include in the database.\n"
"\n"
"\t• <b>Active:</b> If enabled, the path will included in the database to be "
"searched in.\n"
"\t• <b>Path:</b> The full path to be included.\n"
"\t• <b>One Filesystem:</b> If enabled, FSearch won't cross filesystem "
"boundaries for this folder"
msgstr ""
"<b>پوشه‌های شامل:**>\n"
"\n"
"این لیست شامل تمام پوشه‌هایی است که می‌خواهید در پایگاه داده بگنجانید.\n"
"\n"
"\t• <b>فعال:** اگر فعال باشد، مسیر در پایگاه داده برای جستجو گنجانده می‌شود.\n"
"\t• <b>مسیر:** مسیر کامل مورد نظر.\n"
"\t• <b>یک سیستم‌فایلی:** اگر فعال باشد، FSearch مرزهای سیستم‌فایل را برای این "
"پوشه عبور نخواهد داد"

#: src/fsearch_preferences.ui:1186
msgid ""
"<b>Update database on start:</b>\n"
"\n"
"If enabled, the database will be updated automatically in the background "
"when you start FSearch."
msgstr ""
"<b>بروزرسانی پایگاه داده در هنگام شروع:</b>\n"
"\n"
"اگر فعال باشد، پایگاه داده به طور خودکار در پس‌زمینه زمانی که FSearch را شروع "
"می‌کنید، بروزرسانی می‌شود."

#: src/fsearch_preferences.ui:1167
msgid ""
"<b>Search as you type:</b>\n"
"\n"
"If enabled, the search is automatically updated with every keystroke.\n"
"\n"
"If disabled, the search is only updated when you hit <i>Enter</i> or press "
"the search button. "
msgstr ""
"<b>جستجو هنگام تایپ کردن:</b>\n"
"\n"
"اگر فعال باشد، جستجو با هر فشار دادن کلید به‌طور خودکار به‌روزرسانی می‌شود.\n"
"\n"
"اگر غیرفعال باشد، جستجو تنها زمانی به‌روزرسانی می‌شود که کلید <i>Enter</i> را "
"بزنید یا دکمه جستجو را فشار دهید."

#: src/fsearch_preferences.ui:1148
msgid ""
"<b>Hide results when search is empty:</b>\n"
"\n"
"If enabled, no search results are displayed when the search entry is empty.\n"
"\n"
"If disabled, all files and folders will be displayed when the search entry "
"is empty."
msgstr ""
"<b>مخفی کردن نتایج زمانی که جستجو خالی است:</b>\n"
"\n"
"اگر فعال باشد، در صورتی که فیلد جستجو خالی باشد، هیچ نتیجه‌ای نمایش داده "
"نمی‌شود.\n"
"\n"
"اگر غیرفعال باشد، در صورتی که فیلد جستجو خالی باشد، تمام فایل‌ها و پوشه‌ها "
"نمایش داده می‌شوند."

#: src/fsearch_preferences.ui:1131
msgid ""
"<b>Match case when query contains at least one upper case character:</b>\n"
"\n"
"If enabled, search terms containing at least one upper case character will "
"trigger a case-sensitive search. This means a search term like <i>Foo</i> "
"will match <i>FooBar.txt</i> but not <i>foobar.txt</i>."
msgstr ""
"<b>زمانی که پرس‌وجو شامل حداقل یک کاراکتر بزرگ (upper case) است، با حروف بزرگ "
"مطابقت دهد:</b>\n"
"\n"
"اگر فعال باشد، عبارات جستجو که حاوی حداقل یک کاراکتر بزرگ هستند، باعث جستجوی "
"حساس به حروف (case-sensitive) می‌شوند. این بدان معناست که عبارت جستجویی مانند "
"<i>Foo</i> با <i>FooBar.txt</i> مطابقت دارد اما با <i>foobar.txt</i> مطابقت "
"نمی‌دهد."

#: src/fsearch_preferences.ui:1114
msgid ""
"<b>Search in path when query contains path separators:</b>\n"
"\n"
"If enabled, search terms containing path separators (i.e. \"/\") will be "
"automatically matched against the full path of a file or folder."
msgstr ""
"<b>جستجو در مسیر زمانی که پرس‌وجو شامل جداکننده‌های مسیر است:</b>\n"
"\n"
"اگر فعال باشد، عبارات جستجو که حاوی جداکننده‌های مسیر (یعنی \"/\") هستند، به "
"طور خودکار با مسیر کامل یک فایل یا پوشه مطابقت داده می‌شوند."

#: src/fsearch_preferences.ui:1097
msgid ""
"<b>Show warning dialogs:</b>\n"
"\n"
"If enabled, a warning dialog is displayed when a file or folder failed to "
"open."
msgstr ""
"<b>نمایش‌های هشدار را نشان بده:**\n"
"\n"
"اگر فعال باشد، زمانی که یک فایل یا پوشه باز نشود، یک پنجره هشدار نمایش داده "
"می‌شود."

#: src/fsearch_preferences.ui:1080
msgid ""
"<b>Show database indexing status:</b>\n"
"\n"
"If enabled, the path that is currently being indexed is displayed in the "
"statusbar."
msgstr ""
"<b>نمایش وضعیت شاخص‌گذاری پایگاه داده:</b>\n"
"\n"
"اگر فعال باشد، مسیری که در حال حاضر در حال شاخص‌گذاری است در نوار وضعیت نمایش "
"داده می‌شود."

#: src/fsearch_preferences.ui:1063
msgid ""
"<b>Single click to open:</b>\n"
"\n"
"If enabled, a single click will open the selected file/folder. If you only "
"want to select a file/folder while this setting is active, you need to hold "
"<i>Ctrl</i> at the same time while clicking the file/folder."
msgstr ""
"<b>یک کلیک برای باز کردن:</b>\n"
"\n"
"اگر فعال باشد، یک کلیک فایل/پوشه انتخاب شده را باز می‌کند. اگر در حالی که این "
"تنظیم فعال است، فقط می‌خواهید یک فایل/پوشه را انتخاب کنید، باید هنگام کلیک بر "
"روی فایل/پوشه، کلید <i>Ctrl</i> را همزمان نگه دارید."

#: src/fsearch_preferences.ui:1046
msgid ""
"<b>Open path with double click in path column:</b>\n"
"\n"
"If enabled, double clicking in the path column will open the selected path."
msgstr ""
"<b>باز کردن مسیر با کلیک دوگانه در ستون مسیر:</b>\n"
"\n"
"اگر فعال باشد، کلیک دوگانه در ستون مسیر، مسیر انتخاب شده را باز می‌کند."

#: src/fsearch_preferences.ui:1029
msgid ""
"<b>Remember sort order:</b>\n"
"\n"
"If enabled, the sort order of the results view from the previous session "
"will be restored when you open an FSearch window."
msgstr ""
"<b>ترتیب مرتب‌سازی را به خاطر بسپارید:</b>\n"
"\n"
"اگر فعال باشد، ترتیب مرتب‌سازی نمای نتایج از نشست قبلی هنگام باز کردن پنجره "
"FSearch بازیابی می‌شود."

#: src/fsearch_preferences.ui:1012
msgid ""
"<b>Remember column configuration:</b>\n"
"\n"
"If enabled, the column configuration of the results view from the previous "
"session will be restored when you open an FSearch window. This includes the "
"size and visibility of all columns."
msgstr ""
"<b>تنظیمات ستون‌ها را به خاطر بسپارید:</b>\n"
"\n"
"اگر فعال باشد، تنظیمات ستون‌های نمایۀ نتایج از نشست قبلی هنگام باز کردن پنجره "
"FSearch بازیابی می‌شود. این شامل اندازه و قابلیت مشاهده تمام ستون‌ها است."

#: src/fsearch_preferences.ui:995
msgid ""
"<b>Show icons in name column:</b>\n"
"\n"
"If enabled, file/folder icons will be shown in the name column."
msgstr ""
"<b>نمایش آیکون‌ها در ستون نام:</b>\n"
"\n"
"اگر فعال باشد، آیکون‌های فایل/پوشه در ستون نام نشان داده می‌شوند."

#: src/fsearch_preferences.ui:978
msgid ""
"<b>Show tooltips:</b>\n"
"\n"
"If enabled, the results view will show the full path of the focused file/"
"folder in a small tooltip window."
msgstr ""
"<b>نمایش راهنمای ابزار (tooltips):</b>\n"
"\n"
"اگر فعال باشد، نمای نتایج مسیر کامل فایل/پوشه انتخاب شده را در یک پنجره کوچک "
"راهنمای ابزار نشان می‌دهد."

#: src/fsearch_preferences.ui:956
msgid ""
"<b>Show highlighted search terms:</b>\n"
"\n"
"If enabled, the search terms will be highlighted in the results view. For "
"example when you search for \"foo\" all appearances of <i>foo</i> in file/"
"folder names will be highlighted with bold characters:\n"
"\n"
"\t<b>foo</b>bar.txt\n"
"\tfile.<b>foo</b>\n"
"\n"
"This also works for regular expressions and wildcard expressions starting or "
"ending with an asterisk. "
msgstr ""
"<b>نمایش کلمات جست‌وجوی برجسته:**\n"
"\n"
"اگر فعال باشد، کلمات جست‌وجو در نمای نتایج برجسته می‌شوند. به عنوان مثال وقتی "
"برای \"foo\" جست‌وجو می‌کنید، تمام موارد <i>foo</i> در نام‌های فایل/پوشه با "
"حروف ضخیم برجسته می‌شوند:\n"
"\n"
"\t<b>foo</b>bar.txt\n"
"\tfile.<b>foo</b>\n"
"\n"
"این قابلیت برای عبارات منظم و عبارت‌های وحشی که با ستاره شروع یا به آن ختم "
"می‌شوند نیز عمل می‌کند."

#: src/fsearch_preferences.ui:932
msgid ""
"<b>Behaviour after successfully opening a file:</b>\n"
"\n"
"When a file/folder was successfully opened one of the following actions can "
"be performed:\n"
"\t• <b>Nothing:</b> Nothing happens.\n"
"                        • <b>Minimize:</b> The currently selected FSearch "
"window becomes minimized.\n"
"\t• <b>Close:</b> Quit FSearch.\n"
"\n"
"You can configure if those actions should be triggered when the file was "
"opened with\n"
"\t• <b>keyboard shortcuts or menu entries</b> and/or\n"
"\t• <b>mouse click</b>"
msgstr ""
"<b>رفتار پس از باز شدن موفقیت‌آمیز یک فایل:</b>\n"
"\n"
"زمانی که یک فایل/پوشه با موفقیت باز شد، یکی از اقدامات زیر می‌تواند انجام "
"شود:\n"
"\t• <b>هیچ:</b> هیچ اتفاقی نمی‌افتد.\n"
"\t• <b>کوچک‌سازی (Minimize):</b> پنجره فعلی FSearch انتخاب‌شده کوچک می‌شود.\n"
"\t• <b>بستن:** فایـل FSearch بسته می‌شود.\n"
"\n"
"شما می‌توانید تنظیم کنید که آیا این اقدامات باید زمانی که فایل با موارد زیر "
"باز شد، اجرا شوند:\n"
"\t• <b>میان‌برهای کیبورد یا ورودی‌های منو</b> و/یا\n"
"\t• <b>کلیک ماوس</b>"

#: src/fsearch_preferences.ui:913
msgid ""
"<b>Remember window size:</b>\n"
"\n"
"If enabled, the window size from the previous session will be restored when "
"you open an FSearch window.\n"
"\n"
"Note that some window managers ignore this request and force the window to "
"have a different size."
msgstr ""
"<b>اندازه پنجره را به خاطر بسپار:**\n"
"\n"
"اگر فعال باشد، اندازه پنجره از نشست قبلی هنگام باز کردن یک پنجره FSearch "
"بازیابی می‌شود.\n"
"\n"
"توجه داشته باشید که برخی از مدیران پنجره این درخواست را نادیده می‌گیرند و "
"پنجره را با اندازه‌ای متفاوت اجبار می‌کنند."

#: src/fsearch_preferences.ui:893
msgid ""
"<b>Use binary units instead of decimal units:</b>\n"
"\n"
"This settings controls how file sizes are displayed.\n"
"\n"
"\t• <b>Binary units:</b> This refers to binary IEC prefixes <i>(e.g. 1 KiB = "
"1024 bytes)</i>\n"
"\t• <b>Decimal  units:</b> This refers to decimal SI prefixes <i>(e.g. 1 kB "
"= 1000 bytes)</i>"
msgstr ""
"<b>استفاده از واحدهای باینری به جای واحدهای دهدهی:**\n"
"\n"
"این تنظیمات نحوه نمایش اندازه فایل‌ها را کنترل می‌کند.\n"
"\n"
"\t• <b>واحدهای باینری:</b> این به پیش‌فرض‌های باینری IEC اشاره دارد <i>(مثلاً 1 "
"KiB = 1024 بایت)</i>\n"
"\t• <b>واحدهای دهدهی:</b> این به پیش‌فرض‌های دهدهی SI اشاره دارد <i>(مثلاً 1 kB "
"= 1000 بایت)</i>"

#: src/fsearch_preferences.ui:873
msgid ""
"<b>Enable client-side decorations:</b>\n"
"\n"
"If enabled, the search entry and main menu are displayed in the window title "
"bar.\n"
"\n"
"If disabled, the main menu is displayed as a menu bar with the search entry "
"below it.\n"
"This resembles a more traditional UI layout and takes a little bit more "
"space."
msgstr ""
"<b>فعال‌سازی تزئینات سمت کلاینت:</b>\n"
"\n"
"اگر فعال باشد، ورودی جستجو و منوی اصلی در نوار عنوان پنجره نمایش داده "
"می‌شوند.\n"
"\n"
"اگر غیرفعال باشد، منوی اصلی به صورت یک نوار منو با ورودی جستجو در زیر آن "
"نمایش داده می‌شود.\n"
"این چیدمان با طراحی رابط کاربری سنتی‌تری شباهت دارد و فضای کمی بیشتری اشغال "
"می‌کند."

#: src/fsearch_preferences.ui:855
msgid ""
"<b>Enable dark theme:</b>\n"
"\n"
"If enabled, the system theme is asked to use a darker styling for the "
"application <i>(i.e. dark UI elements on bright text)</i>.\n"
"\n"
"Note that not all system themes provide such a darker variant, therefore "
"enabling this setting might not have an effect."
msgstr ""
"<b>فعال‌سازی تم تاریک:</b>\n"
"\n"
"اگر فعال شود، از سیستم خواسته می‌شود که برای اپلیکیشن استایلی تیره‌تر استفاده "
"کند <i>(یعنی عناصر رابط کاربری تیره روی متن روشن)</i>.\n"
"\n"
"توجه داشته باشید که همه تم‌های سیستم نسخه تیره‌تر را ارائه نمی‌دهند، بنابراین "
"فعال کردن این تنظیم ممکن است تأثیری نداشته باشد."

