#: src/fsearch_cli_config.c:159
msgid ""
"Usage: fsearch config unset KEY\n"
"Restore one scalar setting to its built-in default.\n"
msgstr ""
"Uso: fsearch config unset KEY\n"
"Restaura unha opción escalar ao seu valor predeterminado incorporado.\n"

#: src/fsearch_cli_config.c:161
msgid ""
"Usage: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Reset is destructive and requires --yes. --rescan applies to roots, "
"database, excludes, or all.\n"
msgstr ""
"Uso: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"O restablecemento é destrutivo e require --yes. --rescan aplícase ás raíces, "
"á base de datos, ás exclusións ou a todo.\n"

#: src/fsearch_cli_config.c:164
msgid ""
"Usage: fsearch config doctor\n"
"Check configuration readability and whether the saved index uses the same "
"roots and exclusions.\n"
msgstr ""
"Uso: fsearch config doctor\n"
"Comproba a lexibilidade da configuración e se o índice gardado usa as mesmas "
"raíces e exclusións.\n"

#: src/fsearch_cli_config.c:170
msgid ""
"Usage: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                List indexed roots\n"
"  add PATH [OPTIONS]           Add a root directory\n"
"  set PATH [OPTIONS]           Change an existing root\n"
"  remove PATH [--rescan]       Remove an existing root\n"
"\n"
"Options for add and set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Set periodic rescan interval; 0 disables it\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Uso: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Ordes:\n"
"  list [--json]                Lista as raíces indexadas\n"
"  add PATH [OPTIONS]           Engade un directorio raíz\n"
"  set PATH [OPTIONS]           Cambia unha raíz existente\n"
"  remove PATH [--rescan]       Elimina unha raíz existente\n"
"\n"
"Opcións para add e set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Establece o intervalo de reexploración "
"periódica; 0 desactívao\n"
"  --rescan                      Reconstrúe o índice inmediatamente despois "
"de gardar\n"

#: src/fsearch_cli_config.c:187
msgid ""
"Usage: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List exclusions\n"
"  add PATTERN [OPTIONS]         Add an exclusion\n"
"  remove PATTERN [OPTIONS]      Remove a matching exclusion\n"
"  hidden [true|false] [--rescan]\n"
"                                View or change hidden-file exclusion\n"
"\n"
"Options for add and remove:\n"
"  --type fixed|wildcard|regex   Default: fixed\n"
"  --scope full-path|basename    Default: full-path\n"
"  --target both|files|folders   Default: both\n"
"  --active, --inactive          Add state or removal selector\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Uso: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Ordes:\n"
"  list [--json]                 Lista as exclusións\n"
"  add PATTERN [OPTIONS]         Engade unha exclusión\n"
"  remove PATTERN [OPTIONS]      Elimina unha exclusión coincidente\n"
"  hidden [true|false] [--rescan]\n"
"                                Mostra ou cambia a exclusión de ficheiros "
"ocultos\n"
"\n"
"Opcións para add e remove:\n"
"  --type fixed|wildcard|regex   Predeterminado: fixed\n"
"  --scope full-path|basename    Predeterminado: full-path\n"
"  --target both|files|folders   Predeterminado: both\n"
"  --active, --inactive          Estado ao engadir ou selector de "
"eliminación\n"
"  --rescan                      Reconstrúe o índice inmediatamente despois "
"de gardar\n"

#: src/fsearch_cli_config.c:204
msgid ""
"Usage: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List saved filters\n"
"  add NAME [OPTIONS]            Add a named filter\n"
"  set NAME [OPTIONS]            Change a named filter\n"
"  remove NAME                   Remove a named filter\n"
"  reset                         Restore built-in filters\n"
"\n"
"Options for add and set:\n"
"  --query QUERY                 Saved FSearch query\n"
"  --macro MACRO                 Query macro name\n"
"  --case, --no-case             Match case\n"
"  --path, --no-path             Search full paths\n"
"  --regex, --no-regex           Treat query as a regular expression\n"
msgstr ""
"Uso: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Ordes:\n"
"  list [--json]                 Lista os filtros gardados\n"
"  add NAME [OPTIONS]            Engade un filtro con nome\n"
"  set NAME [OPTIONS]            Cambia un filtro con nome\n"
"  remove NAME                   Elimina un filtro con nome\n"
"  reset                         Restaura os filtros incorporados\n"
"\n"
"Opcións para add e set:\n"
"  --query QUERY                 Consulta de FSearch gardada\n"
"  --macro MACRO                 Nome da macro de consulta\n"
"  --case, --no-case             Distingue entre maiúsculas e minúsculas\n"
"  --path, --no-path             Busca nas rutas completas\n"
"  --regex, --no-regex           Trata a consulta como unha expresión "
"regular\n"

