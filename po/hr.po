msgid "Using stale FSearch index; automatic reindexing is disabled."
msgstr ""
"Koristi se zastarjeli FSearch indeks; automatsko ponovno indeksiranje je "
"onemogućeno."

#: src/fsearch_cli.c:239
msgid ""
"\n"
"Index refresh options:\n"
"  --refresh, --refresh-index    Rescan before searching\n"
"  --no-reindex                  Use the existing index without rescanning\n"
"  --reindex-interval SECONDS    Refresh when the index is this old\n"
msgstr ""
"\n"
"Opcije osvježavanja indeksa:\n"
"  --refresh, --refresh-index    Ponovno skeniraj prije pretraživanja\n"
"  --no-reindex                  Koristi postojeći indeks bez ponovnog "
"skeniranja\n"
"  --reindex-interval SECONDS    Osvježi kada je indeks star toliko sekundi\n"

#: src/fsearch_cli.c:526
msgid "fsearch: --reindex-interval requires a non-negative number of seconds\n"
msgstr "fsearch: --reindex-interval zahtijeva nenegativan broj sekundi\n"

#: src/fsearch_cli.c:577
msgid "fsearch: index is unavailable and automatic reindexing is disabled\n"
msgstr ""
"fsearch: indeks nije dostupan i automatsko ponovno indeksiranje je "
"onemogućeno\n"

