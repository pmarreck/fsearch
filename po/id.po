#: src/fsearch.c:918
msgid ""
"Interface selection: set FSEARCH_UI=CLI to default to CLI or FSEARCH_UI=GUI "
"to default to GUI. Use --cli or --gui to override it for one invocation."
msgstr ""
"Pemilihan antarmuka: atur FSEARCH_UI=CLI untuk menggunakan CLI secara "
"default atau FSEARCH_UI=GUI untuk menggunakan GUI secara default. Gunakan --"
"cli atau --gui untuk mengabaikannya pada satu pemanggilan."
