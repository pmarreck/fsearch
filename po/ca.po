#: src/fsearch_cli_config.c:157
msgid ""
"Usage: fsearch config set KEY VALUE\n"
"Set a boolean, integer, string, or enumerated scalar value.\n"
msgstr ""
"Ús: fsearch config set KEY VALUE\n"
"Estableix un valor escalar booleà, enter, de cadena o enumerat.\n"

#: src/fsearch_cli_config.c:159
msgid ""
"Usage: fsearch config unset KEY\n"
"Restore one scalar setting to its built-in default.\n"
msgstr ""
"Ús: fsearch config unset KEY\n"
"Restaura un paràmetre escalar al valor predeterminat incorporat.\n"

#: src/fsearch_cli_config.c:161
msgid ""
"Usage: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Reset is destructive and requires --yes. --rescan applies to roots, "
"database, excludes, or all.\n"
msgstr ""
"Ús: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"El restabliment és destructiu i requereix --yes. --rescan s'aplica a les "
"arrels, la base de dades, les exclusions o tot.\n"

#: src/fsearch_cli_config.c:164
msgid ""
"Usage: fsearch config doctor\n"
"Check configuration readability and whether the saved index uses the same "
"roots and exclusions.\n"
msgstr ""
"Ús: fsearch config doctor\n"
"Comprova que la configuració sigui llegible i si l'índex desat utilitza les "
"mateixes arrels i exclusions.\n"

#: src/fsearch_cli_config.c:170
msgid ""
"Usage: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                List indexed roots\n"
"  add PATH [OPTIONS]           Add a root directory\n"
"  set PATH [OPTIONS]           Change an existing root\n"
"  remove PATH [--rescan]       Remove an existing root\n"
"\n"
"Options for add and set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Set periodic rescan interval; 0 disables it\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Ús: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Ordres:\n"
"  list [--json]                Llista les arrels indexades\n"
"  add PATH [OPTIONS]           Afegeix un directori arrel\n"
"  set PATH [OPTIONS]           Canvia una arrel existent\n"
"  remove PATH [--rescan]       Elimina una arrel existent\n"
"\n"
"Opcions per a add i set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Estableix l'interval de reexploració "
"periòdica; 0 la inhabilita\n"
"  --rescan                      Reconstrueix l'índex immediatament després "
"de desar\n"

#: src/fsearch_cli_config.c:187
msgid ""
"Usage: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List exclusions\n"
"  add PATTERN [OPTIONS]         Add an exclusion\n"
"  remove PATTERN [OPTIONS]      Remove a matching exclusion\n"
"  hidden [true|false] [--rescan]\n"
"                                View or change hidden-file exclusion\n"
"\n"
"Options for add and remove:\n"
"  --type fixed|wildcard|regex   Default: fixed\n"
"  --scope full-path|basename    Default: full-path\n"
"  --target both|files|folders   Default: both\n"
"  --active, --inactive          Add state or removal selector\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Ús: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Ordres:\n"
"  list [--json]                 Llista les exclusions\n"
"  add PATTERN [OPTIONS]         Afegeix una exclusió\n"
"  remove PATTERN [OPTIONS]      Elimina una exclusió coincident\n"
"  hidden [true|false] [--rescan]\n"
"                                Mostra o canvia l'exclusió dels fitxers "
"ocults\n"
"\n"
"Opcions per a add i remove:\n"
"  --type fixed|wildcard|regex   Valor predeterminat: fixed\n"
"  --scope full-path|basename    Valor predeterminat: full-path\n"
"  --target both|files|folders   Valor predeterminat: both\n"
"  --active, --inactive          Afegeix l'estat o el selector d'eliminació\n"
"  --rescan                      Reconstrueix l'índex immediatament després "
"de desar\n"

#: src/fsearch_cli_config.c:204
msgid ""
"Usage: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List saved filters\n"
"  add NAME [OPTIONS]            Add a named filter\n"
"  set NAME [OPTIONS]            Change a named filter\n"
"  remove NAME                   Remove a named filter\n"
"  reset                         Restore built-in filters\n"
"\n"
"Options for add and set:\n"
"  --query QUERY                 Saved FSearch query\n"
"  --macro MACRO                 Query macro name\n"
"  --case, --no-case             Match case\n"
"  --path, --no-path             Search full paths\n"
"  --regex, --no-regex           Treat query as a regular expression\n"
msgstr ""
"Ús: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Ordres:\n"
"  list [--json]                 Llista els filtres desats\n"
"  add NAME [OPTIONS]            Afegeix un filtre amb nom\n"
"  set NAME [OPTIONS]            Canvia un filtre amb nom\n"
"  remove NAME                   Elimina un filtre amb nom\n"
"  reset                         Restaura els filtres incorporats\n"
"\n"
"Opcions per a add i set:\n"
"  --query QUERY                 Consulta de FSearch desada\n"
"  --macro MACRO                 Nom de la macro de consulta\n"
"  --case, --no-case             Distingeix entre majúscules i minúscules\n"
"  --path, --no-path             Cerca en els camins complets\n"
"  --regex, --no-regex           Tracta la consulta com una expressió "
"regular\n"

