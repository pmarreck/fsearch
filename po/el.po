msgstr ""
"Χρήση: fsearch config get KEY [--json]\n"
"Εμφάνιση μίας βαθμωτής τιμής συγκεκριμένου τύπου. Ανακαλύψτε κλειδιά με το "
"'fsearch config show'.\n"

#: src/fsearch_cli_config.c:157
msgid ""
"Usage: fsearch config set KEY VALUE\n"
"Set a boolean, integer, string, or enumerated scalar value.\n"
msgstr ""
"Χρήση: fsearch config set KEY VALUE\n"
"Ορισμός μίας λογικής, ακέραιας, συμβολοσειράς ή απαριθμημένης βαθμωτής "
"τιμής.\n"

#: src/fsearch_cli_config.c:159
msgid ""
"Usage: fsearch config unset KEY\n"
"Restore one scalar setting to its built-in default.\n"
msgstr ""
"Χρήση: fsearch config unset KEY\n"
"Επαναφορά μίας βαθμωτής ρύθμισης στην ενσωματωμένη προεπιλογή της.\n"

#: src/fsearch_cli_config.c:161
msgid ""
"Usage: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Reset is destructive and requires --yes. --rescan applies to roots, "
"database, excludes, or all.\n"
msgstr ""
"Χρήση: fsearch config reset [KEY|SECTION] --yes [--rescan]\n"
"Η επαναφορά είναι καταστροφική και απαιτεί --yes. Το --rescan εφαρμόζεται σε "
"ρίζες, βάση δεδομένων, εξαιρέσεις ή όλα.\n"

#: src/fsearch_cli_config.c:164
msgid ""
"Usage: fsearch config doctor\n"
"Check configuration readability and whether the saved index uses the same "
"roots and exclusions.\n"
msgstr ""
"Χρήση: fsearch config doctor\n"
"Έλεγχος της αναγνωσιμότητας των ρυθμίσεων και αν το αποθηκευμένο ευρετήριο "
"χρησιμοποιεί τις ίδιες ρίζες και εξαιρέσεις.\n"

#: src/fsearch_cli_config.c:170
msgid ""
"Usage: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                List indexed roots\n"
"  add PATH [OPTIONS]           Add a root directory\n"
"  set PATH [OPTIONS]           Change an existing root\n"
"  remove PATH [--rescan]       Remove an existing root\n"
"\n"
"Options for add and set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Set periodic rescan interval; 0 disables it\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Χρήση: fsearch config roots COMMAND [PATH] [OPTIONS]\n"
"\n"
"Εντολές:\n"
"  list [--json]                Παράθεση ευρετηριασμένων ριζών\n"
"  add PATH [OPTIONS]           Προσθήκη ενός ριζικού καταλόγου\n"
"  set PATH [OPTIONS]           Αλλαγή μιας υπάρχουσας ρίζας\n"
"  remove PATH [--rescan]       Αφαίρεση μιας υπάρχουσας ρίζας\n"
"\n"
"Επιλογές για add και set:\n"
"  --active, --inactive\n"
"  --monitor, --no-monitor\n"
"  --one-file-system, --no-one-file-system\n"
"  --scan-after-launch, --no-scan-after-launch\n"
"  --rescan-every SECONDS        Ορισμός διαστήματος περιοδικής επανασάρωσης· "
"το 0 την απενεργοποιεί\n"
"  --rescan                      Άμεση αναδόμηση του ευρετηρίου μετά την "
"αποθήκευση\n"

#: src/fsearch_cli_config.c:187
msgid ""
"Usage: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List exclusions\n"
"  add PATTERN [OPTIONS]         Add an exclusion\n"
"  remove PATTERN [OPTIONS]      Remove a matching exclusion\n"
"  hidden [true|false] [--rescan]\n"
"                                View or change hidden-file exclusion\n"
"\n"
"Options for add and remove:\n"
"  --type fixed|wildcard|regex   Default: fixed\n"
"  --scope full-path|basename    Default: full-path\n"
"  --target both|files|folders   Default: both\n"
"  --active, --inactive          Add state or removal selector\n"
"  --rescan                      Rebuild the index immediately after saving\n"
msgstr ""
"Χρήση: fsearch config excludes COMMAND [PATTERN|VALUE] [OPTIONS]\n"
"\n"
"Εντολές:\n"
"  list [--json]                 Παράθεση εξαιρέσεων\n"
"  add PATTERN [OPTIONS]         Προσθήκη μιας εξαίρεσης\n"
"  remove PATTERN [OPTIONS]      Αφαίρεση μιας αντίστοιχης εξαίρεσης\n"
"  hidden [true|false] [--rescan]\n"
"                                Προβολή ή αλλαγή της εξαίρεσης κρυφών "
"αρχείων\n"
"\n"
"Επιλογές για add και remove:\n"
"  --type fixed|wildcard|regex   Προεπιλογή: fixed\n"
"  --scope full-path|basename    Προεπιλογή: full-path\n"
"  --target both|files|folders   Προεπιλογή: both\n"
"  --active, --inactive          Κατάσταση προσθήκης ή επιλογέας αφαίρεσης\n"
"  --rescan                      Άμεση αναδόμηση του ευρετηρίου μετά την "
"αποθήκευση\n"

#: src/fsearch_cli_config.c:204
msgid ""
"Usage: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Commands:\n"
"  list [--json]                 List saved filters\n"
"  add NAME [OPTIONS]            Add a named filter\n"
"  set NAME [OPTIONS]            Change a named filter\n"
"  remove NAME                   Remove a named filter\n"
"  reset                         Restore built-in filters\n"
"\n"
"Options for add and set:\n"
"  --query QUERY                 Saved FSearch query\n"
"  --macro MACRO                 Query macro name\n"
"  --case, --no-case             Match case\n"
"  --path, --no-path             Search full paths\n"
"  --regex, --no-regex           Treat query as a regular expression\n"
msgstr ""
"Χρήση: fsearch config filters COMMAND [NAME] [OPTIONS]\n"
"\n"
"Εντολές:\n"
"  list [--json]                 Εμφάνιση αποθηκευμένων φίλτρων\n"
"  add NAME [OPTIONS]            Προσθήκη επώνυμου φίλτρου\n"
"  set NAME [OPTIONS]            Αλλαγή επώνυμου φίλτρου\n"
"  remove NAME                   Αφαίρεση επώνυμου φίλτρου\n"
"  reset                         Επαναφορά ενσωματωμένων φίλτρων\n"
"\n"
"Επιλογές για add και set:\n"
"  --query QUERY                 Αποθηκευμένο ερώτημα FSearch\n"
"  --macro MACRO                 Όνομα μακροεντολής ερωτήματος\n"
"  --case, --no-case             Αντιστοίχιση πεζών-κεφαλαίων\n"
"  --path, --no-path             Αναζήτηση πλήρων διαδρομών\n"
"  --regex, --no-regex           Θεώρηση του ερωτήματος ως κανονικής "
"έκφρασης\n"

