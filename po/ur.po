#: src/fsearch_preferences.ui:855
msgid ""
"<b>Enable dark theme:</b>\n"
"\n"
"If enabled, the system theme is asked to use a darker styling for the "
"application <i>(i.e. dark UI elements on bright text)</i>.\n"
"\n"
"Note that not all system themes provide such a darker variant, therefore "
"enabling this setting might not have an effect."
msgstr ""
"<b>ڈارک تھیم فعال کریں:</b>\n"
"\n"
"اگر اسے فعال کیا گیا، تو سسٹم کو درخواست کی جائے گی کہ وہ ایپلیکیشن کے لیے "
"زیادہ گہرے انداز کا استعمال کرے <i> (یعنی روشن متن پر ڈارک UI عناصر)</i>۔\n"
"\n"
"نوٹ کریں کہ تمام سسٹم تھیمز اس طرح کا ڈارک ورژن فراہم نہیں کرتے، اس لیے اس "
"سیٹنگ کو فعال کرنے سے اثرات ظاہر نہیں ہو سکتے ہیں۔"

#: src/fsearch_preferences.ui:873
msgid ""
"<b>Enable client-side decorations:</b>\n"
"\n"
"If enabled, the search entry and main menu are displayed in the window title "
"bar.\n"
"\n"
"If disabled, the main menu is displayed as a menu bar with the search entry "
"below it.\n"
"This resembles a more traditional UI layout and takes a little bit more "
"space."
msgstr ""
"<b>کلائنٹ سائیڈ ڈیکوریشنز فعال کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو سرچ انٹری اور مین مینو ونڈو ٹائٹل بار میں دکھائے جائیں "
"گے۔\n"
"\n"
"اگر اسے غیر فعال کیا جاتا ہے، تو مین مینو ایک مینو بار کے طور پر دکھایا جائے "
"گا جس کے نیچے سرچ انٹری ہوگی۔\n"
"یہ زیادہ روایتی UI لے آؤٹ سے مماثلت رکھتا ہے اور تھوڑی زیادہ جگہ لیتا ہے۔"

#: src/fsearch_preferences.ui:893
msgid ""
"<b>Use binary units instead of decimal units:</b>\n"
"\n"
"This settings controls how file sizes are displayed.\n"
"\n"
"\t• <b>Binary units:</b> This refers to binary IEC prefixes <i>(e.g. 1 KiB = "
"1024 bytes)</i>\n"
"\t• <b>Decimal  units:</b> This refers to decimal SI prefixes <i>(e.g. 1 kB "
"= 1000 bytes)</i>"
msgstr ""
"<b>ڈیسیمل یونٹس کے بجائے بائنری یونٹس استعمال کریں:</b>\n"
"\n"
"یہ سیٹنگز کنٹرول کرتی ہیں کہ فائل کے سائز کیسے دکھائے جائیں۔\n"
"\n"
"\t• <b>بائنری یونٹس:</b> اس سے مراد بائنری IEC پریفکس ہیں <i>(مثال کے طور پر "
"1 KiB = 1024 بائٹس)</i>\n"
"\t• <b>ڈیسیمل یونٹس:</b> اس سے مراد ڈیسیمل SI پریفکس ہیں <i>(مثال کے طور پر "
"1 kB = 1000 بائٹ)</i>"

#: src/fsearch_preferences.ui:913
msgid ""
"<b>Remember window size:</b>\n"
"\n"
"If enabled, the window size from the previous session will be restored when "
"you open an FSearch window.\n"
"\n"
"Note that some window managers ignore this request and force the window to "
"have a different size."
msgstr ""
"<b>ونڈو کا سائز یاد رکھیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو جب آپ FSearch ونڈو کھولیں گے تو پچھلے سیشن سے ونڈو کا "
"سائز بحال کر دیا جائے گا۔\n"
"\n"
"یاد رہے کہ کچھ ونڈو مینیجرز اس درخواست کو نظر انداز کرتے ہیں اور ونڈو کو "
"مختلف سائز پر مجبور کرتے ہیں۔"

#: src/fsearch_preferences.ui:932
msgid ""
"<b>Behaviour after successfully opening a file:</b>\n"
"\n"
"When a file/folder was successfully opened one of the following actions can "
"be performed:\n"
"\t• <b>Nothing:</b> Nothing happens.\n"
"                        • <b>Minimize:</b> The currently selected FSearch "
"window becomes minimized.\n"
"\t• <b>Close:</b> Quit FSearch.\n"
"\n"
"You can configure if those actions should be triggered when the file was "
"opened with\n"
"\t• <b>keyboard shortcuts or menu entries</b> and/or\n"
"\t• <b>mouse click</b>"
msgstr ""
"<b>فائل کامیابی سے کھولنے کے بعد کا رویہ:</b>\n"
"\n"
"جب کوئی فائل/فولڈر کامیابی سے کھولا جائے تو درج ذیل میں سے ایک عمل انجام دیا "
"جا سکتا ہے:\n"
"\t• <b>کچھ نہیں:</b> کچھ نہیں ہوتا۔\n"
"\t• <b>کم کریں (Minimize):</b> فی الحال منتخب کردہ FSearch ونڈو چھوٹی ہو "
"جاتی ہے۔\n"
"\t• <b>بند کریں:</b> FSearch بند ہو جاتا ہے۔\n"
"\n"
"آپ اس بات کو ترتیب دے سکتے ہیں کہ کیا یہ اقدامات تب کیے جائیں جب فائل کو درج "
"ذیل کے ذریعے کھولا گیا ہو:\n"
"\t• <b>کی بورڈ شارٹ کٹس یا مینو اندراجات</b> اور/یا\n"
"\t• <b>ماؤس کلک</b>"

#: src/fsearch_preferences.ui:956
msgid ""
"<b>Show highlighted search terms:</b>\n"
"\n"
"If enabled, the search terms will be highlighted in the results view. For "
"example when you search for \"foo\" all appearances of <i>foo</i> in file/"
"folder names will be highlighted with bold characters:\n"
"\n"
"\t<b>foo</b>bar.txt\n"
"\tfile.<b>foo</b>\n"
"\n"
"This also works for regular expressions and wildcard expressions starting or "
"ending with an asterisk. "
msgstr ""
"<b>نمایاں کردہ تلاش کے الفاظ دکھائیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو نتائج کے منظر میں تلاش کے الفاظ نمایاں ہوں گے۔ مثال کے "
"طور پر جب آپ \"foo\" تلاش کرتے ہیں تو فائل/فولڈر کے ناموں میں <i>foo</i> کی "
"تمام پیش رفت کو بولڈ حروف کے ساتھ نمایاں کیا جائے گا:\n"
"\n"
"\t<b>foo</b>bar.txt\n"
"\tfile.<b>foo</b>\n"
"\n"
"یہ ریگولر ایکسپریشنز اور وائلڈ کارڈ ایکسپریشنز کے لیے بھی کام کرتا ہے جو "
"اسٹار (̀) سے شروع یا ختم ہوتے ہیں۔"

#: src/fsearch_preferences.ui:978
msgid ""
"<b>Show tooltips:</b>\n"
"\n"
"If enabled, the results view will show the full path of the focused file/"
"folder in a small tooltip window."
msgstr ""
"<b>ٹول ٹپس دکھائیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو نتائج کے منظر میں مرکوز فائل/فولڈر کا مکمل راستہ ایک "
"چھوٹے ٹول ٹپ ونڈو میں دکھائی دے گا۔"

#: src/fsearch_preferences.ui:995
msgid ""
"<b>Show icons in name column:</b>\n"
"\n"
"If enabled, file/folder icons will be shown in the name column."
msgstr ""
"<b>نام کے کالم میں آئیکنز دکھائیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو فائل/فولڈر کے آئیکنز نام کے کالم میں دکھائے جائیں گے۔"

#: src/fsearch_preferences.ui:1012
msgid ""
"<b>Remember column configuration:</b>\n"
"\n"
"If enabled, the column configuration of the results view from the previous "
"session will be restored when you open an FSearch window. This includes the "
"size and visibility of all columns."
msgstr ""
"<b>کالم کنفیگریشن یاد رکھیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو جب آپ FSearch ونڈو کھولیں گے تو پچھلے سیشن کے رزلٹ ویو کی "
"کالم کنفیگریشن بحال کر دی جائے گی۔ اس میں تمام کالموں کا سائز اور ان کی نظر "
"آنا (visibility) شامل ہے۔"

#: src/fsearch_preferences.ui:1029
msgid ""
"<b>Remember sort order:</b>\n"
"\n"
"If enabled, the sort order of the results view from the previous session "
"will be restored when you open an FSearch window."
msgstr ""
"<b>ترتیب کو یاد رکھیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو جب آپ FSearch ونڈو کھولیں گے تو پچھلے سیشن کے نتائج کے "
"منظر کی ترتیب بحال کر دی جائے گی۔"

#: src/fsearch_preferences.ui:1046
msgid ""
"<b>Open path with double click in path column:</b>\n"
"\n"
"If enabled, double clicking in the path column will open the selected path."
msgstr ""
"<b>پاتھ کالم میں ڈبل کلک کے ساتھ راستہ کھولیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو پاتھ کالم میں ڈبل کلک کرنے سے منتخب کردہ راستہ کھل جائے "
"گا۔"

#: src/fsearch_preferences.ui:1063
msgid ""
"<b>Single click to open:</b>\n"
"\n"
"If enabled, a single click will open the selected file/folder. If you only "
"want to select a file/folder while this setting is active, you need to hold "
"<i>Ctrl</i> at the same time while clicking the file/folder."
msgstr ""
"<b>کھولنے کے لیے سنگل کلک:</b>\n"
"\n"
"اگر یہ فعال ہے، تو ایک کلک منتخب کردہ فائل/فولڈر کو کھول دے گا۔ اگر آپ اس "
"سیٹنگ کے ساتھ صرف فائل/فولڈر منتخب کرنا چاہتے ہیں، تو آپ کو فائل/فولڈر پر "
"کلک کرتے وقت اسی وقت <i>Ctrl</i> دبائے رکھنا ہوگا۔"

#: src/fsearch_preferences.ui:1080
msgid ""
"<b>Show database indexing status:</b>\n"
"\n"
"If enabled, the path that is currently being indexed is displayed in the "
"statusbar."
msgstr ""
"<b>ڈیٹا بیس انڈیکسنگ کی صورتحال دکھائیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو وہ راستہ جس کی اس وقت انڈیکسنگ ہو رہی ہے اسٹیٹس بار میں "
"ظاہر ہوگا۔"

#: src/fsearch_preferences.ui:1097
msgid ""
"<b>Show warning dialogs:</b>\n"
"\n"
"If enabled, a warning dialog is displayed when a file or folder failed to "
"open."
msgstr ""
"<b>وارننگ ڈائیلاگز دکھائیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو فائل یا فولڈر کھولنے میں ناکامی کی صورت میں ایک وارننگ "
"ڈائیلاگ ظاہر ہوگا۔"

#: src/fsearch_preferences.ui:1114
msgid ""
"<b>Search in path when query contains path separators:</b>\n"
"\n"
"If enabled, search terms containing path separators (i.e. \"/\") will be "
"automatically matched against the full path of a file or folder."
msgstr ""
"<b>جب کویری میں پاتھ سیپریٹر ہو تو پاتھ میں تلاش کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو ایسے سرچ ٹرمز جن میں پاتھ سیپریٹر (مثلاً \"/\") شامل ہوں، "
"وہ خود بخود فائل یا فولڈر کے مکمل پاتھ کے ساتھ میچ کیے جائیں گے۔"

#: src/fsearch_preferences.ui:1131
msgid ""
"<b>Match case when query contains at least one upper case character:</b>\n"
"\n"
"If enabled, search terms containing at least one upper case character will "
"trigger a case-sensitive search. This means a search term like <i>Foo</i> "
"will match <i>FooBar.txt</i> but not <i>foobar.txt</i>."
msgstr ""
"<b>میچ کیس جب کویری میں کم از کم ایک بڑا حرف (upper case) شامل ہو:</b>\n"
"\n"
"اگر یہ فعال ہے، تو وہ تلاش کے الفاظ جن میں کم از کم ایک بڑا حرف شامل ہو، کیس "
"سینسیٹو سرچ کو متحرک کریں گے۔ اس کا مطلب ہے کہ <i>Foo</i> جیسا تلاش کا لفظ "
"<i>FooBar.txt</i> سے میچ ہوگا لیکن <i>foobar.txt</i> سے نہیں اے۔"

#: src/fsearch_preferences.ui:1148
msgid ""
"<b>Hide results when search is empty:</b>\n"
"\n"
"If enabled, no search results are displayed when the search entry is empty.\n"
"\n"
"If disabled, all files and folders will be displayed when the search entry "
"is empty."
msgstr ""
"<b>جب تلاش خالی ہو تو نتائج چھپائیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو جب سرچ انٹری خالی ہوگی تو کوئی تلاش کے نتائج نہیں دکھائے "
"جائیں گے۔\n"
"\n"
"اگر یہ غیر فعال ہے، تو جب سرچ انٹری خالی ہوگی تو تمام فائلیں اور فولڈرز "
"دکھائے جائیں گے۔"

#: src/fsearch_preferences.ui:1167
msgid ""
"<b>Search as you type:</b>\n"
"\n"
"If enabled, the search is automatically updated with every keystroke.\n"
"\n"
"If disabled, the search is only updated when you hit <i>Enter</i> or press "
"the search button. "
msgstr ""
"<b>ٹائپ کرتے ہوئے تلاش کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو ہر کی اسٹروک کے ساتھ تلاش خود بخود اپ ڈیٹ ہو جائے گی۔\n"
"\n"
"اگر یہ غیر فعال ہے، تو تلاش صرف تب اپ ڈیٹ ہوگی جب آپ <i>Enter</i> دبائیں گے "
"یا سرچ بٹن دبائیں گے۔"

#: src/fsearch_preferences.ui:1186
msgid ""
"<b>Update database on start:</b>\n"
"\n"
"If enabled, the database will be updated automatically in the background "
"when you start FSearch."
msgstr ""
"<b>آغاز پر ڈیٹا بیس اپ ڈیٹ کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو جب آپ FSearch شروع کریں گے تو ڈیٹا بیس خود بخود پس منظر "
"میں اپ ڈیٹ ہو جائے گا۔"

#: src/fsearch_preferences.ui:1203
msgid ""
"<b>Included folders:</b>\n"
"\n"
"This list contains all folders you want to include in the database.\n"
"\n"
"\t• <b>Active:</b> If enabled, the path will included in the database to be "
"searched in.\n"
"\t• <b>Path:</b> The full path to be included.\n"
"\t• <b>One Filesystem:</b> If enabled, FSearch won't cross filesystem "
"boundaries for this folder"
msgstr ""
"<b>شمولہت والے فولڈرز:</b>\n"
"\n"
"یہ فہرست ان تمام فولڈرز پر مشتمل ہے جنہیں آپ ڈیٹا بیس میں شامل کرنا چاہتے "
"ہیں۔\n"
"\n"
"\t• <b>فعال:</b> اگر اسے فعال کیا گیا، تو اس راستے کو تلاش کے لیے ڈیٹا بیس "
"میں شامل کر دیا جائے گا۔\n"
"\t• <b>راستہ:</b> وہ مکمل راستہ جسے شامل کیا جانا ہے۔\n"
"\t• <b>ایک فائل سسٹم:</b> اگر اسے فعال کیا گیا، تو FSearch اس فولڈر کے لیے "
"فائل سسٹم کی سرحدوں سے باہر نہیں جائے گا"

#: src/fsearch_preferences.ui:1224
msgid ""
"<b>Add folder to database:</b>\n"
"\n"
"This button opens a dialog where you can select a folder you want to include "
"in the database for searching."
msgstr ""
"<b>ڈیٹا بیس میں فولڈر شامل کریں:</b>\n"
"\n"
"یہ بٹن ایک ڈائیلاگ کھولتا ہے جہاں آپ وہ فولڈر منتخب کر سکتے ہیں جسے آپ تلاش "
"کے لیے ڈیٹا بیس میں شامل کرنا چاہتے ہیں۔"

#: src/fsearch_preferences.ui:1241
msgid ""
"<b>Add a specific path:</b>\n"
"\n"
"Type the full path of a folder here and click the button next to it to "
"include that folder in the database. This is useful for adding a path "
"directly without browsing for it."
msgstr ""
"<b>ایک مخصوص راستہ شامل کریں:</b>\n"
"\n"
"\n"
"یہاں ایک فولڈر کا مکمل راستہ ٹائپ کریں اور اسے ڈیٹا بیس میں شامل کرنے کے لیے "
"اس کے ساتھ والے بٹن پر کلک کریں۔ یہ کسی راستے کو تلاش کیے بغیر براہ راست "
"شامل کرنے کے لیے مفید ہے۔"

#: src/fsearch_preferences.ui:1258
msgid ""
"<b>Remove selected row:</b>\n"
"\n"
"This removes the selected folder from the list of included folders."
msgstr ""
"<b>منتخب کردہ قطار کو ہٹائیں:</b>\n"
"\n"
"یہ منتخب کردہ فولڈر کو شامل شدہ فولڈرز کی فہرست سے ہٹا دیتا ہے۔"

#: src/fsearch_preferences.ui:1275
msgid ""
"<b>Attempt to monitor:</b>\n"
"\n"
"If enabled, FSearch watches this folder for changes and keeps the database "
"up to date automatically, so you don't have to rescan manually.\n"
"\n"
"Monitoring isn't supported on every file system and uses a small amount of "
"system resources per watched folder. For large directory trees with many "
"files the system may run out of resources to watch them all."
msgstr ""
"<b>مانیٹر کرنے کی کوشش کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو FSearch اس فولڈر میں تبدیلیوں پر نظر رکھتا ہے اور ڈیٹا "
"بیس کو خود بخود اپ ڈیٹ رکھتا ہے، تاکہ آپ کو دستی طور پر دوبارہ اسکین نہ کرنا "
"پڑے۔\n"
"\n"
"ہر فائل سسٹم پر مانیٹرنگ کی سہولت دستیاب نہیں ہوتی اور ہر مانیٹر کیے گئے "
"فولڈر کے لیے سسٹم کے وسائل کا تھوڑا سا حصہ استعمال ہوتا ہے۔ بہت زیادہ فائلوں "
"والے بڑے ڈائریکٹری ٹریوں کے لیے، سسٹم ان سب کو مانیٹر کرنے کے لیے وسائل سے "
"خالی ہو سکتا ہے۔"

#: src/fsearch_preferences.ui:1294
msgid ""
"<b>Scan after launch:</b>\n"
"\n"
"If enabled, this folder is rescanned every time FSearch starts, so the "
"database reflects any changes made while FSearch wasn't running."
msgstr ""
"<b>لانچ کے بعد اسکین کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو ہر بار FSearch شروع ہونے پر اس فولڈر کو دوبارہ اسکین کیا "
"جائے گا، تاکہ ڈیٹا بیس میں وہ تمام تبدیلیاں نظر آئیں جو FSearch چلنے کے "
"دوران نہیں کی گئی تھیں۔"

#: src/fsearch_preferences.ui:1311
msgid ""
"<b>Stay on one file system:</b>\n"
"\n"
"If enabled, FSearch won't cross file system boundaries while scanning this "
"folder. Mounted file systems below it (e.g. external drives or network "
"shares) are skipped."
msgstr ""
"<b>ایک فائل سسٹم پر رہیں:</b>\n"
"\n"
"اگر اسے فعال کیا گیا، تو FSearch اس فولڈر کو اسکین کرتے وقت فائل سسٹم کی "
"حدود سے باہر نہیں جائے گا۔ اس کے نیچے لگے ہوئے فائل سسٹم (مثلاً بیرونی "
"ڈرائیوز یا نیٹ ورک شیئرز) کو چھوڑ دیا جائے گا۔"

#: src/fsearch_preferences.ui:1328
msgid ""
"<b>Rescan every:</b>\n"
"\n"
"If enabled, this folder is rescanned automatically at the given interval. "
"Use the hours and minutes fields to set how often the rescan happens.\n"
"\n"
"This is useful for folders on file systems that can't be monitored for "
"changes."
msgstr ""
"<b>ہر بار دوبارہ اسکین کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو اس فولڈر کو دیے گئے وقفے پر خود بخود دوبارہ اسکین کیا "
"جائے گا۔ دوبارہ اسکن کرنے کی کثرت طے کرنے کے لیے گھنٹوں اور منٹوں کے خانوں "
"کا استعمال کریں۔\n"
"\n"
"یہ ان فولڈرز کے لیے مفید ہے جو فائل سسٹمز پر ہوتے ہیں جن میں تبدیلیوں کی "
"نگرانی نہیں کی جا سکتی۔"

#: src/fsearch_preferences.ui:1347
msgid ""
"<b>Exclude rules:</b>\n"
"\n"
"This list contains rules for the files and folders you want to exclude from "
"the database.\n"
"\n"
"\t• <b>Active:</b> If enabled, the rule is applied and matching items are "
"excluded.\n"
"\t• <b>Pattern:</b> The text matched against each item, interpreted "
"according to the Type.\n"
"\t• <b>Type:</b> How the pattern is interpreted — <i>Literal</i> (exact "
"text), <i>Wildcard</i> (using * and ?) or <i>Regex</i> (a regular "
"expression).\n"
"\t• <b>Match:</b> Whether the pattern is matched against the item's <i>Full "
"Path</i> or only its <i>Basename</i> (the name without the path).\n"
"\t• <b>Applies To:</b> Whether the rule affects <i>Files</i>, <i>Folders</i> "
"or both."
msgstr ""
"<b>خارج کرنے کے قوانین (Exclude rules):</b>\n"
"\n"
"یہ فہرست ان فائلوں اور فولڈرز کے لیے قواعدات پر مشتمل ہے جنہیں آپ ڈیٹا بیس "
"سے نکالنا چاہتے ہیں۔\n"
"\n"
"\t• <b>فعال (Active):</b> اگر اسے فعال کیا گیا ہو، تو قاعدہ لاگو ہوگا اور "
"ملنے والی اشیاء کو خارج کر دیا جائے گا۔\n"
"\t• <b>پیٹرن (Pattern):</b> وہ متن جو ہر آئٹم کے خلاف میچ کیا جاتا ہے، جسے "
"Type کے مطابق سمجھا جاتا ہے۔\n"
"\t• <b>قسم (Type):</b> پیٹرن کو کیسے سمجھا جائے گا — <i>Literal</i> (بالکل "
"وہی ٹیکسٹ)، <i>Wildcard</i> (* اور ? کا استعمال کرتے ہوئے) یا <i>Regex</i> "
"(ایک باقاعدہ اظہار/regular expression)۔\n"
"\t• <b>میچ (Match):</b> آیا پیٹرن کو آئٹم کے <i>مکمل راستے (Full Path)</i> "
"کے خلاف میچ کیا جائے گا یا صرف اس کے <i>بنیادی نام (Basename)</i> (راستے کے "
"بغیر نام) کے ساتھ۔\n"
"\t• <b>کس پر لاگو ہوتا ہے (Applies To):</b> آیا یہ قاعدہ <i>فائلوں (Files)</"
"i>، <i>فولڈرز (Folders)</i> یا دونوں پر اثر انداز ہوتا ہے۔"

#: src/fsearch_preferences.ui:1370
msgid ""
"<b>Add exclude rule:</b>\n"
"\n"
"This adds a new, empty rule to the list. Edit its Pattern, Type, Match and "
"Applies To columns to control what gets excluded from the database."
msgstr ""
"<b>خارج کرنے کا قاعدہ شامل کریں:</b>\n"
"\n"
"\n"
"یہ فہرست میں ایک نیا، خالی قاعدہ شامل کرتا ہے۔ ڈیٹا بیس سے کس چیز کو خارج "
"کیا جائے اس پر قابو پانے کے لیے اس کے Pattern، Type، Match اور Applies To "
"کالمز کو تبدیل کریں۔"

#: src/fsearch_preferences.ui:1387
msgid ""
"<b>Remove selected row:</b>\n"
"\n"
"This removes the selected rule from the list of exclude rules."
msgstr ""
"<b>منتخب کردہ قطار کو ہٹائیں:</b>\n"
"\n"
"یہ منتخب کردہ قاعدے کو خارج کردہ قواعد کی فہرست سے ہٹا دیتا ہے۔"

#: src/fsearch_preferences.ui:1404
msgid ""
"<b>Restore default exclude rules:</b>\n"
"\n"
"This button restores the default set of exclude rules.\n"
"\n"
"⚠ All rules which were created or edited by the user will be lost! ⚠"
msgstr ""
"<b>ڈیفالٹ خارج کرنے کے قوانین بحال کریں:</b>\n"
"\n"
"یہ بٹن ڈیفالٹ سیٹ کے خارج کرنے کے قوانین کو بحال کرتا ہے۔\n"
"\n"
"⚠ صارف کی طرف سے بنائے گئے یا ترمیم کیے گئے تمام قوانین ضائع ہو جائیں گے! ⚠"

#: src/fsearch_preferences.ui:1423
msgid ""
"<b>Exclude files and folders from database:</b>\n"
"\n"
"This is a semi-colon separated list of files (or folders) you want to "
"exclude from the database. For example <i>.git;.cache;*.swp</i> will exclude "
"all files or folders which are called either <i>.git</i> or <i>.cache</i> or "
"end with <i>.swp</i>."
msgstr ""
"<b>فائلوں اور فولڈرز کو ڈیٹا بیس سے نکالیں:</b>\n"
"\n"
"یہ ان فائلوں (یا فولڈرز) کی سیمی-کولن کے ذریعے الگ کردہ فہرست ہے جنہیں آپ "
"ڈیٹا بیس سے نکالنا چاہتے ہیں۔ مثال کے طور پر <i>.git;.cache;*.swp</i> ان "
"تمام فائلوں یا فولڈرز کو نکال دے گا جن کا نام <i>.git</i> یا <i>.cache</i> "
"ہے یا جو <i>.swp</i> پر ختم ہوتے ہیں۔"

#: src/fsearch_preferences.ui:1440
msgid ""
"<b>Exclude hidden files and folders:</b>\n"
"\n"
"If enabled, hidden files and folders will be excluded from the database "
"<i>(i.e. all files or folders which start with a dot character)</i>."
msgstr ""
"<b>چھپی ہوئی فائلیں اور فولڈرز نکال دیں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو چھپی ہوئی فائلیں اور فولڈرز ڈیٹا بیس سے نکال دیے جائیں گے "
"<i> (یعنی وہ تمام فائلیں یا فولڈرز جو ڈاٹ کے نشان سے شروع ہوتے ہیں)</i>۔"

#: src/fsearch_preferences.ui:1457
msgid "Focus a setting to get a detailed description of what it does."
msgstr "تفصیلی تفصیلات جاننے کے لیے کسی سیٹنگ پر توجہ مرکوز کریں۔"

#: src/fsearch_preferences.ui:1470
msgid ""
"<b>Periodically update database at a specific time interval:</b>\n"
"\n"
"If enabled and as long as FSearch is running, the database will be updated "
"periodically with the given time interval.\n"
"\n"
"If you want to update the database in the background, even when FSearch is "
"not running, you should use tools like cron or systemd timers to "
"periodically trigger the update with:\n"
"\n"
"<i><tt>fsearch --update-database</tt></i>"
msgstr ""
"<b>ایک مخصوص وقت کے وقفے پر ڈیٹا بیس کو باقاعدگی سے اپ ڈیٹ کریں:</b>\n"
"\n"
"اگر یہ فعال ہے اور جب تک FSearch چل رہا ہے، ڈیٹا بیس دیے گئے وقت کے وقفے کے "
"ساتھ باقاعدگی سے اپ ڈیٹ ہوگا۔\n"
"\n"
"اگر آپ چاہتے ہیں کہ ڈیٹا بیس پس منظر (background) میں اپ ڈیٹ ہو، یہاں تک کہ "
"جب FSearch نہیں چل رہا ہو، تو آپ کو cron یا systemd ٹائمر جیسے ٹولز استعمال "
"کرنے چاہئیں تاکہ درج ذیل کمانڈ کے ساتھ باقاعدگی سے اپ ڈیٹ کو متحرک کیا جا "
"سکے:\n"
"\n"
"<i><tt>fsearch --update-database</tt></i>"

#: src/fsearch_preferences.ui:1491
msgid ""
"<b>Launch desktop files:</b>\n"
"\n"
"If enabled, activating a <i>.desktop</i> file will launch the application "
"defined within that file. This way FSearch can act like an application "
"launcher. Otherwise the <i>.desktop</i> file will be opened with the default "
"handler for this type of files, which is usually a text editor."
msgstr ""
"<b>ڈیسک ٹاپ فائلیں شروع کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو ایک <i>.desktop</i> فائل کو فعال کرنے سے اس فائل میں بیان "
"کردہ ایپلیکیشن شروع ہو جائے گی۔ اس طرح FSearch ایک ایپلیکیشن لانچر کے طور پر "
"کام کر سکتا ہے۔ ورنہ، <i>.desktop</i> فائل اس قسم کی فائلوں کے لیے ڈیفالٹ "
"ہینڈلر کے ساتھ کھلے گی، جو عام طور پر ایک ٹیکسٹ ایڈیٹر ہوتا ہے۔"

#: src/fsearch_preferences.ui:1508
msgid ""
"<b>Filters:</b>\n"
"\n"
"This is a list of all available filters. A filter is a predefined search.\n"
"\n"
"\t• <b>Name:</b> A unique and descriptive identifier for the filter\n"
"\t• <b>Macro:</b> By typing the macro text followed by a ':' you can enable "
"the filter on demand\n"
"\t• <b>Query:</b> The search term by which the database should be filtered"
msgstr ""
"<b>فلٹرز:</b>\n"
"\n"
"یہ تمام دستیاب فلٹرز کی فہرست ہے۔ ایک فلٹر ایک پہلے سے طے شدہ تلاش ہے۔\n"
"\n"
"\t• <b>نام:</b> فلٹر کے لیے ایک منفرد اور وضاحتی شناخت\n"
"\t• <b>میکرو:</b> میکرو ٹیکسٹ لکھنے اور اس کے بعد ':' لگانے سے آپ ضرورت کے "
"مطابق فلٹر کو فعال کر سکتے ہیں\n"
"\t• <b>کوئری:</b> وہ تلاش کی گئی اصطلاح جس کے ذریعے ڈیٹا بیس کو فلٹر کیا "
"جانا چاہیے"

#: src/fsearch_preferences.ui:1529
msgid ""
"<b>Add a new filter:</b>\n"
"\n"
"This button opens a dialog where you can edit a new filter."
msgstr ""
"<b>نیا فلٹر شامل کریں:</b>\n"
"\n"
"یہ بٹن ایک ڈائیلاگ کھولتا ہے جہاں آپ نیا فلٹر ایڈٹ کر سکتے ہیں۔"

#: src/fsearch_preferences.ui:1546
msgid ""
"<b>Remove selected filter:</b>\n"
"\n"
"This button removes the currently selected filter."
msgstr ""
"<b>منتخب کردہ فلٹر ختم کریں:</b>\n"
"\n"
"یہ بٹن موجودہ منتخب شدہ فلٹر کو ختم کر دیتا ہے۔"

#: src/fsearch_preferences.ui:1563
msgid ""
"<b>Edit selected filter:</b>\n"
"\n"
"This button opens a dialog where you can edit the selected filter."
msgstr ""
"<b>منتخب کردہ فلٹر ایڈٹ کریں:</b>\n"
"\n"
"یہ بٹن ایک ڈائیلاگ کھولتا ہے جہاں آپ منتخب کردہ فلٹر کو ایڈٹ کر سکتے ہیں۔"

#: src/fsearch_preferences.ui:1580
msgid ""
"<b>Restore default filters:</b>\n"
"\n"
"This button restores the default filter configuration.\n"
"\n"
"⚠ All filters which were created or edited by the user will be lost! ⚠"
msgstr ""
"<b>ڈیفالٹ فلٹرز بحال کریں:</b>\n"
"\n"
"یہ بٹن ڈیفالٹ فلٹر کنفیگریشن کو بحال کرتا ہے۔\n"
"\n"
"⚠ صارف کے ذریعے بنائے گئے یا تبدیل کیے گئے تمام فلٹر ختم ہو جائیں گے! ⚠"

#: src/fsearch_preferences.ui:1599
msgid ""
"<b>Exit on Escape:</b>\n"
"\n"
"If enabled, FSearch exits when the Escape key is pressed instead of the "
"window being minimized."
msgstr ""
"<b>ایسکیپ پر بند کریں:</b>\n"
"\n"
"اگر یہ فعال ہے، تو ونڈو کو چھوٹا کرنے کے بجائے ایسکیپ (Escape) بٹن دبانے پر "
"FSearch بند ہو جائے گا۔"

#: src/fsearch_preferences.ui:1618 src/fsearch_window.ui:290
