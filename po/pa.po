#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:4 src/main.c:36
msgid "FSearch"
msgstr "FSearch"

#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:5
msgid "A file search application focusing on performance and advanced features"
msgstr "ਪ੍ਰਦਰਸ਼ਨ ਅਤੇ ਉੱਨਤ ਵਿਸ਼ੇਸ਼ਤਾਵਾਂ 'ਤੇ ਧਿਆਨ ਕੇਂਦ੍ਰਤ ਕਰਨ ਵਾਲੀ ਇੱਕ ਫਾਈਲ ਖੋਜ ਐਪਲੀਕੇਸ਼ਨ"

#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:10
msgid "search;fsearch;files;folders;music;video;documents;find;tool;everything;"
msgstr "ਖੋਜ;fsearch;ਫਾਈਲਾਂ;ਫੋਲਡਰ;ਸੰਗੀਤ;ਵੀਡੀਓ;ਦਸਤਾਵੇਜ਼;ਲੱਭੋ;ਸੰਦ;ਸਭ ਕੁਝ;"

#: data/io.github.cboxdoerfer.FSearch.desktop.in.in:12
msgid "File Search Utility"
msgstr "ਫਾਈਲ ਖੋਜ ਉਪਯੋਗਤਾ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:8
msgid "A graphical file search application"
msgstr "ਇੱਕ ਗ੍ਰਾਫਿਕਲ ਫਾਈਲ ਖੋਜ ਐਪਲੀਕੇਸ਼ਨ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:10
msgid ""
"FSearch helps you to find files and folders as easy and fast as possible. "
"Just type a few letters and search results will appear almost instantly."
msgstr "FSearch ਤੁਹਾਨੂੰ ਫਾਈਲਾਂ ਅਤੇ ਫੋਲਡਰਾਂ ਨੂੰ ਜਿੰਨਾ ਸੰਭਵ ਹੋ ਸਕੇ ਆਸਾਨ ਅਤੇ ਤੇਜ਼ੀ ਨਾਲ ਲੱਭਣ ਵਿੱਚ ਮਦਦ ਕਰਦਾ ਹੈ। ਬਸ ਕੁਝ ਅੱਖਰ ਟਾਈਪ ਕਰੋ ਅਤੇ ਖੋਜ ਨਤੀਜੇ ਲਗਭਗ ਤੁਰੰਤ ਦਿਖਾਈ ਦੇਣਗੇ।"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:14
msgid ""
"There are a lot of features which make searching as efficient and powerful "
"as possible. Such as:"
msgstr "ਇੱਥੇ ਬਹੁਤ ਸਾਰੀਆਂ ਵਿਸ਼ੇਸ਼ਤਾਵਾਂ ਹਨ ਜੋ ਖੋਜ ਨੂੰ ਜਿੰਨਾ ਸੰਭਵ ਹੋ ਸਕੇ ਕੁਸ਼ਲ ਅਤੇ ਸ਼ਕਤੀਸ਼ਾਲੀ ਬਣਾਉਂਦੀਆਂ ਹਨ। ਜਿਵੇ ਕੀ:"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:19
msgid ""
"Ignore case (e.g. searching for \"<code>fsearch</code>\" will match "
"\"FSearch\" as well)"
msgstr "ਕੇਸ ਨੂੰ ਅਣਡਿੱਠ ਕਰੋ (ਉਦਾਹਰਨ ਲਈ \\\"<code>fsearch</code>\\\" ਦੀ ਖੋਜ ਕਰਨਾ \\\"FSearch\\\" ਨਾਲ ਵੀ ਮੇਲ ਖਾਂਦਾ ਹੈ)"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:20
msgid "Regular expressions"
msgstr "ਨਿਯਮਤ ਸਮੀਕਰਨ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:21
msgid "Wildcard support"
msgstr "ਵਾਈਲਡਕਾਰਡ ਸਹਾਇਤਾ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:22
msgid "Filter support (e.g. only search for audio files)"
msgstr "ਫਿਲਟਰ ਸਮਰਥਨ (ਉਦਾਹਰਣ ਲਈ ਸਿਰਫ ਆਡੀਓ ਫਾਈਲਾਂ ਦੀ ਖੋਜ)"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:23
msgid "Exclude certain files and folders"
msgstr "ਕੁਝ ਫਾਈਲਾਂ ਅਤੇ ਫੋਲਡਰਾਂ ਨੂੰ ਬਾਹਰ ਕੱਢੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:24
msgid "Fast sort by name, path, size, modification time and extension"
msgstr "ਨਾਮ, ਮਾਰਗ, ਆਕਾਰ, ਸੋਧ ਸਮਾਂ ਅਤੇ ਐਕਸਟੈਂਸ਼ਨ ਦੁਆਰਾ ਤੇਜ਼ੀ ਨਾਲ ਛਾਂਟੀ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:26
msgid ""
"<em>Note:</em> Due to Flatpak's sandboxing, FSearch can't find every file on "
"your system."
msgstr "<em>ਨੋਟ:</em> ਫਲੈਟਪੈਕ ਦੇ ਸੈਂਡਬਾਕਸਿੰਗ ਦੇ ਕਾਰਨ, FSearch ਤੁਹਾਡੇ ਸਿਸਟਮ 'ਤੇ ਹਰੇਕ ਫਾਈਲ ਨੂੰ ਨਹੀਂ ਲੱਭ ਸਕਦਾ ਹੈ।"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:35
msgid "The default UI layout"
msgstr "ਪੂਰਵ-ਨਿਰਧਾਰਤ UI ਖਾਕਾ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:41
msgid "A layout more closely following GNOME HIGs"
msgstr "ਗਨੋਮ HIGs ਨੂੰ ਹੋਰ ਵੀ ਨੇੜਿਓਂ ਪਾਲਣ ਵਾਲਾ ਖਾਕਾ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:49
msgid "search"
msgstr "ਖੋਜ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:50
msgid "fsearch"
msgstr "fsearch"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:51
msgid "files"
msgstr "ਫਾਈਲਾਂ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:52
msgid "folders"
msgstr "ਫੋਲਡਰ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:53
msgid "music"
msgstr "ਸੰਗੀਤ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:54
msgid "video"
msgstr "ਵੀਡੀਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:55
msgid "documents"
msgstr "ਦਸਤਾਵੇਜ਼"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:56
msgid "find"
msgstr "ਲੱਭੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:57
msgid "tool"
msgstr "ਸੰਦ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:58
msgid "everything"
msgstr "ਸਭ ਕੁਝ"

#. Kept for appstreamcli < 1.0 (e.g. Ubuntu 20.04/22.04 PPA builds), which doesn't know <developer>.
#. Translators: please do NOT translate this.
#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:77
msgid "Christian Boxdörfer"
msgstr "ਕ੍ਰਿਸ਼ਚੀਅਨ ਬਾਕਸਡੋਰਫਰ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:89
msgid "DB rewrite"
msgstr "DB ਮੁੜ ਲਿਖਣਾ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:90
msgid "DB: Add support for filesystem monitoring"
msgstr "DB: ਫਾਈਲ ਸਿਸਟਮ ਨਿਗਰਾਨੀ ਲਈ ਸਮਰਥਨ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:91
msgid ""
"DB: Allow files and folders to be excluded based on fixed patterns, "
"wildcards or regular expressions"
msgstr "DB: ਫਾਈਲਾਂ ਅਤੇ ਫੋਲਡਰਾਂ ਨੂੰ ਫਿਕਸਡ ਪੈਟਰਨਾਂ, ਵਾਈਲਡਕਾਰਡ ਜਾਂ ਨਿਯਮਤ ਸਮੀਕਰਨ ਦੇ ਆਧਾਰ 'ਤੇ ਬਾਹਰ ਰੱਖਣ ਦੀ ਇਜਾਜ਼ਤ ਦਿਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:92
msgid ""
"DB: Allow included folders to be scheduled and scanned after launch "
"independently"
msgstr "DB: ਸੁਤੰਤਰ ਤੌਰ 'ਤੇ ਲਾਂਚ ਕਰਨ ਤੋਂ ਬਾਅਦ ਸ਼ਾਮਲ ਕੀਤੇ ਫੋਲਡਰਾਂ ਨੂੰ ਅਨੁਸੂਚਿਤ ਅਤੇ ਸਕੈਨ ਕਰਨ ਦੀ ਇਜਾਜ਼ਤ ਦਿਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:93
msgid "DB: Make rescanning more efficient"
msgstr "DB: ਰੀਸਕੈਨਿੰਗ ਨੂੰ ਹੋਰ ਕੁਸ਼ਲ ਬਣਾਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:94
msgid "DB: Store database config in DB file"
msgstr "DB: DB ਫਾਈਲ ਵਿੱਚ ਸਟੋਰ ਡੇਟਾਬੇਸ ਸੰਰਚਨਾ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:95
msgid "DB: Add checksum to DB file"
msgstr "DB: DB ਫਾਈਲ ਵਿੱਚ ਚੈੱਕਸਮ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:96
msgid "Make icon and file info gathering asynchronous (no UI blocking)"
msgstr "ਆਈਕਨ ਅਤੇ ਫਾਈਲ ਜਾਣਕਾਰੀ ਇਕੱਠੀ ਕਰਨ ਨੂੰ ਅਸਿੰਕ੍ਰੋਨਸ ਬਣਾਓ (ਕੋਈ UI ਬਲਾਕਿੰਗ ਨਹੀਂ)"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:97
msgid "Reduce memory usage"
msgstr "ਮੈਮੋਰੀ ਦੀ ਵਰਤੋਂ ਘਟਾਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:98
msgid "Add contextual help for all preferences"
msgstr "ਸਾਰੀਆਂ ਤਰਜੀਹਾਂ ਲਈ ਪ੍ਰਸੰਗਿਕ ਮਦਦ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:99
msgid "Numerous bug fixes and stability and performance improvements"
msgstr "ਕਈ ਬੱਗ ਫਿਕਸ ਅਤੇ ਸਥਿਰਤਾ ਅਤੇ ਪ੍ਰਦਰਸ਼ਨ ਸੁਧਾਰ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:106
msgid "New search engine"
msgstr "ਨਵਾਂ ਖੋਜ ਇੰਜਣ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:107
msgid "Greatly improved highlighting of search terms"
msgstr "ਖੋਜ ਸ਼ਬਦਾਂ ਦੀ ਹਾਈਲਾਈਟਿੰਗ ਵਿੱਚ ਬਹੁਤ ਸੁਧਾਰ ਕੀਤਾ ਗਿਆ ਹੈ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:108
msgid "Custom filters"
msgstr "ਕਸਟਮ ਫਿਲਟਰ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:109
msgid "Improved sort performance"
msgstr "ਕ੍ਰਮਬੱਧ ਪ੍ਰਦਰਸ਼ਨ ਵਿੱਚ ਸੁਧਾਰ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:110
msgid "Improved scroll performance"
msgstr "ਸੁਧਾਰੀ ਹੋਈ ਸਕ੍ਰੋਲ ਕਾਰਗੁਜ਼ਾਰੀ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:111
msgid "Remember file selection after a database update"
msgstr "ਇੱਕ ਡਾਟਾਬੇਸ ਅੱਪਡੇਟ ਦੇ ਬਾਅਦ ਫਾਇਲ ਚੋਣ ਨੂੰ ਯਾਦ ਰੱਖੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:112
msgid "Automatically scroll the result list in rubberband selection mode"
msgstr "ਰਬਰਬੈਂਡ ਚੋਣ ਮੋਡ ਵਿੱਚ ਨਤੀਜੇ ਸੂਚੀ ਨੂੰ ਆਟੋਮੈਟਿਕਲੀ ਸਕ੍ਰੋਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:113
msgid "Invert selection with rubber band when 'Ctrl' is pressed"
msgstr "ਜਦੋਂ 'Ctrl' ਦਬਾਇਆ ਜਾਂਦਾ ਹੈ ਤਾਂ ਰਬੜ ਬੈਂਡ ਨਾਲ ਚੋਣ ਨੂੰ ਉਲਟਾਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:114
msgid "Focus search entry when the main window gets activated"
msgstr "ਜਦੋਂ ਮੁੱਖ ਵਿੰਡੋ ਸਰਗਰਮ ਹੋ ਜਾਂਦੀ ਹੈ ਤਾਂ ਖੋਜ ਇੰਦਰਾਜ਼ 'ਤੇ ਫੋਕਸ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:115
msgid "Add filter for applications (i.e. .desktop files)"
msgstr "ਐਪਲੀਕੇਸ਼ਨਾਂ ਲਈ ਫਿਲਟਰ ਸ਼ਾਮਲ ਕਰੋ (ਜਿਵੇਂ ਕਿ .ਡੈਸਕਟਾਪ ਫਾਈਲਾਂ)"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:116
msgid ""
"Add option to launch applications directly instead of opening the .desktop "
"files"
msgstr ".desktop ਫਾਈਲਾਂ ਨੂੰ ਖੋਲ੍ਹਣ ਦੀ ਬਜਾਏ ਸਿੱਧੇ ਐਪਲੀਕੇਸ਼ਨਾਂ ਨੂੰ ਲਾਂਚ ਕਰਨ ਲਈ ਵਿਕਲਪ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:117
msgid "Show application icons for .desktop files"
msgstr ".desktop ਫਾਈਲਾਂ ਲਈ ਐਪਲੀਕੇਸ਼ਨ ਆਈਕਨ ਦਿਖਾਓ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:118
msgid "Add .odp and .ods files to document filter"
msgstr "ਦਸਤਾਵੇਜ਼ ਫਿਲਟਰ ਵਿੱਚ .odp ਅਤੇ .ods ਫਾਈਲਾਂ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:119
msgid ""
"'Open with' menu now only shows applications which can handle the selected "
"files"
msgstr "'ਓਪਨ ਵਿਦ' ਮੀਨੂ ਹੁਣ ਸਿਰਫ਼ ਉਹਨਾਂ ਐਪਲੀਕੇਸ਼ਨਾਂ ਨੂੰ ਦਿਖਾਉਂਦਾ ਹੈ ਜੋ ਚੁਣੀਆਂ ਗਈਆਂ ਫਾਈਲਾਂ ਨੂੰ ਸੰਭਾਲ ਸਕਦੀਆਂ ਹਨ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:120
msgid ""
"Improved opening of multiple files with the same type (they get now passed "
"as a list to applications, instead of one by one)"
msgstr "ਇੱਕੋ ਕਿਸਮ ਦੀਆਂ ਕਈ ਫਾਈਲਾਂ ਨੂੰ ਖੋਲ੍ਹਣ ਵਿੱਚ ਸੁਧਾਰ ਕੀਤਾ ਗਿਆ ਹੈ (ਉਹ ਹੁਣ ਇੱਕ ਤੋਂ ਬਾਅਦ ਇੱਕ ਦੀ ਬਜਾਏ ਐਪਲੀਕੇਸ਼ਨਾਂ ਦੀ ਸੂਚੀ ਦੇ ਰੂਪ ਵਿੱਚ ਪਾਸ ਹੋ ਜਾਂਦੇ ਹਨ)"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:121
msgid "Better support for opening files in sandboxed mode"
msgstr "ਸੈਂਡਬੌਕਸਡ ਮੋਡ ਵਿੱਚ ਫਾਈਲਾਂ ਖੋਲ੍ਹਣ ਲਈ ਬਿਹਤਰ ਸਮਰਥਨ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:122
msgid ""
"Add menu items with links to the issue tracker, forum and donation pages"
msgstr "ਮੁੱਦੇ ਟਰੈਕਰ, ਫੋਰਮ ਅਤੇ ਦਾਨ ਪੰਨਿਆਂ ਦੇ ਲਿੰਕਾਂ ਦੇ ਨਾਲ ਮੀਨੂ ਆਈਟਮਾਂ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:123
msgid "Improve support for non-Linux systems"
msgstr "ਗੈਰ-ਲੀਨਕਸ ਸਿਸਟਮਾਂ ਲਈ ਸਮਰਥਨ ਵਿੱਚ ਸੁਧਾਰ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:124
msgid ""
"Add option to exit FSearch when Escape is pressed instead of minimizing the "
"window"
msgstr "ਵਿੰਡੋ ਨੂੰ ਛੋਟਾ ਕਰਨ ਦੀ ਬਜਾਏ Escape ਦਬਾਉਣ 'ਤੇ FSearch ਤੋਂ ਬਾਹਰ ਨਿਕਲਣ ਲਈ ਵਿਕਲਪ ਸ਼ਾਮਲ ਕਰੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:125
msgid "Exclude '/proc' and '/sys' by default"
msgstr "ਮੂਲ ਰੂਪ ਵਿੱਚ '/proc' ਅਤੇ '/sys' ਨੂੰ ਬਾਹਰ ਕੱਢੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:126
msgid "Open context menu when 'Menu' key or 'Shift + F10' are pressed"
msgstr "ਜਦੋਂ 'ਮੇਨੂ' ਕੁੰਜੀ ਜਾਂ 'Shift + F10' ਦਬਾਈ ਜਾਂਦੀ ਹੈ ਤਾਂ ਸੰਦਰਭ ਮੀਨੂ ਖੋਲ੍ਹੋ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:127
msgid "and tons of bug fixes, translation updates and smaller improvements"
msgstr "ਅਤੇ ਬਹੁਤ ਸਾਰੇ ਬੱਗ ਫਿਕਸ, ਅਨੁਵਾਦ ਅੱਪਡੇਟ ਅਤੇ ਛੋਟੇ ਸੁਧਾਰ"

#: data/io.github.cboxdoerfer.FSearch.metainfo.xml.in:133
msgid "Initial release."
msgstr "ਸ਼ੁਰੂਆਤੀ ਰੀਲੀਜ਼।"

#: src/fsearch.c:181
msgid "translator-credits"
msgstr "ਅਨੁਵਾਦਕ-ਕ੍ਰੈਡਿਟ"

#: src/fsearch.c:183
msgid "A search utility focusing on performance and advanced features"
msgstr "ਪ੍ਰਦਰਸ਼ਨ ਅਤੇ ਉੱਨਤ ਵਿਸ਼ੇਸ਼ਤਾਵਾਂ 'ਤੇ ਧਿਆਨ ਕੇਂਦਰਿਤ ਕਰਨ ਵਾਲੀ ਇੱਕ ਖੋਜ ਉਪਯੋਗਤਾ"

#: src/fsearch.c:330
