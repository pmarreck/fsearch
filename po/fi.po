#: src/fsearch_cli.c:169
msgid "Using stale FSearch index; automatic reindexing is disabled."
msgstr ""
"Käytetään vanhentunutta FSearch-hakemistoa; automaattinen uudelleenluonti on "
"poissa käytöstä."

#: src/fsearch_cli.c:239
msgid ""
"\n"
"Index refresh options:\n"
"  --refresh, --refresh-index    Rescan before searching\n"
"  --no-reindex                  Use the existing index without rescanning\n"
"  --reindex-interval SECONDS    Refresh when the index is this old\n"
msgstr ""
"\n"
"Indeksin päivitysvaihtoehdot:\n"
"  --refresh, --refresh-index    Skannaa uudelleen ennen hakua\n"
"  --no-reindex                  Käytä olemassa olevaa indeksiä ilman "
"uudelleenskannausta\n"
"  --reindex-interval SECONDS    Päivitä, kun indeksi on näin vanha\n"

#: src/fsearch_cli.c:526
msgid "fsearch: --reindex-interval requires a non-negative number of seconds\n"
msgstr "fsearch: --reindex-interval vaatii positiivisen sekuntimäärän\n"

#: src/fsearch_cli.c:577
msgid "fsearch: index is unavailable and automatic reindexing is disabled\n"
msgstr ""
"fsearch: hakemistoa ei ole käytettävissä ja automaattinen uudelleenluonti on "
"poissa käytöstä\n"

